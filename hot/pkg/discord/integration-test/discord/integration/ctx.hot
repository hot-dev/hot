::discord::integration::ctx ns
meta {
    doc: """Placeholder credential wiring for the discord integration suite: copies `DISCORD_BOT_TOKEN`, `DISCORD_PUBLIC_KEY` from the environment into context at load. Unset variables are skipped."""
}

set-ctx fn (key: Str, env-name: Str, secret: Bool): Null {
    value ::hot::env/get(env-name, "")
    cond {
        is-empty(value) => { null }
        secret => {
            ::hot::ctx/set-secret(key, value)
            null
        }
        => {
            ::hot::ctx/set(key, value)
            null
        }
    }
}

wired [
    set-ctx("discord.bot.token", "DISCORD_BOT_TOKEN", true),
    set-ctx("discord.public.key", "DISCORD_PUBLIC_KEY", false)
]
