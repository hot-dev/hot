list-all-configurations
meta {doc: """GET /v1/terminal/configurations - List all Configurations"""}
fn (ending-before: Str, expand: Str, is-account-default: Str, limit: Str, starting-after: Str, request: GetTerminalConfigurationsRequest): GetTerminalConfigurationsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/terminal/configurations?ending_before=${ending-before}&expand=${expand}&is_account_default=${is-account-default}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetTerminalConfigurationsResponse(response.body), err(HttpError(response)))
}

