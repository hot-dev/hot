// ============================================================================
// Execute Webhook (no bot auth required — uses webhook token)
// ============================================================================

ExecuteWebhookRequest type {
  webhook_id: Str,
  webhook_token: Str,
  wait: Bool?,
  thread_id: Str?,
  content: Str?,
  username: Str?,
  avatar_url: Str?,
  tts: Bool?,
  embeds: Vec<Map>?,
  allowed_mentions: Map?,
  components: Vec<Map>?,
  flags: Int?
}

execute-webhook
meta {
    doc: """
POST /webhooks/{webhook_id}/{webhook_token} - Execute a webhook to send a message. Does not require bot authentication. Set `wait: true` to get the created message object back.

**Example**

```hot
::webhooks ::discord::webhooks

response ::webhooks/execute-webhook(::webhooks/ExecuteWebhookRequest({
  webhook_id: "123456789",
  webhook_token: "my-webhook-token",
  content: "Alert: deployment complete!",
  wait: true
}))
response.id  // => "message-id" (only when wait=true)
```
"""
}
fn (request: ExecuteWebhookRequest): Map {
  body {
    content: request.content,
    username: request.username,
    avatar_url: request.avatar_url,
    tts: request.tts,
    embeds: request.embeds,
    allowed_mentions: request.allowed_mentions,
    components: request.components,
    flags: request.flags
  }

  query-wait if(eq(request.wait, true), "true", "")
  query-thread if(is-some(request.thread_id), request.thread_id, "")
  response ::hot::http/request(::hot::http/HttpRequest({
    method: "POST",
    url: `${::discord::core/BASE_URL}/webhooks/${request.webhook_id}/${request.webhook_token}?wait=${query-wait}&thread_id=${query-thread}`,
    headers: {Content-Type: "application/json"},
    body: to-json(untype(body))
  }))
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

