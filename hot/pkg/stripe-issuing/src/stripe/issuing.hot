  response api-request("POST", `${::stripe/BASE_URL}/v1/issuing/tokens/${token}`, {}, request)
  if(is-ok-response(response), PostIssuingTokensTokenResponse(response.body), err(HttpError(response)))
}

GetIssuingTransactionsRequest type {

}

GetIssuingTransactionsResponse type {
    data: Vec<IssuingTransaction>,
    has_more: Bool,
    object: "list",
    url: Str
}


list-all-transactions
meta {doc: """GET /v1/issuing/transactions - List all transactions"""}
fn (card: Str, cardholder: Str, created: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, type-param: Str, request: GetIssuingTransactionsRequest): GetIssuingTransactionsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/issuing/transactions?card=${card}&cardholder=${cardholder}&created=${created}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}&type=${type-param}`, {}, request)
  if(is-ok-response(response), GetIssuingTransactionsResponse(response.body), err(HttpError(response)))
}

GetIssuingTransactionsTransactionRequest type {

}

GetIssuingTransactionsTransactionResponse type {
    amount: Int,
    amount_details: Any?,
    authorization: Any?,
    balance_transaction: Any?,
    card: Any,
    cardholder: Any?,
    created: Int,
    currency: Str,
    dispute: Any?,
    id: Str,
    livemode: Bool,
    merchant_amount: Int,
    merchant_currency: Str,
    merchant_data: IssuingAuthorizationMerchantData,
    metadata: Map,
    network_data: Any?,
    object: "issuing.transaction",
    purchase_details: Any?,
    token: Any?,
    treasury: Any?,
    type: "capture" | "refund",
    wallet: "apple_pay" | "google_pay" | "samsung_pay"?
}


retrieve-transaction
meta {doc: """GET /v1/issuing/transactions/{transaction} - Retrieve a transaction"""}
fn (transaction: Str, expand: Str, request: GetIssuingTransactionsTransactionRequest): GetIssuingTransactionsTransactionResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/issuing/transactions/${transaction}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetIssuingTransactionsTransactionResponse(response.body), err(HttpError(response)))
}

