::discord::messages ns

api-request ::discord::api/request
HttpError ::discord::api/HttpError
is-ok-response ::hot::http/is-ok-response

// ============================================================================
// Messages
// ============================================================================

GetChannelMessagesRequest type {
  channel_id: Str,
  around: Str?,
  before: Str?,
  after: Str?,
  limit: Int?
}

get-channel-messages
meta {
    doc: """
GET /channels/{channel_id}/messages - Retrieve messages from a channel. Returns up to 100 messages. Use `before`, `after`, or `around` a message ID for pagination.

**Example**

```hot
::messages ::discord::messages

response ::messages/get-channel-messages(::messages/GetChannelMessagesRequest({
  channel_id: "123456789",
  limit: 10
}))
// => [{id: "...", content: "Hello", author: {...}}, ...]
```
"""
}
fn (request: GetChannelMessagesRequest): Vec<Map> {
  response api-request("GET", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages?limit=${or(request.limit, "")}&around=${or(request.around, "")}&before=${or(request.before, "")}&after=${or(request.after, "")}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

GetMessageRequest type {
  channel_id: Str,
  message_id: Str
}

get-message
meta {
    doc: """GET /channels/{channel_id}/messages/{message_id} - Retrieve a specific message by ID."""
}
fn (request: GetMessageRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages/${request.message_id}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

CreateMessageRequest type {
  channel_id: Str,
  content: Str?,
  tts: Bool?,
  embeds: Vec<Map>?,
  allowed_mentions: Map?,
  message_reference: Map?,
  components: Vec<Map>?,
  sticker_ids: Vec<Str>?,
  flags: Int?
}

create-message
meta {
    doc: """
POST /channels/{channel_id}/messages - Send a message to a channel. Provide `content` for text or `embeds` for rich content. Use `message_reference` to reply to a message.

**Example**

```hot
::messages ::discord::messages

response ::messages/create-message(::messages/CreateMessageRequest({
  channel_id: "123456789",
  content: "Hello from Hot!"
}))
response.id       // => "987654321"
response.content  // => "Hello from Hot!"
```
"""
}
fn (request: CreateMessageRequest): Map {
  body {
    content: request.content,
    tts: request.tts,
    embeds: request.embeds,
    allowed_mentions: request.allowed_mentions,
    message_reference: request.message_reference,
    components: request.components,
    sticker_ids: request.sticker_ids,
    flags: request.flags
  }

  response api-request("POST", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

EditMessageRequest type {
  channel_id: Str,
  message_id: Str,
  content: Str?,
  embeds: Vec<Map>?,
  allowed_mentions: Map?,
  components: Vec<Map>?,
  flags: Int?
}

edit-message
meta {
    doc: """
PATCH /channels/{channel_id}/messages/{message_id} - Edit a previously sent message. Only the message author or bot can edit.

**Example**

```hot
::messages ::discord::messages

response ::messages/edit-message(::messages/EditMessageRequest({
  channel_id: "123456789",
  message_id: "987654321",
  content: "Updated message text"
}))
```
"""
}
fn (request: EditMessageRequest): Map {
  body {
    content: request.content,
    embeds: request.embeds,
    allowed_mentions: request.allowed_mentions,
    components: request.components,
    flags: request.flags
  }

  response api-request("PATCH", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages/${request.message_id}`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

DeleteMessageRequest type {
  channel_id: Str,
  message_id: Str
}

delete-message
meta {
    doc: """DELETE /channels/{channel_id}/messages/{message_id} - Delete a message. Bots can delete any message; users can only delete their own."""
}
fn (request: DeleteMessageRequest): Bool {
  response api-request("DELETE", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages/${request.message_id}`)
  if(is-ok-response(response), true, err(HttpError(response)))
}

BulkDeleteMessagesRequest type {
  channel_id: Str,
  messages: Vec<Str>
}

bulk-delete-messages
meta {
    doc: """POST /channels/{channel_id}/messages/bulk-delete - Delete multiple messages at once (2-100). Messages older than 14 days cannot be bulk-deleted."""
}
fn (request: BulkDeleteMessagesRequest): Bool {
  response api-request("POST", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages/bulk-delete`, {}, {messages: request.messages})
  if(is-ok-response(response), true, err(HttpError(response)))
}

