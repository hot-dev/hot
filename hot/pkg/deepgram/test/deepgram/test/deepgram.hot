::deepgram::test ns
meta ["test"]

test-transcript-extraction
meta ["test"] fn () {
    response {
        results: {
            channels: [{alternatives: [{transcript: "hello hot", confidence: 0.99}]}]
        }
    }
    assert-eq("hello hot", ::deepgram/transcript(response))
}

test-transcript-empty-shapes
meta ["test"] fn () {
    assert-eq("", ::deepgram/transcript({}))
    assert-eq("", ::deepgram/transcript({results: {channels: []}}))
    assert-eq("", ::deepgram/transcript({results: {channels: [{alternatives: []}]}}))
}

test-query-string
meta ["test"] fn () {
    qs ::deepgram/query-string({model: "nova-3", smart_format: true, language: null})
    assert(contains(qs, "model=nova-3"))
    assert(contains(qs, "smart_format=true"))
    assert(not(contains(qs, "language")))
}
