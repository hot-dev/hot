retrieve-review
meta {doc: """GET /v1/reviews/{review} - Retrieve a review"""}
fn (review: Str, expand: Str, request: GetReviewsReviewRequest): GetReviewsReviewResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/reviews/${review}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetReviewsReviewResponse(response.body), err(HttpError(response)))
}

