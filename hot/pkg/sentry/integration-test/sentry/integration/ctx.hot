::sentry::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the sentry integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "sentry.token": ::env/get("SENTRY_TOKEN", ""),
    "sentry.org": ::env/get("SENTRY_ORG", ""),
    "sentry.url": ::env/get("SENTRY_URL", ""),
})
