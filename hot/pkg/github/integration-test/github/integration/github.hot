::github::integration ns
meta ["test"]

// =============================================================================
// Integration Tests (live GitHub; read-only)
// =============================================================================
// Requires ctx: github.token (a PAT with public repo read access)
// Run with: hot test --project pkg-integration-github

::users ::github::users
::repos ::github::repos
::search ::github::search

test-authenticated-user
meta ["test"] fn () {
    me ::users/get-authenticated()
    assert(is-some(me.login), "token should resolve to a user")
}

test-get-public-repo
meta ["test"] fn () {
    repo ::repos/get-repo("torvalds", "linux")
    assert-eq("linux", repo.name)
    assert(is-some(repo.default_branch))
}

test-search-issues
meta ["test"] fn () {
    hits ::search/search-issues("repo:rust-lang/rust is:issue is:open label:C-bug")
    assert(gt(hits.total_count, 0))
}

test-list-org-repos
meta ["test"] fn () {
    repos ::repos/list-org-repos("hot-dev", {per_page: 100})
    assert(gt(length(repos), 0), "org listing should return repos")
    assert-eq(1, length(filter(repos, (r) { eq(r.name, "hot-github-integration-test") })),
        "fixture repo should be visible in the org listing")
}

test-get-content-on-directory-errs
meta ["test"] fn () {
    // The contents endpoint returns a Vec for directories; get-content
    // must surface that as a clear Err, not a halt on .path/.sha.
    out ::repos/get-content("hot-dev", "hot-github-integration-test", "fixtures")
    assert(is-err(out), "directory path should err")
}
