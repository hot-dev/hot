list-all-topups
meta {doc: """GET /v1/topups - List all top-ups"""}
fn (amount: Str, created: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, status: Str, request: GetTopupsRequest): GetTopupsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/topups?amount=${amount}&created=${created}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}&status=${status}`, {}, request)
  if(is-ok-response(response), GetTopupsResponse(response.body), err(HttpError(response)))
}

