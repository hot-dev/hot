meta {
    core: true,
    doc: """
    Return `coll` with elements in reverse order.

    **Example**

    ```hot
    reverse([1, 2, 3])   // [3, 2, 1]
    reverse("hello")    // "olleh"
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/reverse, [coll])
}


