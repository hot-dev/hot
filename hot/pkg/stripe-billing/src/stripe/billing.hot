fn (active: Str, ending-before: Str, expand: Str, is-default: Str, limit: Str, starting-after: Str, request: GetBillingPortalConfigurationsRequest): GetBillingPortalConfigurationsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/billing_portal/configurations?active=${active}&ending_before=${ending-before}&expand=${expand}&is_default=${is-default}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetBillingPortalConfigurationsResponse(response.body), err(HttpError(response)))
}

