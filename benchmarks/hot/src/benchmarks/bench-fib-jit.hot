::benchmarks::fib-jit ns

fib-recursive fn (n: Int): Int {
    if(lte(n, 1), n, add(fib-recursive(sub(n, 1)), fib-recursive(sub(n, 2))))
}

::time ::hot::time

run-bench fn () {
    warmup fib-recursive(25)
    println(`warmup fib-recursive(25) = ${warmup}`)

    start ::time/epoch-millis(::time/now())
    result fib-recursive(25)
    end ::time/epoch-millis(::time/now())
    elapsed sub(end, start)
    println(`steady fib-recursive(25) = ${result} in ${elapsed}ms`)
}

run-bench()
