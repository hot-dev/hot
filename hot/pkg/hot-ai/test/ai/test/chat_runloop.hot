test-run-loop-stream-emit-stream-deltas-safe
meta {
    doc: """With `emit-stream-deltas: true` and no run/stream context, the loop should still complete normally."""
}

meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-stream-fn: mock-stream-end-immediately,
        model: "mock-model",
        emit-stream-deltas: true
    })
    result ::chat/run-loop-stream(opts, "hi")
    assert-eq("Hello world!", result)
}

// ============================================================================
// Token budget checks
// ============================================================================

test-count-tokens-heuristic-empty
meta ["test"]
fn () {
    assert-eq(0, ::chat/count-tokens-heuristic([], "any-model"))
}

test-count-tokens-heuristic-bounded
meta ["test"]
fn () {
    msgs [
        ::chat/Message({role: "user", content: "Hello there!", tool-calls: null, tool-call-id: null})
    ]
    n ::chat/count-tokens-heuristic(msgs, "any-model")
    assert(gt(n, 0))
    assert(lt(n, 50))
}

mock-counter-large
meta { doc: """Test helper: count-tokens-fn that always reports a large number.""" }
fn (messages: Vec<::chat/Message>, model: Str): Int { 500 }

mock-counter-small
meta { doc: """Test helper: count-tokens-fn that always reports a small number.""" }
fn (messages: Vec<::chat/Message>, model: Str): Int { 50 }

test-budget-fail-on-overflow
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-end-immediately,
        model: "mock-model",
        max-context-tokens: 100,
        count-tokens-fn: mock-counter-large
    })
    // Budget overflow halts via `fail(...)`; try captures the halt.
    attempt ::hot::lang/try(::chat/run-loop, [opts, "anything"])
    match attempt {
        Result.Err => {
            assert(contains(attempt.msg, "context limit"), "error mentions context limit")
        }

        Result.Ok => {
            match attempt {
                Result.Err => {
                    assert(contains(attempt.msg, "context limit"), "error mentions context limit")
                }

                _ => { assert(false, "expected budget failure") }
            }
        }
    }
}

test-budget-passes-when-under-limit
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-end-immediately,
        model: "mock-model",
        max-context-tokens: 100000,
        count-tokens-fn: mock-counter-small
    })
    result ::chat/run-loop(opts, "hi")
    assert-eq("Hello from mock!", result)
}

test-budget-skipped-when-no-limit
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-end-immediately,
        model: "mock-model",
        count-tokens-fn: mock-counter-large
    })
    result ::chat/run-loop(opts, "hi")
    assert-eq("Hello from mock!", result)
}

test-budget-stream-fail-on-overflow
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-stream-fn: mock-stream-end-immediately,
        model: "mock-model",
        max-context-tokens: 100,
        count-tokens-fn: mock-counter-large
    })
    attempt ::hot::lang/try(::chat/run-loop-stream, [opts, "anything"])
    match attempt {
        Result.Err => {
            assert(contains(attempt.msg, "context limit"), "error mentions context limit")
        }

        Result.Ok => {
            match attempt {
                Result.Err => {
                    assert(contains(attempt.msg, "context limit"), "error mentions context limit")
                }

                _ => { assert(false, "expected stream budget failure") }
            }
        }
    }
}

test-message-helpers
meta ["test"]
fn () {
    u ::chat/user-message("hi")
    assert-eq("user", u.role)
    assert-eq("hi", u.content)

    a ::chat/assistant-message("done", null)
    assert-eq("assistant", a.role)
    assert-eq("done", a.content)
    assert(is-null(a.tool-calls), "no tool calls")

    tr ::chat/tool-result-message(::tool/ToolResult({id: "x", output: 42, is-error: false}))
    assert-eq("tool", tr.role)
    assert-eq(42, tr.content)
    assert-eq("x", tr.tool-call-id)
}
