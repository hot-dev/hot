::hot::conf ns

// Namespace alias for env module
::env ::hot::env

hot.set.profile "local-dev"
hot.set.project "hot-dev"
hot.set.remote "hot-dev"

hot.profile.local-dev.user.email "local@hot.dev"
hot.profile.local-dev.org.slug "local"
hot.profile.local-dev.env.name "development"

hot.remote.hot-dev.url ::env/get("HOT_API_URL", "https://api.hot.dev")
hot.remote.hot-dev.key ::env/get("HOT_API_KEY", "")

hot.project.hot-dev.src.paths ["./hot/src"]
//hot.project.hot-dev.test.paths ["./hot/test", "./hot/pkg/hot-std/test", "./hot/pkg/aws-eventstream/test"]
hot.project.hot-dev.test.paths ["./hot/test", "./hot/pkg/hot-std/test", "./hot/src/team-agent/test", "./hot/src/personal-agent/test"]
hot.project.hot-dev.test.capture true
hot.project.hot-dev.resources.paths [
    "./hot/src/team-agent/resources",
    "./hot/src/personal-agent/resources",
    "./hot/pkg/hot-std/test/fixtures/resources",
]
// The default hot-dev project compiles the Team Agent agent, so it owns
// the agent's Markdown-authored skills too. Keep codegen scoped to the
// agent resources so test-only resource fixtures remain data fixtures.
hot.project.hot-dev.skills.codegen.enabled true
hot.project.hot-dev.skills.codegen.paths ["./hot/src/team-agent/resources", "./hot/src/personal-agent/resources"]
hot.project.hot-dev.deps {
    // App/demo dependencies used by ./hot/src. Broader package coverage lives
    // in hot-pkg-all and focused package test projects below.
    "hot.dev/hot-ai": { "local": "./hot/pkg/hot-ai" },
    "hot.dev/hot-ai-agent": { "local": "./hot/pkg/hot-ai-agent" },
    "hot.dev/anthropic": { "local": "./hot/pkg/anthropic" },
    "hot.dev/openai": { "local": "./hot/pkg/openai" },
    "hot.dev/telegram": { "local": "./hot/pkg/telegram" },
    "hot.dev/slack": { "local": "./hot/pkg/slack" },
    "hot.dev/whisper": { "local": "./hot/pkg/whisper" },
    "hot.dev/ffmpeg": { "local": "./hot/pkg/ffmpeg" },
    "hot.dev/playwright": { "local": "./hot/pkg/playwright" },

    // Optional package families intentionally omitted from hot-dev:
    // gemini, xai, qwen, AWS, Discord modules, email, Stripe, Twilio,
    // Supabase, and unused box-tool packages. See hot-pkg-all for static
    // package inventory checks.
}

// =============================================================================
// Package Aggregate Static Check
// =============================================================================
// CI uses this project to type-check all package sources and hermetic package
// unit tests without making the default hot-dev project depend on every
// optional package. Live integration tests stay in focused pkg-integration
// projects and scripts.
hot.project.hot-pkg-all.src.paths ["./hot/pkg/hot-std/src"]
hot.project.hot-pkg-all.test.paths [
    "./hot/pkg/anthropic/test",
    "./hot/pkg/aws-eventstream/test",
    "./hot/pkg/ffmpeg/test",
    "./hot/pkg/hot-ai/test",
    "./hot/pkg/hot-ai-agent/test",
    "./hot/pkg/hot-std/test",
    "./hot/pkg/imagemagick/test",
    "./hot/pkg/libreoffice/test",
    "./hot/pkg/mcp/test",
    "./hot/pkg/openai/test",
    "./hot/pkg/pandoc/test",
    "./hot/pkg/playwright/test",
    "./hot/pkg/sox/test",
    "./hot/pkg/supabase/test",
    "./hot/pkg/supabase-admin/test",
    "./hot/pkg/tesseract/test",
    "./hot/pkg/whisper/test"
]
hot.project.hot-pkg-all.test.capture true
hot.project.hot-pkg-all.deps {
    "hot.dev/anthropic": { "local": "./hot/pkg/anthropic" },
    "hot.dev/aws-bedrock": { "local": "./hot/pkg/aws-bedrock" },
    "hot.dev/aws-core": { "local": "./hot/pkg/aws-core" },
    "hot.dev/aws-dynamodb": { "local": "./hot/pkg/aws-dynamodb" },
