::supabase::integration::db ns
meta ["test"]

::db ::supabase::db
::f ::supabase::filters

SUPABASE_TEST_TABLE ::hot::env/get("SUPABASE_TEST_TABLE", "hot-integration-test")

ok-body fn (lazy response: Any, label: Str): Any {
  attempt ::hot::lang/try(() { do response })
  cond {
    is-err(attempt) => { fail(`${label} transport failed: ${attempt.$val.$msg}`) }
    => {
      resolved attempt.$val
      cond {
        gte(resolved.status, 400) => {
          fail(`${label} failed with status ${resolved.status}: ${to-json(resolved.body)}`)
        }
        => { resolved.body }
      }
    }
  }
}

test-insert-select-update-delete
meta ["test"]
fn () {
  assert(SUPABASE_TEST_TABLE, "Set SUPABASE_TEST_TABLE in .env (defaults to 'hot-integration-test')")

  unique-id random-string(8)

  // Step 1: Insert
  inserted ok-body(::db/insert-response(::db/InsertRequest({
    table: SUPABASE_TEST_TABLE,
    data: {name: `hot-test-${unique-id}`, value: 42}
  })), "insert")

  assert(not(is-empty(inserted)), "insert should return the created row")
  row first(inserted)
  assert(row.id, "inserted row should have an id")
  assert-eq(`hot-test-${unique-id}`, row.name, "name should match")

  // Step 2: Select
  selected ok-body(::db/select-http-response(::db/SelectRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/eq("id", row.id)],
    single: true
  })), "select single")

  assert-eq(row.id, selected.id, "selected row id should match")
  assert-eq(42, selected.value, "value should be 42")

  // Step 3: Update
  updated ok-body(::db/update-response(::db/UpdateRequest({
    table: SUPABASE_TEST_TABLE,
    data: {value: 99},
    filters: [::f/eq("id", row.id)]
  })), "update")

  assert-eq(99, first(updated).value, "updated value should be 99")

  // Step 4: Delete
  ok-body(::db/delete-response(::db/DeleteRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/eq("id", row.id)]
  })), "delete")

  // Verify deletion
  verify ok-body(::db/select-http-response(::db/SelectRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/eq("id", row.id)]
  })), "verify delete")
  assert(is-empty(verify), "row should be deleted")
}

test-upsert
meta ["test"]
fn () {
  assert(SUPABASE_TEST_TABLE, "Set SUPABASE_TEST_TABLE in .env")

  unique-id random-string(8)

  // Insert via upsert
  ok-body(::db/upsert-response(::db/UpsertRequest({
    table: SUPABASE_TEST_TABLE,
    data: {name: `upsert-test-${unique-id}`, value: 1},
    on-conflict: "name"
  })), "upsert")

  // Verify
  rows ok-body(::db/select-http-response(::db/SelectRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/eq("name", `upsert-test-${unique-id}`)]
  })), "select upserted row")
  assert-eq(1, length(rows), "should have 1 row")

  // Clean up
  ok-body(::db/delete-response(::db/DeleteRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/eq("name", `upsert-test-${unique-id}`)]
  })), "cleanup upsert")
}

test-filters
meta ["test"]
fn () {
  assert(SUPABASE_TEST_TABLE, "Set SUPABASE_TEST_TABLE in .env")

  unique-id random-string(8)

  // Insert test data
  ok-body(::db/insert-response(::db/InsertRequest({
    table: SUPABASE_TEST_TABLE,
    data: [
      {name: `filter-a-${unique-id}`, value: 10},
      {name: `filter-b-${unique-id}`, value: 20},
      {name: `filter-c-${unique-id}`, value: 30}
    ]
  })), "insert filter fixtures")

  // Test gte filter
  results ok-body(::db/select-http-response(::db/SelectRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/ilike("name", `filter-*-${unique-id}`), ::f/gte("value", 20)],
    order: "value.asc"
  })), "select filter fixtures")
  assert-eq(2, length(results), "should match 2 rows with value >= 20")

  // Clean up
  ok-body(::db/delete-response(::db/DeleteRequest({
    table: SUPABASE_TEST_TABLE,
    filters: [::f/ilike("name", `filter-*-${unique-id}`)]
  })), "cleanup filter fixtures")
}
