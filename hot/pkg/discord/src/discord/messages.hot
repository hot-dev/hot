  channel_id: Str
}

get-pinned-messages
meta {
    doc: """
GET /channels/{channel_id}/pins - Get all pinned messages in a channel. Returns up to 50 message objects.

**Example**

```hot
::messages ::discord::messages

response ::messages/get-pinned-messages(::messages/GetPinnedMessagesRequest({
  channel_id: "123456789"
}))
// => [{id: "...", content: "Important!", pinned: true, ...}, ...]
```
"""
}
fn (request: GetPinnedMessagesRequest): Vec<Map> {
  response api-request("GET", `${::discord::core/BASE_URL}/channels/${request.channel_id}/pins`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

