# Hot API key. API keys are scoped to an organization and environment.
HOT_API_KEY=

# Optional release/update channel overrides.
# Set HOT_UPDATE_DISABLED=true to make `hot update` a local no-op.
HOT_UPDATE_DISABLED=
HOT_UPDATE_BASE_URL=
HOT_UPDATE_INSTALLER_URL=

# Optional comma-separated API hosts that should not be resolved as custom domains.
HOT_API_KNOWN_HOSTS=
