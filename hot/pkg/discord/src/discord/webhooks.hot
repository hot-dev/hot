::discord::webhooks ns

api-request ::discord::api/request
HttpError ::discord::api/HttpError
is-ok-response ::hot::http/is-ok-response

// ============================================================================
// Webhook Management
// ============================================================================

CreateWebhookRequest type {
  channel_id: Str,
  name: Str,
  avatar: Str?
}

create-webhook
meta {
    doc: """
POST /channels/{channel_id}/webhooks - Create a new webhook for a channel. Requires MANAGE_WEBHOOKS. Webhook names must be between 1 and 80 characters.

**Example**

```hot
::webhooks ::discord::webhooks

response ::webhooks/create-webhook(::webhooks/CreateWebhookRequest({
  channel_id: "123456789",
  name: "Hot Notifications"
}))
response.id     // => "webhook-id"
response.token  // => "webhook-token"
```
"""
}
fn (request: CreateWebhookRequest): Map {
  body {
    name: request.name,
    avatar: request.avatar
  }

  response api-request("POST", `${::discord::core/BASE_URL}/channels/${request.channel_id}/webhooks`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

