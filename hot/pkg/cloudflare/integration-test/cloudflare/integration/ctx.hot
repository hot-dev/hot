::cloudflare::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the cloudflare integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "cloudflare.token": ::env/get("CLOUDFLARE_TOKEN", ""),
    "cloudflare.account.id": ::env/get("CLOUDFLARE_ACCOUNT_ID", ""),
})
