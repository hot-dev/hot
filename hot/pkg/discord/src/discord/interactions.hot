// ============================================================================
// Application Commands (Slash Commands)
// ============================================================================

GetGlobalCommandsRequest type {
  application_id: Str,
  with_localizations: Bool?
}

get-global-commands
meta {
    doc: """GET /applications/{application_id}/commands - List all global application commands. These are available in every guild the app is installed in."""
}
fn (request: GetGlobalCommandsRequest): Vec<Map> {
  response api-request("GET", `${::discord::core/BASE_URL}/applications/${request.application_id}/commands?with_localizations=${or(request.with_localizations, "")}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

CreateGlobalCommandRequest type {
  application_id: Str,
  name: Str,
  description: Str?,
  options: Vec<Map>?,
  type: Int?,
  dm_permission: Bool?,
  default_member_permissions: Str?,
  nsfw: Bool?
}

create-global-command
meta {
    doc: """
POST /applications/{application_id}/commands - Create a global slash command. Takes up to 1 hour to propagate. `type`: 1=CHAT_INPUT (slash), 2=USER (context menu), 3=MESSAGE (context menu).

**Example**

```hot
::interactions ::discord::interactions

::interactions/create-global-command(::interactions/CreateGlobalCommandRequest({
  application_id: "123456789",
  name: "hello",
  description: "Say hello from Hot!",
  options: [{
    name: "name",
    description: "Who to greet",
    type: 3,
    required: false
  }]
}))
```
"""
}
fn (request: CreateGlobalCommandRequest): Map {
  body merge({}, {
    name: request.name,
    description: request.description,
    options: request.options,
    type: request.type,
    dm_permission: request.dm_permission,
    default_member_permissions: request.default_member_permissions,
    nsfw: request.nsfw
  })
  response api-request("POST", `${::discord::core/BASE_URL}/applications/${request.application_id}/commands`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

BulkOverwriteGlobalCommandsRequest type {
  application_id: Str,
  commands: Vec<Map>
}

bulk-overwrite-global-commands
meta {
    doc: """PUT /applications/{application_id}/commands - Overwrite all global commands. This replaces the entire set. Useful for syncing commands on deploy."""
}
fn (request: BulkOverwriteGlobalCommandsRequest): Vec<Map> {
  response api-request("PUT", `${::discord::core/BASE_URL}/applications/${request.application_id}/commands`, {}, request.commands)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

