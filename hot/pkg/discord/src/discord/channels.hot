// ============================================================================
// Guild Channels
// ============================================================================

GetGuildChannelsRequest type {
  guild_id: Str
}

get-guild-channels
meta {
    doc: """
GET /guilds/{guild_id}/channels - List all channels in a guild. Does not include threads.

**Example**

```hot
::channels ::discord::channels

response ::channels/get-guild-channels(::channels/GetGuildChannelsRequest({
  guild_id: "123456789"
}))
// => [{id: "...", name: "general", type: 0}, ...]
```
"""
}
fn (request: GetGuildChannelsRequest): Vec<Map> {
  response api-request("GET", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/channels`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

CreateGuildChannelRequest type {
  guild_id: Str,
  name: Str,
  type: Int?,
  topic: Str?,
  bitrate: Int?,
  user_limit: Int?,
  rate_limit_per_user: Int?,
  position: Int?,
  permission_overwrites: Vec<Map>?,
  parent_id: Str?,
  nsfw: Bool?,
  default_auto_archive_duration: Int?
}

create-guild-channel
meta {
    doc: """POST /guilds/{guild_id}/channels - Create a new channel in a guild. Requires MANAGE_CHANNELS. Channel `type`: 0 = text, 2 = voice, 4 = category, 5 = announcement, 13 = stage, 15 = forum."""
}
fn (request: CreateGuildChannelRequest): Map {
  body merge({}, {
    name: request.name,
    type: request.type,
    topic: request.topic,
    bitrate: request.bitrate,
    user_limit: request.user_limit,
    rate_limit_per_user: request.rate_limit_per_user,
    position: request.position,
    permission_overwrites: request.permission_overwrites,
    parent_id: request.parent_id,
    nsfw: request.nsfw,
    default_auto_archive_duration: request.default_auto_archive_duration
  })
  response api-request("POST", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/channels`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

