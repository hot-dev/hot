::hot::test::env ns
meta ["test"]

// Note: assert, assert-eq, is-type, gt, length are all core functions - no aliasing needed
test-env
meta ["test"] fn () {
    // Test get function with default value (since "test" env var likely doesn't exist)
    result ::hot::env/get("test-non-existent", "default")
    assert-eq("default", result, "::hot::env/get(\"test\", \"default\") returns default value")
    // Test get-all function returns a map (should not be null)
    assert(is-type(::hot::env/get-all(), Map), "::hot::env/get-all() returns a non-empty map")
    assert(gt(length(::hot::env/get-all()), 0), "::hot::env/get-all() returns map of length > 0")
}
