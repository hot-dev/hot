::hot::test::tcp ns
meta ["test"]

::tcp ::hot::tcp

is-err ::hot::type/is-err

// Happy-path connect/read/write/TLS tests live in Rust (tcp.rs, tls.rs),
// where the test can spawn a local listener. Hot tests cover the argument
// validation and connection-failure paths, which need no server.

// Connecting to a port nothing listens on returns an error Result
test-connect-refused
meta ["test"] fn () {
    // Port 1 (tcpmux) is essentially never bound on modern systems
    result ::tcp/connect("127.0.0.1", 1, ::hot::tcp/TcpOptions({timeout: 2000}))
    assert(is-err(result), "connect to unbound port should return error")
}

// Invalid ports are rejected before any network IO
test-connect-invalid-port
meta ["test"] fn () {
    assert(is-err(::tcp/connect("127.0.0.1", 0)), "port 0 is invalid")
    assert(is-err(::tcp/connect("127.0.0.1", 99999)), "port 99999 is invalid")
}

// Unresolvable hosts return an error Result
test-connect-bad-host
meta ["test"] fn () {
    result ::tcp/connect("nonexistent.invalid", 80, ::hot::tcp/TcpOptions({timeout: 2000}))
    assert(is-err(result), "connect to unresolvable host should return error")
}

// Regression: a native connect failure is a SINGLE well-formed Err —
// the payload must be the message, never a nested Result.Err (which
// made is-err return false and err-value useless).
test-connect-err-is-not-nested
meta ["test"] fn () {
    result ::tcp/connect("127.0.0.1", 1, ::hot::tcp/TcpOptions({timeout: 2000}))
    assert(is-err(result), "connect failure is an Err")
    payload err-value(result)
    assert(not(is-err(payload)), "Err payload is not itself a Result.Err")
    assert(is-str(payload), "Err payload is the failure message")
}

// Regression: ::hot::lang/try around a native that errors by value is
// idempotent — the Err passes through unchanged instead of being
// re-wrapped as Ok(Err) (invisible to is-err) or Err(Err).
test-try-around-native-err-is-idempotent
meta ["test"] fn () {
    r ::hot::lang/try(() { ::tcp/connect("127.0.0.1", 1, ::hot::tcp/TcpOptions({timeout: 2000})) })
    assert(is-err(r), "try around a failing connect is an Err")
    assert(not(is-err(err-value(r))), "no nested Err through the try boundary")
}
