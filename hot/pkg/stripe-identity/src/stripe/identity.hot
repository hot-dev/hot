retrieve-verificationreport
meta {
    doc: """GET /v1/identity/verification_reports/{report} - Retrieve a VerificationReport"""
}
fn (report: Str, expand: Str, request: GetIdentityVerificationReportsReportRequest): GetIdentityVerificationReportsReportResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/identity/verification_reports/${report}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetIdentityVerificationReportsReportResponse(response.body), err(HttpError(response)))
}

