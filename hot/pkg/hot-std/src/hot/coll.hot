::hot::coll ns
meta {doc: """Collection functions for Vec, Map, and Str manipulation."""}

map
meta {
    core: true,
    doc: """
    Apply `func` to each element of `coll` and return a collection of results.

    **Example**

    ```hot
    map([1, 2, 3], mul(%, 2))
    // [2, 4, 6]

    map({a: 1, b: 2}, (k, v) { add(v, 10) })
    // [11, 12]

    map(items, risky, OnErr.Preserve)
    // preserves domain Err values as result slots
    ```
    """
}
fn
(coll: Str | Vec | Map, func: Fn): Str | Vec | Map {
    call-lib(::hot::coll/map, [coll, func])
},
(coll: Str | Vec | Map, func: Fn, on-err: OnErr): Str | Vec | Map {
    call-lib(::hot::coll/map, [coll, func, on-err])
}


pmap
meta {
    core: true,
    doc: """
    Parallel map: apply `func` to each element of `coll` concurrently.

    **Example**

    ```hot
    // Fetch multiple URLs in parallel
    urls ["https://api.example.com/a", "https://api.example.com/b"]
    pmap(urls, ::hot::http/get(%))
    ```
    """
}
fn
(coll: Str | Vec | Map, func: Fn): Str | Vec | Map {
    call-lib(::hot::coll/pmap, [coll, func])
},
(coll: Str | Vec | Map, func: Fn, on-err: OnErr): Str | Vec | Map {
    call-lib(::hot::coll/pmap, [coll, func, on-err])
}


map-indexed
meta {
    core: true,
    doc: """
    Map with indices: call `func(index, value)` for each element.

    **Example**

    ```hot
    map-indexed(["a", "b", "c"], (i, x) { concat(i, ":", x) })
    // ["0:a", "1:b", "2:c"]
    ```
    """
}
fn
(coll: Str | Vec | Map, func: Fn): Str | Vec | Map {
    call-lib(::hot::coll/map-indexed, [coll, func])
},
(coll: Str | Vec | Map, func: Fn, on-err: OnErr): Str | Vec | Map {
    call-lib(::hot::coll/map-indexed, [coll, func, on-err])
}


filter
meta {
    core: true,
    doc: """
    Return elements of `coll` that satisfy `predicate`.

    **Example**

    ```hot
    filter([1, 2, 3, 4, 5], gt(%, 2))
    // [3, 4, 5]

    filter({a: 1, b: 2, c: 3}, (k, v) { gt(v, 1) })
    // [["b", 2], ["c", 3]]
    ```
    """
}
fn (coll: Str | Vec | Map, predicate: Fn): Str | Vec | Map {
    call-lib(::hot::coll/filter, [coll, predicate])
}


remove
meta {
    core: true,
    doc: """
    Remove elements of `coll` that satisfy `predicate`.

    **Example**

    ```hot
    remove([1, 2, 3, 4, 5], gt(%, 3))
    // [1, 2, 3]
    ```
    """
}
fn (coll: Str | Vec | Map, predicate: Fn): Str | Vec | Map {
    call-lib(::hot::coll/remove, [coll, predicate])
}


delete
meta {
    core: true,
    doc: """
    Delete key (or index) from collection.

    **Example**

    ```hot
    delete([1, 2, 3], 1)          // [1, 3]
    delete({a: 1, b: 2}, "a") // {b: 2}
    delete("hello", 0)            // "ello"
    ```
    """
}
fn (coll: Str | Vec | Map, key-or-index: Str | Int): Str | Vec | Map {
    call-lib(::hot::coll/delete, [coll, key-or-index])
}


reduce
meta {
    core: true,
    doc: """
    Reduce `coll` using `reducer(acc, x)` starting with `initial`.
    Supports early termination: return `reduced(value)` from the reducer
    to stop iteration immediately and return `value`.

    **Example**

    ```hot
    reduce([1, 2, 3, 4], (acc, x) { add(acc, x) }, 0)
    // 10

    reduce(["a", "b", "c"], (acc, x) { concat(acc, x) }, "")
    // "abc"

    // Short-circuit: stop when sum exceeds 5
    reduce([1, 2, 3, 4, 5], (acc, x) {
        total add(acc, x)
        if(gt(total, 5), reduced(total), total)
    }, 0)
    // 6
    ```
    """
}
fn (coll: Str | Vec | Map, reducer: Fn, initial: Any): Any {
    call-lib(::hot::coll/reduce, [coll, reducer, initial])
}


concat
meta {
    core: true,
    doc: """
    Concatenate values of the same type (strings, vectors, or bytes).

    **Example**

    ```hot
    concat([1, 2], [3, 4])        // [1, 2, 3, 4]
    concat("Hello", " ", "World") // "Hello World"
    concat(Bytes([1, 2]), Bytes([3, 4]))  // Bytes([1, 2, 3, 4])
    ```
    """
}
fn
(a: Vec, b: Vec, ...rest: Vec): Vec {
    call-lib(::hot::coll/concat, [a, b, ...rest])
},
(a: Str, b: Str, ...rest: Str): Str {
    call-lib(::hot::coll/concat, [a, b, ...rest])
},
(a: Bytes, b: Bytes, ...rest: Bytes): Bytes {
    call-lib(::hot::coll/concat, [a, b, ...rest])
}


length
meta {
    core: true,
    doc: """
    Return the number of elements in `coll`.

    **Example**

    ```hot
    length([1, 2, 3])        // 3
    length("hello")          // 5
    length({a: 1, b: 2}) // 2
    length(Bytes([1, 2, 3])) // 3
    ```
    """
}
fn (coll: Str | Vec | Map | Bytes): Int {
    call-lib(::hot::coll/length, [coll])
}


get
meta {
    core: true,
    doc: """
    Get a value from `coll` by key or index.

    For Map, looks up by key. For Vec, Str, and Bytes, looks up by 0-based index.
    Returns `null` if not found (2-arity) or `not-found` value (3-arity).

    **Example**

    ```hot
    // Map lookup
    get({a: 1, b: 2}, "a")           // 1
    get({a: 1}, "missing")              // null
    get({a: 1}, "missing", "default")  // "default"

    // Vec lookup
    get([10, 20, 30], 1)                  // 20
    get([10, 20], 5)                      // null
    get([10, 20], 5, -1)                  // -1

    // Str lookup (returns single character)
    get("hello", 0)                       // "h"
    get("hello", 10)                      // null

    // Bytes lookup (returns byte as Int)
    get(Bytes([65, 66, 67]), 0)           // 65
    ```
    """
}
fn
(coll: Map | Vec | Str | Bytes, key: Any): Any {
    call-lib(::hot::coll/get, [coll, key])
},
(coll: Map | Vec | Str | Bytes, key: Any, not-found: Any): Any {
    call-lib(::hot::coll/get, [coll, key, not-found])
}


assoc
meta {
    core: true,
    doc: """
    Associate a key-value pair with a map, returning a new map.

    Creates a new map with the key-value pair added or updated.
    Useful for adding keys dynamically (when key is a variable).

    **Example**

    ```hot
    assoc({a: 1}, "b", 2)           // {a: 1, b: 2}
    assoc({a: 1}, "a", 42)          // {a: 42}

    // Dynamic key
    key "mykey"
    assoc({}, key, "value")           // {mykey: "value"}
    ```
    """
}
fn (map: Map, key: Any, value: Any): Map {
    call-lib(::hot::coll/assoc, [map, key, value])
}


assoc-some
meta {
    core: true,
    doc: """
    Associate a key-value pair with a map only if the value is not null.
    Returns the map unchanged if the value is null. Pipe-friendly.

    **Example**

    ```hot
    assoc-some({a: 1}, "b", 2)       // {a: 1, b: 2}
    assoc-some({a: 1}, "b", null)    // {a: 1}

    // Pipe-friendly for building maps with optional fields
    {name: "Alice"}
      |> assoc-some("email", user.email)
      |> assoc-some("phone", user.phone)
      |> assoc-some("age", user.age)
    ```
    """
}
fn (map: Map, key: Any, value: Any): Map {
    if(is-some(value), assoc(map, key, value), map)
}


update
meta {
    core: true,
    doc: """
    Apply a function to the value at `key` in a map, returning a new map.
    If the key doesn't exist, `func` receives `null`.

    **Example**

    ```hot
    update({count: 1}, "count", add(%, 1))
    // {count: 2}

    update({name: "alice"}, "name", uppercase)
    // {name: "ALICE"}

    // Key doesn't exist — func receives null
    update({}, "count", or(%, 0) |> add(1))
    // {count: 1}

    // Pipe-friendly
    {hits: 0, name: "test"}
      |> update("hits", add(%, 1))
      |> update("name", uppercase)
    // {hits: 1, name: "TEST"}
    ```
    """
}
fn (map: Map, key: Any, func: Fn): Map {
    assoc(map, key, func(get(map, key)))
}


get-in
meta {
    core: true,
    doc: """
    Walk a path of keys through nested Maps/Vecs.

    Returns the value at the nested path, or null (or a default) if any key is missing.

    **Example**

    ```hot
    data {users: [{name: "Alice"}, {name: "Bob"}]}

    get-in(data, ["users", 0, "name"])
    // "Alice"

    get-in(data, ["missing", "path"])
    // null

    get-in(data, ["missing"], "fallback")
    // "fallback"

    // Deeply nested config
    config {db: {host: "localhost", port: 5432}}
    get-in(config, ["db", "port"])
    // 5432
    ```
    """
}
fn
(coll: Map | Vec, path: Vec): Any {
    call-lib(::hot::coll/get-in, [coll, path])
},
(coll: Map | Vec, path: Vec, default: Any): Any {
    call-lib(::hot::coll/get-in, [coll, path, default])
}


assoc-in
meta {
    core: true,
    doc: """
    Immutably set a value at a nested path, creating intermediate maps as needed.

    Returns a new structure with the value set at the given path.
    Intermediate maps are created if they don't exist.

    **Example**

    ```hot
    assoc-in({}, ["a", "b"], 1)
    // {a: {b: 1}}

    config {db: {host: "localhost", port: 5432}}
    assoc-in(config, ["db", "port"], 5433)
    // {db: {host: "localhost", port: 5433}}

    // Preserves sibling keys
    assoc-in({a: {b: 1, c: 2}}, ["a", "b"], 99)
    // {a: {b: 99, c: 2}}
    ```
    """
}
fn (coll: Map | Vec, path: Vec, value: Any): Map | Vec {
    call-lib(::hot::coll/assoc-in, [coll, path, value])
}


update-in
meta {
    core: true,
    doc: """
    Apply a function to the value at a nested path.

    Like `assoc-in`, but instead of setting a value directly,
    applies a function to the current value at the path.

    **Example**

    ```hot
    update-in({a: {b: 1}}, ["a", "b"], add(%, 10))
    // {a: {b: 11}}

    config {db: {port: 5432, retries: 3}}
    config |> update-in(["db", "retries"], add(%, 1))
    // {db: {port: 5432, retries: 4}}
    ```
    """
}
fn (coll: Map | Vec, path: Vec, func: Fn): Map | Vec {
    call-lib(::hot::coll/update-in, [coll, path, func])
}


merge
meta {
    core: true,
    doc: """
    Deep merge two maps. Values from `b` override `a`.

    **Example**

    ```hot
    merge({a: 1, b: 2}, {b: 3, c: 4})
    // {a: 1, b: 3, c: 4}

    // Deep merge for nested maps
    merge({x: {a: 1}}, {x: {b: 2}})
    // {x: {a: 1, b: 2}}
    ```
    """
}
fn (a: Map, b: Map): Map {
    call-lib(::hot::coll/merge, [a, b])
}


map-keys
meta {
    core: true,
    doc: """
    Apply a function to every key in a map, returning a new map with transformed keys.

    **Example**

    ```hot
    map-keys({hello: 1, world: 2}, uppercase)
    // {HELLO: 1, WORLD: 2}

    map-keys({first_name: "Alice", last_name: "Smith"}, replace(%, "_", "-"))
    // {first-name: "Alice", last-name: "Smith"}
    ```
    """
}
fn (m: Map, func: Fn): Map {
    reduce(keys(m), (acc, k) { assoc(acc, func(k), get(m, k)) }, {})
}


map-vals
meta {
    core: true,
    doc: """
    Apply a function to every value in a map, returning a new map with transformed values.

    **Example**

    ```hot
    map-vals({a: 1, b: 2, c: 3}, mul(%, 10))
    // {a: 10, b: 20, c: 30}

    map-vals({name: "alice", city: "paris"}, uppercase)
    // {name: "ALICE", city: "PARIS"}

    // Coerce all values to strings
    map-vals({a: 1, b: true, c: null}, Str)
    // {a: "1", b: "true", c: "null"}
    ```
    """
}
fn (m: Map, func: Fn): Map {
    reduce(keys(m), (acc, k) { assoc(acc, k, func(get(m, k))) }, {})
}


filter-keys
meta {
    core: true,
    doc: """
    Return a new map keeping only entries where the key satisfies `predicate`.

    **Example**

    ```hot
    filter-keys({name: "Alice", age: 30, email: "a@b.com"}, ne(%, "age"))
    // {name: "Alice", email: "a@b.com"}

    // Keep only keys starting with "db_"
    config {db_host: "localhost", db_port: 5432, app_name: "myapp"}
    filter-keys(config, starts-with(%, "db_"))
    // {db_host: "localhost", db_port: 5432}
    ```
    """
}
fn (m: Map, predicate: Fn): Map {
    reduce(keys(m), (acc, k) { if(predicate(k), assoc(acc, k, get(m, k)), acc) }, {})
}


filter-vals
meta {
    core: true,
    doc: """
    Return a new map keeping only entries where the value satisfies `predicate`.

    **Example**

    ```hot
    filter-vals({a: 1, b: null, c: 3, d: null}, is-some)
    // {a: 1, c: 3}

    filter-vals({x: 10, y: -5, z: 20}, gt(%, 0))
    // {x: 10, z: 20}

    // Remove empty strings
    filter-vals({name: "Alice", phone: "", email: "a@b.com"}, not(eq(%, "")))
    // {name: "Alice", email: "a@b.com"}
    ```
    """
}
fn (m: Map, predicate: Fn): Map {
    reduce(keys(m), (acc, k) { if(predicate(get(m, k)), assoc(acc, k, get(m, k)), acc) }, {})
}


first
meta {
    core: true,
    doc: """
    Return the first element of `coll`.

    **Example**

    ```hot
    first([1, 2, 3])   // 1
    first("hello")    // "h"
    first([])          // null
    ```
    """
}
fn (coll: Str | Vec | Map): Any {
    call-lib(::hot::coll/first, [coll])
}


