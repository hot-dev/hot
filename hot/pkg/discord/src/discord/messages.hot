// ============================================================================
// Reactions
// ============================================================================

CreateReactionRequest type {
  channel_id: Str,
  message_id: Str,
  emoji: Str
}

create-reaction
meta {
    doc: """
PUT /channels/{channel_id}/messages/{message_id}/reactions/{emoji}/@me - Add a reaction to a message. For custom emoji use `name:id` format; for Unicode emoji use the URL-encoded character.

**Example**

```hot
::messages ::discord::messages

// Unicode emoji
::messages/create-reaction(::messages/CreateReactionRequest({
  channel_id: "123456789",
  message_id: "987654321",
  emoji: "%F0%9F%91%8D"
}))

// Custom emoji
::messages/create-reaction(::messages/CreateReactionRequest({
  channel_id: "123456789",
  message_id: "987654321",
  emoji: "hotbot:123456789"
}))
```
"""
}
fn (request: CreateReactionRequest): Bool {
  response api-request("PUT", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages/${request.message_id}/reactions/${request.emoji}/@me`)
  if(is-ok-response(response), true, err(HttpError(response)))
}

