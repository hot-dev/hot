test-map-indexed-preserves-domain-err-with-onerr-preserve
meta ["test"] fn () {
    result ::hot::coll/map-indexed([10, 20, 30], (i: Int, x: Int) {
        cond {
            eq(i, 1) => { err("map-indexed domain err") }
            => { ok(add(i, x)) }
        }
