::hot::test::exec ns
meta ["test"]

// fail and cancel halt execution. try-call is the halt boundary used here so
// tests can inspect the captured runtime error without aborting the whole suite.

call-fail-1 fn (): Any {
    fail("something went wrong")
}

call-fail-with-data fn (): Any {
    fail("validation failed", {field: "email", reason: "invalid"})
}

call-cancel-1 fn (): Any {
    cancel("user cancelled")
}

call-cancel-with-data fn (): Any {
    cancel("timeout exceeded", {elapsed: 30000})
}

call-fail-then-marker fn (): Any {
    fail("halt here")
    "continued"
}

call-temporary-fail fn (): Any {
    fail("temporary failure")
}

test-fail-produces-error
meta ["test"] fn () {
    attempt ::hot::lang/try-call(call-fail-1, [])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "something went wrong"))
}

test-fail-with-data
meta ["test"] fn () {
    attempt ::hot::lang/try-call(call-fail-with-data, [])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "validation failed"))
}

test-cancel-produces-error
meta ["test"] fn () {
    attempt ::hot::lang/try-call(call-cancel-1, [])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "user cancelled"))
}

test-cancel-with-data
meta ["test"] fn () {
    attempt ::hot::lang/try-call(call-cancel-with-data, [])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "timeout exceeded"))
}

test-fail-does-not-continue
meta ["test"] fn () {
    attempt ::hot::lang/try-call(call-fail-then-marker, [])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "halt here"))
}

test-fail-state-does-not-leak
meta ["test"] fn () {
    attempt ::hot::lang/try-call(call-temporary-fail, [])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "temporary failure"))

    // This parallel flow must succeed — it should NOT see the failure above.
    data parallel|map {
        a 10
        b 20
    }

    assert-eq(data, {a: 10, b: 20}, "parallel flow runs cleanly after fail()")
}

test-div-by-zero-returns-error
meta ["test"] fn () {
    result div(10, 0)
    assert(is-err(result), "div(10, 0) should produce error, not crash")
}

test-div-by-zero-dec-returns-error
meta ["test"] fn () {
    result div(10.0, 0.0)
    assert(is-err(result), "div(10.0, 0.0) should produce error, not crash")
}

// try-call accepts inline lambdas, not just named functions.

test-try-call-with-inline-lambda-success
meta ["test"] fn () {
    attempt ::hot::lang/try-call((x: Any) { add(x, 1) }, [41])
    assert-eq(true, attempt.ok)
    assert-eq(42, attempt.value)
}

test-try-call-with-inline-lambda-fail
meta ["test"] fn () {
    attempt ::hot::lang/try-call((x: Any) { fail("lambda boom") }, [3])
    assert-eq(false, attempt.ok)
    assert(contains(attempt.error, "lambda boom"))
}

test-try-call-with-inline-lambda-no-args
meta ["test"] fn () {
    attempt ::hot::lang/try-call(() { 7 }, [])
    assert-eq(true, attempt.ok)
    assert-eq(7, attempt.value)
}

test-mixed-type-arithmetic
meta ["test"] fn () {
    // Int + Dec should produce Dec
    result add(10, 1.5)
    assert-eq(11.5, result, "add(Int, Dec) produces Dec")

    result2 sub(10, 0.5)
    assert-eq(9.5, result2, "sub(Int, Dec) produces Dec")

    result3 mul(3, 2.5)
    assert-eq(7.5, result3, "mul(Int, Dec) produces Dec")
}
