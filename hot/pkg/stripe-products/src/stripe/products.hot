create-product
meta {doc: """POST /v1/products - Create a product"""}
fn (request: PostProductsRequest): PostProductsResponse {
  response api-request("POST", `${::stripe/BASE_URL}/v1/products`, {}, request)
  if(is-ok-response(response), PostProductsResponse(response.body), err(HttpError(response)))
}

