::hot::time ns
meta {doc: """Date, time, and duration types based on the Temporal specification."""}

// Time unit types - wrapper types for numeric time values
Nanosecond type
meta {doc: """Nanosecond time unit. Wraps an Int value."""}

Microsecond type
meta {doc: """Microsecond time unit. Wraps an Int value."""}

Millisecond type
meta {doc: """Millisecond time unit. Wraps an Int value."""}

Second type
meta {doc: """Second time unit. Wraps an Int value."""}

Minute type
meta {doc: """Minute time unit. Wraps an Int value."""}

Hour type
meta {doc: """Hour time unit. Wraps an Int value."""}

Day type
meta {doc: """Day time unit. Wraps an Int value."""}

Week type
meta {doc: """Week time unit. Wraps an Int value."""}

Month type
meta {doc: """Month time unit. Wraps an Int value."""}

Year type
meta {doc: """Year time unit. Wraps an Int value."""}

Nanosecond -> Int fn(nanosecond) { Int(nanosecond.$val) }

Microsecond -> Int fn(microsecond) { Int(microsecond.$val) }

Millisecond -> Int fn(millisecond) { Int(millisecond.$val) }

Second -> Int fn(second) { Int(second.$val) }

Minute -> Int fn(minute) { Int(minute.$val) }

Hour -> Int fn(hour) { Int(hour.$val) }

Day -> Int fn(day) { Int(day.$val) }

Week -> Int fn(week) { Int(week.$val) }

Month -> Int fn(month) { Int(month.$val) }

Year -> Int fn(year) { Int(year.$val) }


Instant
meta {
    doc: """
    An exact moment in time (UTC). Based on Temporal.Instant.

    **Example**

    ```hot
    now ::hot::time/now()           // Current instant
    Str(now)                        // "2024-12-04T15:30:00Z"
    ::hot::time/epoch-millis(now)   // 1733324400000
    ```
    """
}
type {
    epochNanoseconds: Int
}
fn
(epoch-millis: Millisecond): Instant {
    call-lib(::hot::time/instant-from-millis, [epoch-millis])
},
(epoch-micros: Microsecond): Instant {
    call-lib(::hot::time/instant-from-micros, [epoch-micros])
},
(epoch-nanos: Nanosecond): Instant {
    call-lib(::hot::time/instant-from-nanos, [epoch-nanos])
},
(plain-date: PlainDate): Instant {
    call-lib(::hot::time/instant-from-plain-date, [plain-date])
},
(plain-time: PlainTime): Instant {
    call-lib(::hot::time/instant-from-plain-time, [plain-time])
},
(plain-date-time: PlainDateTime): Instant {
    call-lib(::hot::time/instant-from-plain-date-time, [plain-date-time])
}


Duration
meta {
    doc: """
    A length of time. Can be used to add/subtract from dates and times.

    **Example**

    ```hot
    d ::hot::time/days(7)              // 7-day duration
    d Duration({"hours": 2, "minutes": 30})  // 2h 30m duration
    Str(d)                             // "PT2H30M"
    ```
    """
}
type {
    years: Dec,
    months: Dec,
    weeks: Dec,
    days: Dec,
    hours: Dec,
    minutes: Dec,
    seconds: Dec,
    milliseconds: Dec,
    microseconds: Dec,
    nanoseconds: Dec
}
fn
(iso: Str): Duration {
    call-lib(::hot::time/parse-duration, [iso])
},
(components: Map): Duration {
    call-lib(::hot::time/duration, [components])
}


PlainDate
meta {
    doc: """
    A calendar date without time or timezone. Based on Temporal.PlainDate.

    **Example**

    ```hot
    today PlainDate()                   // Today's date
    christmas PlainDate(2024, 12, 25)   // Specific date
    parsed PlainDate("2024-12-25")      // From ISO string
    Str(christmas)                      // "2024-12-25"
    ```
    """
}
type {
    year: Int,
    month: Int,
    day: Int,
    calendar: Str
}
fn
(): PlainDate { call-lib(::hot::time/now-plain-date, []) },
(date: Str): PlainDate {
    call-lib(::hot::time/parse-plain-date, [date])
},
(year: Int, month: Int, day: Int): PlainDate {
    call-lib(::hot::time/plain-date, [year, month, day])
}


PlainTime
meta {
    doc: """
    A wall-clock time without date or timezone. Based on Temporal.PlainTime.

    **Example**

    ```hot
    now PlainTime()                  // Current time
    noon PlainTime(12, 0, 0)         // Specific time
    parsed PlainTime("14:30:00")     // From ISO string
    Str(noon)                        // "12:00:00"
    ```
    """
}
type {
    hour: Int,
    minute: Int,
    second: Int,
    millisecond: Int,
    microsecond: Int,
    nanosecond: Int
}
fn
(): PlainTime { call-lib(::hot::time/now-plain-time, []) },
(time: Str): PlainTime {
    call-lib(::hot::time/parse-plain-time, [time])
},
(hour: Int, minute: Int, second: Int): PlainTime {
    call-lib(::hot::time/plain-time, [hour, minute, second])
}


PlainDateTime
meta {
    doc: """
    A date and time without timezone. Based on Temporal.PlainDateTime.

    **Example**

    ```hot
    now PlainDateTime()                            // Current date/time
    party PlainDateTime(2024, 12, 31, 23, 59, 0)   // New Year's Eve
    parsed PlainDateTime("2024-12-31T23:59:00")    // From ISO string
    Str(party)                                     // "2024-12-31T23:59:00"
    ```
    """
}
type {
    year: Int,
    month: Int,
    day: Int,
    hour: Int,
    minute: Int,
    second: Int,
    millisecond: Int,
    microsecond: Int,
    nanosecond: Int,
    calendar: Str
}
fn
(): PlainDateTime { call-lib(::hot::time/now-plain-date-time, []) },
(datetime: Str): PlainDateTime {
    call-lib(::hot::time/parse-plain-date-time, [datetime])
},
(year: Int, month: Int, day: Int, hour: Int, minute: Int, second: Int): PlainDateTime {
    call-lib(::hot::time/plain-date-time, [year, month, day, hour, minute, second])
}


ZonedDateTime
meta {
    doc: """
    A date and time with timezone. Based on Temporal.ZonedDateTime.

    Represents an exact moment in time, projected into a specific timezone.
    Combines the exactness of Instant with the human-readable fields of
    PlainDateTime, aware of DST transitions and UTC offset changes.

    **Example**

    ```hot
    // From IXDTF string
    zdt ZonedDateTime("2026-02-17T10:30:00-06:00[America/Chicago]")

    // From Instant + timezone
    zdt ZonedDateTime(::hot::time/now(), "America/Chicago")

    // From PlainDateTime + timezone
    zdt ZonedDateTime(PlainDateTime(2026, 3, 8, 2, 30, 0), "America/Chicago")

    zdt.year       // 2026
    zdt.hour       // 10
    zdt.offset     // "-06:00"
    zdt.timezone   // "America/Chicago"
    Str(zdt)       // "2026-02-17T10:30:00-06:00[America/Chicago]"
    ```
    """
}
type {
    epochNanoseconds: Int,
    timezone: Str,
    offset: Str,
    year: Int,
    month: Int,
    day: Int,
    hour: Int,
    minute: Int,
    second: Int,
    millisecond: Int,
    microsecond: Int,
    nanosecond: Int,
    calendar: Str
}
fn
(ixdtf: Str): ZonedDateTime {
    call-lib(::hot::time/zoned-date-time-from-string, [ixdtf])
},
(instant: Instant, timezone: Str): ZonedDateTime {
    call-lib(::hot::time/zoned-date-time-from-instant, [instant, timezone])
},
(plain-date-time: PlainDateTime, timezone: Str): ZonedDateTime {
    call-lib(::hot::time/zoned-date-time-from-plain-date-time, [plain-date-time, timezone])
}


// Current time functions
now
meta {
    doc: """
    Get the current instant.

    **Example**

    ```hot

    current ::hot::time/now()
    Str(current)  // "2024-12-04T10:30:00Z"
    ```
    """
}
fn (): Instant {
    call-lib(::hot::time/now, [])
}

// Instant functions (creation via Instant(...) type constructor)
epoch-millis
meta {
    doc: """
    Get milliseconds since Unix epoch for `instant`.

    **Example**

    ```hot

    ms ::hot::time/epoch-millis(::hot::time/now())
    // 1733312400000
    ```
    """
}
fn (instant: Instant): Int {
    call-lib(::hot::time/epoch-millis, [instant])
}


epoch-nanos
meta {
    doc: """
    Get nanoseconds since Unix epoch for `instant`.

    **Example**

    ```hot

    ns ::hot::time/epoch-nanos(::hot::time/now())
    // 1733312400000000000
    ```
    """
}
fn (instant: Instant): Int {
    call-lib(::hot::time/epoch-nanos, [instant])
}


