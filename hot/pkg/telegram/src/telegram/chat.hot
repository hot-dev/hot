::telegram::chat ns

api-request ::telegram::api/request

// ============================================================================
// Chat Info
// ============================================================================

GetChatRequest type {
  chat_id: Any
}

get-chat
meta {
    doc: """
getChat - Get information about a chat. Returns the full chat object with title, type, description, and settings.

**Example**

```hot
::chat ::telegram::chat

response ::chat/get-chat(::chat/GetChatRequest({
  chat_id: -1001234567890
}))
response.title  // => "My Group"
response.type   // => "supergroup"
```
"""
}
fn (request: GetChatRequest): Map {
  api-request("getChat", untype(request))
}

GetChatMemberCountRequest type {
  chat_id: Any
}

get-chat-member-count
meta {
    doc: """getChatMemberCount - Get the number of members in a chat."""
}
fn (request: GetChatMemberCountRequest): Int {
  api-request("getChatMemberCount", untype(request))
}

GetChatMemberRequest type {
  chat_id: Any,
  user_id: Int
}

get-chat-member
meta {
    doc: """getChatMember - Get information about a specific member of a chat. Returns their status (creator, administrator, member, restricted, left, kicked)."""
}
