meta {
    core: true,
    doc: """
    Sort `coll` in ascending order.

    **Example**

    ```hot
    sort([3, 1, 4, 1, 5, 9])
    // [1, 1, 3, 4, 5, 9]
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
