// Duration functions (creation via Duration(...) type constructor)
// Parsing and formatting
parse
meta {
    doc: """
    Parse an ISO-like date/time string into PlainDateTime, PlainDate or PlainTime.

    **Example**

    ```hot

    ::hot::time/parse("2024-12-25")           // PlainDate
    ::hot::time/parse("14:30:00")             // PlainTime
    ::hot::time/parse("2024-12-25T14:30:00")  // PlainDateTime
    ```
    """
}
fn (date-string: Str): PlainDateTime | PlainDate | PlainTime {
    call-lib(::hot::time/parse, [date-string])
}


// Enhanced string constructors - use format via Str coercions
// String coercions via ->
Instant -> Str fn (instant: Instant): Str {
    call-lib(::hot::time/to-string, [instant])
}


Duration -> Str fn (duration: Duration): Str {
    call-lib(::hot::time/to-string, [duration])
}


PlainDate -> Str fn (date: PlainDate): Str {
    call-lib(::hot::time/to-string, [date])
}


PlainTime -> Str fn (time: PlainTime): Str {
    call-lib(::hot::time/to-string, [time])
}


PlainDateTime -> Str fn (dt: PlainDateTime): Str {
    call-lib(::hot::time/to-string, [dt])
}


ZonedDateTime -> Str fn (zdt: ZonedDateTime): Str {
    call-lib(::hot::time/to-string, [zdt])
}


// Formatting
format
meta {
    doc: """
    Format a date/time value using a pattern string.

    Works with PlainDate, PlainTime, PlainDateTime, ZonedDateTime, and Instant.
    Uses English month/day names. For ISO output, use `Str()` coercion instead.

    **Pattern tokens:**

    | Token  | Meaning              | Example   |
    | ------ | -------------------- | --------- |
    | YYYY   | 4-digit year         | 2026      |
    | YY     | 2-digit year         | 26        |
    | MMMM   | Full month name      | February  |
    | MMM    | Short month name     | Feb       |
    | MM     | 2-digit month        | 02        |
    | M      | Month number         | 2         |
    | DD     | 2-digit day          | 17        |
    | D      | Day of month         | 17        |
    | dddd   | Full weekday name    | Tuesday   |
    | ddd    | Short weekday name   | Tue       |
    | HH     | 24-hour hour (2-dig) | 14        |
    | H      | 24-hour hour         | 14        |
    | hh     | 12-hour hour (2-dig) | 02        |
    | h      | 12-hour hour         | 2         |
    | mm     | Minutes (2-digit)    | 30        |
    | ss     | Seconds (2-digit)    | 05        |
    | SSS    | Milliseconds         | 123       |
    | A      | AM/PM                | PM        |
    | a      | am/pm                | pm        |
    | z      | Timezone abbrev      | CST       |
    | Z      | UTC offset           | -06:00    |
    | X      | Unix seconds         | 1771362600|

    **Example**

    ```hot

    date ::hot::time/PlainDate(2026, 2, 17)
    ::hot::time/format(date, "MMMM D, YYYY")          // "February 17, 2026"
    ::hot::time/format(date, "MM/DD/YYYY")             // "02/17/2026"

    dt ::hot::time/PlainDateTime(2026, 2, 17, 14, 30, 0)
    ::hot::time/format(dt, "h:mm A")                   // "2:30 PM"
    ::hot::time/format(dt, "dddd, MMMM D YYYY HH:mm") // "Tuesday, February 17 2026 14:30"
    ```
    """
}
fn (temporal: Any, pattern: Str): Str {
    call-lib(::hot::time/format, [temporal, pattern])
}


// Timezone functions
now-zoned
meta {
    doc: """
    Get the current time as a ZonedDateTime in the given timezone.

    **Example**

    ```hot

    chicago ::hot::time/now-zoned("America/Chicago")
    tokyo ::hot::time/now-zoned("Asia/Tokyo")
    chicago.timezone  // "America/Chicago"
    ```
    """
}
fn (timezone: Str): ZonedDateTime {
    call-lib(::hot::time/now-zoned, [timezone])
}


with-timezone
meta {
    doc: """
    Convert a ZonedDateTime to a different timezone. The underlying instant
    remains the same; the wall-clock fields change to reflect the new zone.

    **Example**

    ```hot

    chicago ZonedDateTime("2026-02-17T10:30:00-06:00[America/Chicago]")
    tokyo ::hot::time/with-timezone(chicago, "Asia/Tokyo")
    tokyo.hour      // 1 (next day)
    tokyo.timezone  // "Asia/Tokyo"
    ```
    """
}
fn (zdt: ZonedDateTime, timezone: Str): ZonedDateTime {
    call-lib(::hot::time/with-timezone, [zdt, timezone])
}


to-plain-date-time
meta {
    doc: """
    Extract the wall-clock date and time from a ZonedDateTime, discarding
    the timezone. Returns a PlainDateTime.

    **Example**

    ```hot

    zdt ZonedDateTime("2026-02-17T10:30:00-06:00[America/Chicago]")
    dt ::hot::time/to-plain-date-time(zdt)
    Str(dt)  // "2026-02-17T10:30:00"
    ```
    """
}
fn (zdt: ZonedDateTime): PlainDateTime {
    call-lib(::hot::time/to-plain-date-time, [zdt])
}


to-plain-date
meta {
    doc: """
    Extract the date from a ZonedDateTime, discarding time and timezone.
    Returns a PlainDate.

    **Example**

    ```hot

    zdt ZonedDateTime("2026-02-17T10:30:00-06:00[America/Chicago]")
    d ::hot::time/to-plain-date(zdt)
    Str(d)  // "2026-02-17"
    ```
    """
}
fn (zdt: ZonedDateTime): PlainDate {
    call-lib(::hot::time/to-plain-date, [zdt])
}


to-plain-time
meta {
    doc: """
    Extract the wall-clock time from a ZonedDateTime, discarding date and
    timezone. Returns a PlainTime.

    **Example**

    ```hot

    zdt ZonedDateTime("2026-02-17T10:30:00-06:00[America/Chicago]")
    t ::hot::time/to-plain-time(zdt)
    Str(t)  // "10:30:00"
    ```
    """
}
fn (zdt: ZonedDateTime): PlainTime {
    call-lib(::hot::time/to-plain-time, [zdt])
}


to-instant
meta {
    doc: """
    Extract the exact moment from a ZonedDateTime as an Instant,
    discarding the timezone.

    **Example**

    ```hot

    zdt ZonedDateTime("2026-02-17T10:30:00-06:00[America/Chicago]")
    inst ::hot::time/to-instant(zdt)
    ::hot::time/epoch-millis(inst)  // epoch millis for that moment
    ```
    """
}
fn (zdt: ZonedDateTime): Instant {
    call-lib(::hot::time/to-instant, [zdt])
}


// Convenience functions for common durations
years
meta {
    doc: """
    Create a Duration representing `amount` years.

    **Example**

    ```hot

    ::hot::time/years(2)  // Duration of 2 years
    ```
    """
}
fn (amount: Any): Duration { Duration({years: amount}) }


