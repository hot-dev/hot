::stripe::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the stripe integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "stripe.api.key": ::env/get("STRIPE_API_KEY", ""),
    "stripe.webhook.secret": ::env/get("STRIPE_WEBHOOK_SECRET", ""),
})
