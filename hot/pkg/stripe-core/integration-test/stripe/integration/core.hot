::stripe::integration::core ns
meta ["test"]

// =============================================================================
// Integration Tests
// =============================================================================
// These tests require STRIPE_SECRET_KEY to be set in context

test-stripe-api-connection
meta ["test"]
fn () {
    // Test basic API connectivity by checking balance (read-only)
    response ::stripe::core/get("/v1/balance")

    assert-eq(200, response.status, "Should connect to Stripe API successfully")
    assert(response.body.available, "Balance response should have 'available' field")
}

test-stripe-list-customers
meta ["test"]
fn () {
    // List customers (read-only, safe operation)
    response ::stripe::core/get("/v1/customers?limit=1")

    assert-eq(200, response.status, "Should list customers successfully")
    assert(response.body.data, "Response should have 'data' field")
    assert-eq("list", response.body.object, "Response object should be 'list'")
}
