::ai::agent::test::ctx ns
meta ["test"]

::actx    ::ai::agent::ctx
::session ::ai::session
::hctx    ::hot::ctx

Session  ::session/Session
Identity ::session/Identity

test-bind-and-recover-session-and-sender
meta ["test"]
fn () {
    ::actx/clear-request()
    s Session({id: "person:alice"})
    i Identity({id: "alice", name: "Alice"})
    ::actx/bind-request(s, i, null)

    assert-eq("person:alice", ::actx/current-session-id())
    assert-eq("alice",        ::actx/current-user-id())
    assert-eq("Alice",        ::actx/current-user-name())

    recovered ::actx/current-session()
    assert(not(is-null(recovered)))
    assert-eq("person:alice", recovered.id)

    sender ::actx/current-sender()
    assert(not(is-null(sender)))
    assert-eq("alice", sender.id)
    assert-eq("Alice", sender.name)
}

test-current-sender-falls-back-to-id-when-name-missing
meta ["test"]
fn () {
    ::actx/clear-request()
    s Session({id: "person:bob"})
    i Identity({id: "bob"})
    ::actx/bind-request(s, i, null)

    sender ::actx/current-sender()
    assert-eq("bob", sender.id)
    assert-eq("bob", sender.name)
}

test-extras-roundtrip
meta ["test"]
fn () {
    ::actx/clear-request()
    s Session({id: "person:carol"})
    i Identity({id: "carol", name: "Carol"})
    ::actx/bind-request(s, i, {channel: "#general", transport: "web"})

    extras ::actx/current-extras()
    assert-eq("#general", get(extras, "channel"))
    assert-eq("web",      get(extras, "transport"))
}

test-unbound-returns-null
meta ["test"]
fn () {
    ::actx/clear-request()
    assert(is-null(::actx/current-session-id()))
    assert(is-null(::actx/current-user-id()))
    assert(is-null(::actx/current-user-name()))
    assert(is-null(::actx/current-session()))
    assert(is-null(::actx/current-sender()))
    assert-eq({}, ::actx/current-extras())
}

test-clear-removes-bindings
meta ["test"]
fn () {
    s Session({id: "person:dan"})
    i Identity({id: "dan", name: "Dan"})
    ::actx/bind-request(s, i, null)
    assert-eq("dan", ::actx/current-user-id())

    ::actx/clear-request()
    assert(is-null(::actx/current-user-id()))
    assert(is-null(::actx/current-sender()))
}
