::twilio::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the twilio integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "twilio.account.sid": ::env/get("TWILIO_ACCOUNT_SID", ""),
    "twilio.auth.token": ::env/get("TWILIO_AUTH_TOKEN", ""),
})
