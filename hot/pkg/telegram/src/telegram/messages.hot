::telegram::messages ns

api-request ::telegram::api/request

// ============================================================================
// Send Messages
// ============================================================================

SendMessageRequest type {
  chat_id: Any,
  text: Str,
  parse_mode: Str?,
  entities: Vec<Map>?,
  link_preview_options: Map?,
  disable_notification: Bool?,
  protect_content: Bool?,
  reply_parameters: Map?,
  reply_markup: Map?,
  message_thread_id: Int?
}

send-message
meta {
    doc: """
sendMessage - Send a text message to a chat. `chat_id` can be an integer ID or a string `@channel_username`. `parse_mode` can be "HTML", "Markdown", or "MarkdownV2".

**Example**

```hot
::messages ::telegram::messages

response ::messages/send-message(::messages/SendMessageRequest({
  chat_id: 123456789,
  text: "Hello from Hot!"
}))
response.message_id  // => 42

// With formatting
response ::messages/send-message(::messages/SendMessageRequest({
  chat_id: 123456789,
  text: "<b>Bold</b> and <i>italic</i>",
  parse_mode: "HTML"
}))
```
"""
}
fn (request: SendMessageRequest): Map {
  api-request("sendMessage", untype(request))
}

