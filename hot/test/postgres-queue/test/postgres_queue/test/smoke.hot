::postgres_queue::test::smoke ns

test-postgres-uri-config
meta ["test"] fn () {
    uri ::hot::env/get("HOT_TEST_POSTGRES_URI", "postgres://hot:hot@127.0.0.1:55432/hot")

    assert(contains(uri, "postgres://"), "Postgres queue test URI should use postgres")
    assert(contains(uri, "/hot"), "Postgres queue test URI should target the hot database")
}
