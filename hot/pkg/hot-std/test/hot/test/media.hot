::hot::test::media ns
meta ["test"]

// ============================================================================
// Tests for ::hot::media - Unified AI-generated media types
// ============================================================================

Media ::hot::media/Media
Image ::hot::media/Image
Audio ::hot::media/Audio
Video ::hot::media/Video
MediaBatch ::hot::media/MediaBatch
MediaError ::hot::media/MediaError
FileMeta ::hot::file/FileMeta

// Mock FileMeta for testing
mock-file-meta fn (path: Str, size: Int): FileMeta {
    FileMeta({
        file-id: "test-123",
        path: path,
        size: size,
        etag: null,
        content-type: "image/png",
        storage-backend: "local",
        created-at: 1704067200,
        updated-at: 1704067200
    })
}

// ============================================================================
// Media.Image Tests
// ============================================================================

test-image-creation
meta ["test"]
fn () {
    file-meta mock-file-meta("uploads/test.png", 12345)

    image-data Image({
        file: file-meta,
        prompt: "A beautiful sunset",
        revised_prompt: "A stunning sunset over mountains",
        model: "aurora",
        provider: "xai",
        width: 1024,
        height: 1024,
        format: "png",
        style: "vivid",
        quality: "hd"
    })

    media Media.Image(image-data)

    assert(::hot::media/is-image(media), "Should be identified as image")
    assert(not(::hot::media/is-audio(media)), "Should not be identified as audio")
    assert(not(::hot::media/is-video(media)), "Should not be identified as video")
    assert(not(::hot::media/has-duration(media)), "Image should not have duration")
}

test-image-field-access
meta ["test"]
fn () {
    file-meta mock-file-meta("output/city.png", 54321)

    media Media.Image({
        file: file-meta,
        prompt: "A futuristic city",
        revised_prompt: null,
        model: "dall-e-3",
        provider: "openai",
        width: 1792,
        height: 1024,
        format: "png",
        style: "natural",
        quality: "standard"
    })

    // Test field access via $val
    assert-eq("output/city.png", media.$val.file.path, "Should access $val.file.path")
    assert-eq("A futuristic city", media.$val.prompt, "Should access $val.prompt")
    assert-eq("openai", media.$val.provider, "Should access $val.provider")
    assert-eq("dall-e-3", media.$val.model, "Should access $val.model")
    assert(is-null(::hot::media/duration(media)), "duration() should return null for images")
}

// ============================================================================
// Media.Audio Tests
// ============================================================================

test-audio-creation
meta ["test"]
fn () {
    file-meta mock-file-meta("audio/speech.mp3", 98765)

    audio-data Audio({
        file: file-meta,
        prompt: "Hello, welcome to our service.",
        transcript: null,
        model: "tts-1-hd",
        provider: "openai",
        duration_seconds: 3.5,
        format: "mp3",
        voice: "alloy",
        language: "en"
    })

    media Media.Audio(audio-data)

    assert(not(::hot::media/is-image(media)), "Should not be identified as image")
    assert(::hot::media/is-audio(media), "Should be identified as audio")
    assert(not(::hot::media/is-video(media)), "Should not be identified as video")
    assert(::hot::media/has-duration(media), "Audio should have duration")
}

test-audio-field-access
meta ["test"]
fn () {
    file-meta mock-file-meta("audio/greeting.wav", 44100)

    media Media.Audio({
        file: file-meta,
        prompt: "Welcome message",
        transcript: "Hello and welcome!",
        model: "tts-1",
        provider: "openai",
        duration_seconds: 2.75,
        format: "wav",
        voice: "nova",
        language: "en-US"
    })

    // Test field access via $val
    assert-eq("audio/greeting.wav", media.$val.file.path, "Should access $val.file.path")
    assert-eq("Welcome message", media.$val.prompt, "Should access $val.prompt")
    assert-eq("openai", media.$val.provider, "Should access $val.provider")
    assert-eq(2.75, ::hot::media/duration(media), "duration() should return duration_seconds")
}

