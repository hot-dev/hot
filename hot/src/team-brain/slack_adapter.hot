::team-brain::slack-adapter ns
meta {
    doc: """
    Slack transport adapter for Team Brain.

    Mirrors `telegram_adapter.hot`:

    - Translates Slack `message.channels` events into
      `::transport/IncomingMessage`.
    - Implements `reply-impl` / `show-typing-impl` / `message-link`
      so `::transport` can dispatch outbound traffic.
    - Owns the Events API webhook (`/slack/events`).

    ## Slack identity model

    - `Session.id` is `slack:${team_id}:${channel_id}` so it can never
      collide with a Telegram chat or another Slack workspace.
    - `Identity.id` is the Slack `user` id (`U…`); `name` is the
      cached display name when available, falling back to `user_id` so
      we always have something to render.

    ## Threading

    Slack uses `thread_ts` for replies. We pass it through as the
    `reply-to` field of `IncomingMessage` (string-typed because Slack
    timestamps are floats serialized as strings like `"1700000000.123456"`).
    Replies that omit `reply-to` post to the channel root.
    """
}

::store ::hot::store
::ctx   ::hot::ctx
::regex ::hot::regex

::session   ::ai::session
::transport ::team-brain::transport
::agent     ::team-brain::agent

// Slack package namespaces. The third-party `::slack` package
// groups Web API methods by surface (messaging, users, …) rather
// than by API method, so we only need two: `messaging` for
// `chat.postMessage` and `users` for `users.info`.
::slack-msg   ::slack::messaging
::slack-users ::slack::users

// Type aliases used in fn signatures. See note in telegram_adapter.hot:
// Hot resolves these in `: Session`-style annotations but currently
// fails to dispatch type-constructor *calls* via the alias from
// inside another function body (looks them up as functions in the
// local namespace and 404s). Construct with the full `::session/Session(...)`
// form below; reserve the short forms for type positions.
Session      ::session/Session
Identity     ::session/Identity
HttpRequest  ::hot::http/HttpRequest
HttpResponse ::hot::http/HttpResponse

// ============================================================================
// Identity / Session translation
// ============================================================================

session-from-channel
meta {
    doc: """
    Build a transport-stamped `Session` for a Slack channel. The
    `team_id` is included in the namespace so a single bot installed
    across multiple workspaces never confuses channels with
    coincidentally-equal ids.
    """
}
fn (team-id: Str, channel-id: Str): Session {
    ::transport/session-with-transport(
        ::session/Session({
            id: `slack:${team-id}:${channel-id}`,
            meta: {team-id: team-id, channel-id: channel-id},
        }),
        "slack",
    )
}

channel-id-from-session
meta {
    doc: "Pull the Slack channel id back out of a session built by `session-from-channel`."
}
fn (session: Session): Str {
    cond {
        and(is-some(session.meta), is-some(get(or(session.meta, {}), "channel-id"))) => {
            get(session.meta, "channel-id")
        }
        // Fallback: parse `slack:T1:C2` shape.
        => {
            parts split(session.id, ":")
            cond {
                gte(length(parts), 3) => { last(parts) }
                => { "" }
            }
        }
    }
}

// In-memory user-name cache so we don't burn `users.info` calls on
// every inbound message. `id -> name`. Cleared on process restart;
// the demo doesn't need persistence here.
user-name-cache ::hot::store/Map({name: "brain:slack:users"})

resolve-user-name
meta {
    doc: """
    Look up a Slack user's display name via `users.info`, caching the
    result. Falls back to the user id if the API call fails so we
    always have something to render.
    """
}
fn (user-id: Str): Str {
    cached ::store/get(user-name-cache, user-id)
    cond {
        is-some(cached) => { cached }
        => {
            result ::hot::lang/try-call(() {
                resp ::slack-users/users-info(::slack-users/UsersInfoRequest({user: user-id}))
                user or(resp.user, {})
                or(get(user, "real_name"), get(user, "name"), user-id)
            })
            name if(result.ok, result.value, user-id)
            ::store/put(user-name-cache, user-id, name)
            name
        }
    }
}

identity-from-slack
meta { doc: "Slack `user` id → `::ai::session/Identity` with cached display name." }
fn (user-id: Str): Identity {
    ::session/Identity({id: user-id, name: resolve-user-name(user-id)})
}

// ============================================================================
// Inbound: Slack event → IncomingMessage
// ============================================================================

to-incoming
meta {
    doc: """
    Translate a Slack `message` event payload (the inner `event` object
    of an Events API envelope) into `::transport/IncomingMessage`.

    `team_id` is required because session keying namespaces by it. Pass
    the outer envelope's `team_id`, not the inner event's `source_team`
    (which is the message author's home workspace, not the workspace
    the message was sent in).
    """
}
fn (event: Map, team-id: Str): ::transport/IncomingMessage {
    channel-id event.channel
    user-id    or(event.user, "USLACKBOT")
    text       or(event.text, "")
    ts         or(event.thread_ts, event.ts)
    timestamp  Int(or(event.ts, "0"))
    ::transport/IncomingMessage({
        session: session-from-channel(team-id, channel-id),
        sender: identity-from-slack(user-id),
        text: text,
        message-id: ts,
        timestamp: timestamp,
        voice: null,
        raw: event,
    })
}

// ============================================================================
// Outbound: reply + show-typing implementations
// ============================================================================

to-slack-markdown
meta {
    doc: """
    Translate the agent core's HTML-flavored output into Slack mrkdwn
    at the adapter boundary. Static templates (`welcome-message`,
    `help-message`, `stats-text`, `diag-text`, `format-sources`) and
    LLM replies that fall back to HTML all flow through here before
    `chat.postMessage` sees them, so a B2B reader installing the bot
    in Slack never sees raw `<b>` / `<code>` tags.

    Conversions

    | from                        | to                  |
    |-----------------------------|---------------------|
    | `<b>x</b>`                  | `*x*`               |
    | `<i>x</i>`                  | `_x_`               |
    | `<code>x</code>`            | `` `x` ``           |
    | `<a href="URL">label</a>`   | `<URL|label>`       |
    | `&amp;`, `&lt;`, `&gt;`,    | decoded             |
    | `&quot;`, `&#39;`           |                     |

    Clean mrkdwn passes through unchanged — none of the regex patterns
    match plain `*bold*`, `_italic_`, or `` `code` ``. The
    `slack-tone` skill steers the LLM toward emitting mrkdwn directly;
    this translator catches the static templates and any HTML the
    model emits anyway.

    Caveat: a literal `<b>` in user-authored content gets interpreted
    as bold. This matches the existing Telegram behaviour where
    `parse_mode=HTML` does the same thing.
    """
}
fn (text: Str): Str {
    // Capture-group refs use ${N} not $N. The Rust regex engine parses
    // $name greedily, consuming any identifier chars (including `_`)
    // that follow. `_$1_` would be read as `_` + group "1_" (nonexistent,
    // expanding to "") + ``, dropping the captured content. `${1}` is
    // delimited and unambiguous. We use it everywhere for consistency
    // even where the next char isn't an identifier (e.g. `*${1}*`).
    //
    // Caveat for nested tags: a `<b>`/`<i>`/`<code>` inside a link
    // label gets translated independently (regardless of pipe order),
    // so `<a href="...">⟨tag⟩X⟨/tag⟩</a>` becomes
    // `<URL|*X*>` not `<URL|<tag>X</tag>>`. Slack doesn't render
    // markdown inside link labels in either form, so neither output is
    // visually correct — the agent's format-sources is currently the
    // only call site that nests this way and the production output
    // doesn't depend on the inner formatting rendering. test-
    // format-sources-shape pins this behaviour.
    text
        |> ::regex/replace-all("<b>(.*?)</b>",                    "*${1}*")
        |> ::regex/replace-all("<i>(.*?)</i>",                    "_${1}_")
        |> ::regex/replace-all("<code>(.*?)</code>",              "`${1}`")
        |> ::regex/replace-all("<a href=\"([^\"]+)\">(.*?)</a>",  "<${1}|${2}>")
        |> ::regex/replace-all("&amp;",  "&")
        |> ::regex/replace-all("&lt;",   "<")
        |> ::regex/replace-all("&gt;",   ">")
        |> ::regex/replace-all("&quot;", "\"")
        |> ::regex/replace-all("&#39;",  "'")
}

reply-impl
meta {
    doc: """
    Send `text` to the Slack channel encoded in `session`. Threads
    under `reply-to` (a Slack `ts`) when present. Slack's `chat.postMessage`
    accepts `thread_ts` for threading; passing it for a non-threaded
    parent silently creates a thread of one, which matches Telegram's
    `reply_to_message_id` behaviour.

    Incoming text is HTML-flavored because the agent core was born on
    Telegram. We translate to Slack mrkdwn at the adapter boundary
    (`to-slack-markdown`) so static templates and any HTML the LLM
    emits both render correctly without forking the agent core.
    """
}
fn (session: Session, text: Str, reply-to: Str?): Any {
    channel channel-id-from-session(session)
    ::slack-msg/chat-post-message(::slack-msg/ChatPostMessageRequest({
        channel: channel,
        text: to-slack-markdown(text),
        thread_ts: if(and(is-some(reply-to), not(is-empty(reply-to))), reply-to, null),
    }))
}

show-typing-impl
meta {
    doc: """
    Slack has no first-class typing indicator for bots — the closest
    thing is the ephemeral "<bot> is thinking…" shown when assistant
    apps are actively responding, which requires the assistant API.
    For now this is a no-op; users see the reply when it arrives.
    """
}
fn (session: Session): Any { {ok: true, no-op: true} }

message-link
meta {
    doc: """
    Build a Slack permalink for a `(channel, ts)` pair. Permalinks
    look like `https://${team}.slack.com/archives/${channel}/p${ts-no-dot}`.
    Returns `""` when the team subdomain isn't configured.
    """
}
fn (session: Session, message-id: Any): Str {
    team-domain or(::ctx/get("slack.team.domain"), "")
    channel channel-id-from-session(session)
    cond {
        is-empty(team-domain) => { "" }
        => {
            ts-flat replace(Str(message-id), ".", "")
            `https://${team-domain}.slack.com/archives/${channel}/p${ts-flat}`
        }
    }
}

// ============================================================================
// Webhook: Slack Events API receiver
// ============================================================================

on-slack-event
meta {
    doc: """
    Receive Slack Events API callbacks. Handles three kinds:

    - `url_verification` — respond with `{challenge: ...}` so Slack
      finishes registering the endpoint.
    - `event_callback` with a `message` inner type — translate via
      `to-incoming` and dispatch into `::agent/process-incoming`.
    - Everything else — 200 OK so Slack stops retrying.

    Bot messages (`bot_id` set) and `message_changed` / `message_deleted`
    subtypes are silently dropped; we only want fresh user messages.

    ## Wiring (wrapper pattern)

    `on-slack-event` is a pure callable. It does NOT mount its own
    webhook — keeping the `meta {webhook: …}` off the library
    function prevents duplicate route registrations and ambiguous
    service routing when this adapter is compiled into more than
    one project. Register it from your agent assembly file as a
    meta-bearing alias:

    ```hot
    ::slack-adapter ::team-brain::slack-adapter

    slack-on-event
    meta {
        agent: TeamBrain,
        webhook: {
            service: "team-brain",
            path: "/slack/events",
            method: "POST",
            description: "Receive Slack Events API callbacks",
        },
    }
    ::slack-adapter/on-slack-event
    ```

    Pick a `service:` name unique to the deploying project; that's
    what Hot's worker uses to route inbound HTTPS to the right
    build. Then point your Slack app's "Event Subscriptions" URL
    at `https://<your-worker>/slack/events`.
    """
}
fn (request: HttpRequest): HttpResponse {
    body or(request.body, {})
    cond {
        eq(or(body.type, ""), "url_verification") => {
            ::hot::http/HttpResponse({status: 200, body: {challenge: body.challenge}})
        }
        eq(or(body.type, ""), "event_callback") => {
            inner or(body.event, {})
            team-id or(body.team_id, "")
            cond {
                not(eq(or(inner.type, ""), "message")) => { ::hot::http/HttpResponse({status: 200, body: {ok: true}}) }
                is-some(inner.bot_id)                  => { ::hot::http/HttpResponse({status: 200, body: {ok: true}}) }
                is-some(inner.subtype)                 => { ::hot::http/HttpResponse({status: 200, body: {ok: true}}) }
                => {
                    ::agent/process-incoming(to-incoming(inner, team-id))
                    ::hot::http/HttpResponse({status: 200, body: {ok: true}})
                }
            }
        }
        => { ::hot::http/HttpResponse({status: 200, body: {ok: true}}) }
    }
}
