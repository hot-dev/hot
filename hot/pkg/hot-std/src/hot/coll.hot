meta {
    core: true,
    doc: """
    Remove duplicate elements from `coll`.

    **Example**

    ```hot
    distinct([1, 2, 2, 3, 3, 3])
    // [1, 2, 3]
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/distinct, [coll])
}


