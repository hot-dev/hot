::ai::test::chat_runloop ns
meta ["test"]

::chat ::ai::chat
::tool ::ai::tool

ReplyDelta         ::chat/ReplyDelta
TextDelta          ::chat/TextDelta
ToolUseStart       ::chat/ToolUseStart
ToolUseInputDelta  ::chat/ToolUseInputDelta
ToolUseEnd         ::chat/ToolUseEnd
StreamStop         ::chat/StreamStop

// ============================================================================
// Fixtures
// ============================================================================

add-fn
meta {
    doc: """Test tool — sums two integers."""
}
fn (x: Int, y: Int): Int {
    add(x, y)
}

multiply-fn
meta {
    doc: """Test tool — multiplies two integers."""
}
fn (x: Int, y: Int): Int {
    mul(x, y)
}

failing-fn
meta {
    doc: """Test tool that always fails."""
}
fn (input: Str): Str {
    fail(`failing-fn rejected '${input}'`)
}

// ----------------------------------------------------------------------------
// Mock chat-fn — looks at message history to decide what to return
// ----------------------------------------------------------------------------

mock-chat-end-immediately
meta {
    doc: """Mock chat-fn that ends on the first turn with no tool calls."""
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    ::chat/ChatReply({
        text: "Hello from mock!",
        tool-calls: null,
        stop-reason: "end_turn",
        usage: null,
        raw: null
    })
}

mock-chat-one-tool-then-end
meta {
    doc: """
    Mock chat-fn that requests `add-fn(2, 3)` on the first turn, then
    returns a final answer once it sees the tool result in messages.
    """
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    has-tool-result some(messages, eq(%.role, "tool"))
    cond {
        has-tool-result => {
            tool-msg find-first(messages, eq(%.role, "tool"))
            ::chat/ChatReply({
                text: `The answer is ${tool-msg.content}.`,
                tool-calls: null,
                stop-reason: "end_turn",
                usage: null,
                raw: null
            })
        }
        => {
            ::chat/ChatReply({
                text: "Let me compute that.",
                tool-calls: [::tool/ToolCall({
                    id: "call-1",
                    name: "::ai::test::chat_runloop/add-fn",
                    input: {x: 2, y: 3}
                })],
                stop-reason: "tool_use",
                usage: null,
                raw: null
            })
        }
    }
}

mock-chat-two-parallel-tools
meta {
    doc: """
    Mock that requests two tool calls in one turn, then returns a
    final answer after seeing both results.
    """
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    tool-results filter(messages, eq(%.role, "tool"))
    cond {
        gte(length(tool-results), 2) => {
            ::chat/ChatReply({
                text: `add=${tool-results[0].content} mul=${tool-results[1].content}`,
                tool-calls: null,
                stop-reason: "end_turn",
                usage: null,
                raw: null
            })
        }
        => {
            ::chat/ChatReply({
                text: null,
                tool-calls: [
                    ::tool/ToolCall({id: "c1", name: "::ai::test::chat_runloop/add-fn", input: {x: 2, y: 3}}),
                    ::tool/ToolCall({id: "c2", name: "::ai::test::chat_runloop/multiply-fn", input: {x: 4, y: 5}})
                ],
                stop-reason: "tool_use",
                usage: null,
                raw: null
            })
        }
    }
}

mock-chat-infinite-tool-calls
meta {
    doc: """Mock that always asks for another tool call — used to trigger max-iterations."""
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    ::chat/ChatReply({
        text: null,
        tool-calls: [::tool/ToolCall({
            id: `call-${length(messages)}`,
            name: "::ai::test::chat_runloop/add-fn",
            input: {x: 1, y: 1}
        })],
        stop-reason: "tool_use",
        usage: null,
        raw: null
    })
}

mock-chat-tool-error-recovery
meta {
    doc: """
    Mock that calls a failing tool first, observes the error, then
    falls back to a simple text answer.
    """
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    tool-msg find-first(messages, eq(%.role, "tool"))
    cond {
        is-some(tool-msg) => {
            ::chat/ChatReply({
                text: "I saw the error and recovered.",
                tool-calls: null,
                stop-reason: "end_turn",
                usage: null,
                raw: null
            })
        }
        => {
            ::chat/ChatReply({
                text: null,
                tool-calls: [::tool/ToolCall({
                    id: "call-err",
                    name: "::ai::test::chat_runloop/failing-fn",
                    input: {input: "bad"}
                })],
                stop-reason: "tool_use",
                usage: null,
                raw: null
            })
        }
    }
}

// ============================================================================
// Tests
// ============================================================================

test-run-loop-immediate-end
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-end-immediately,
        model: "mock-model"
    })
    result ::chat/run-loop(opts, "hi")
    assert-eq("Hello from mock!", result)
}

test-run-loop-one-tool-roundtrip
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-one-tool-then-end,
        model: "mock-model",
        tools: [::tool/from-fn(add-fn)]
    })
    result ::chat/run-loop(opts, "what is 2 + 3?")
    assert-eq("The answer is 5.", result)
}

test-run-loop-two-parallel-tools
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-two-parallel-tools,
        model: "mock-model",
        tools: [::tool/from-fn(add-fn), ::tool/from-fn(multiply-fn)]
    })
    result ::chat/run-loop(opts, "compute things")
    assert-eq("add=5 mul=20", result)
}

test-run-loop-max-iterations-exceeded
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-infinite-tool-calls,
        model: "mock-model",
        tools: [::tool/from-fn(add-fn)],
        max-iterations: 3
    })
    // `try` keeps this test from aborting if the loop halts, while the
    // nested match also handles a domain Err returned by the run loop.
    attempt ::hot::lang/try(::chat/run-loop, [opts, "loop forever"])
    match attempt {
        Result.Err => {
            assert(contains(attempt.msg, "max-iterations"), "error mentions max-iterations")
        }

        Result.Ok => {
            match attempt {
                Result.Err => {
                    assert(contains(attempt.msg, "max-iterations"), "error mentions max-iterations")
                }

                _ => { assert(false, "expected max-iterations failure") }
            }
        }
    }
}

test-run-loop-tool-error-recovery
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-tool-error-recovery,
        model: "mock-model",
        tools: [::tool/from-fn(failing-fn)]
    })
    result ::chat/run-loop(opts, "try a failing tool")
    assert-eq("I saw the error and recovered.", result)
}

