list-orders
meta {doc: """GET /v1/climate/orders - List orders"""}
fn (ending-before: Str, expand: Str, limit: Str, starting-after: Str, request: GetClimateOrdersRequest): GetClimateOrdersResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/climate/orders?ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetClimateOrdersResponse(response.body), err(HttpError(response)))
}

