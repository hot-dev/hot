}

ModifyGuildMemberRequest type {
  guild_id: Str,
  user_id: Str,
  nick: Str?,
  roles: Vec<Str>?,
  mute: Bool?,
  deaf: Bool?,
  channel_id: Str?,
  communication_disabled_until: Str?
}

modify-guild-member
meta {
    doc: """PATCH /guilds/{guild_id}/members/{user_id} - Modify a guild member. Can change nickname, roles, mute/deaf, voice channel, or timeout. Set `communication_disabled_until` to an ISO 8601 timestamp to timeout a user (max 28 days)."""
}
fn (request: ModifyGuildMemberRequest): Map {
  body {
    nick: request.nick,
    roles: request.roles,
    mute: request.mute,
    deaf: request.deaf,
    channel_id: request.channel_id,
    communication_disabled_until: request.communication_disabled_until
  }

  response api-request("PATCH", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/members/${request.user_id}`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

RemoveGuildMemberRequest type {
  guild_id: Str,
  user_id: Str
}

remove-guild-member
meta {
    doc: """DELETE /guilds/{guild_id}/members/{user_id} - Remove (kick) a member from the guild. Requires KICK_MEMBERS permission."""
}
fn (request: RemoveGuildMemberRequest): Bool {
  response api-request("DELETE", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/members/${request.user_id}`)
  if(is-ok-response(response), true, err(HttpError(response)))
}

