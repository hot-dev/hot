::team-brain::researcher ns
meta {
    doc: """
  Researcher is a second agent in the Team Brain demo. It listens on the
  `agents:collaborate` bus and answers questions that Team Brain decided
  it can't answer from group memory (general fact lookups, definitions,
  external knowledge).

  This exists primarily to light up the Agent Graph and demonstrate the
  ::ai::bus collaboration pattern: one agent routing work to another,
  responses returning over a typed reply event.
  """
}

::ctx ::hot::ctx
::bus ::ai::bus
::chat ::ai::chat

::anthropic-chat ::anthropic::messages
::openai-chat    ::openai::chat

CollaborationRequest ::bus/CollaborationRequest

// ============================================================================
// Agent Definition
// ============================================================================

Researcher
meta {
    doc: "External-knowledge agent that answers fact-lookup questions over ::ai::bus.",
    agent: {
        name: "Researcher",
        description: "Answers general-knowledge questions for other agents via ::ai::bus/collaborate",
        tags: ["telegram", "ai", "bus", "research"],
    },
}
type {
  model: Str,
  system-prompt: Str,
}

DEFAULT_MODEL "gpt-5-mini"

SYSTEM_PROMPT """
  You are Researcher, an AI assistant that fields general-knowledge
  questions delegated by other agents.

  - Be concise (3-5 sentences max unless asked otherwise).
  - When you are uncertain, SAY SO explicitly. Better to flag a gap than
    invent an answer.
  - Do not pretend to have access to private context (chat history, files,
    user data). You only know what is in your training data.
  - Use plain text. The calling agent handles its own formatting.
"""

researcher Researcher({
  model:         ::ctx/get("researcher.model", DEFAULT_MODEL),
  system-prompt: ::ctx/get("researcher.system", SYSTEM_PROMPT),
})

// ============================================================================
// AI dispatch (mirrors the pattern in agent.hot but kept independent so
// Researcher and Team Brain can run different models).
// ============================================================================

provider-to-chat-fn fn match (provider: ::chat/Provider): Fn {
  ::chat/Provider.Anthropic => { ::anthropic-chat/chat }
  ::chat/Provider.OpenAi    => { ::openai-chat/chat }
  =>                           { ::openai-chat/chat }
}

ask-llm fn (question: Str): Str {
  model    researcher.model
  provider ::chat/detect-provider(model)
  chat-fn  provider-to-chat-fn(provider)
  chat-fn(model, question, researcher.system-prompt)
}

// ============================================================================
// Collaboration handler
// ============================================================================
// Listens on the global collaboration channel and responds when the
// requesting agent matches one of our peers. Other agents on the same
// bus will simply ignore requests they aren't equipped to handle.

PEERS ["Team Brain"]

answer
meta {
    doc: "Receives collaboration requests over ::ai::bus and responds with a fact-lookup answer.",
    agent: Researcher,
    on-event: "agents:collaborate",
    sends: [
        {
            event: "brain:ask-response",
            doc: "Responds to TeamBrain collaboration requests using the reply event carried on the request.",
        },
    ],
}
fn (event) {
  req event.data
  cond {
    not(in(req.from-agent, PEERS)) => { "ignored: not a known peer" }
    is-empty(or(req.question, "")) => { "ignored: empty question" }
    => {
      answer ask-llm(req.question)
      ::bus/respond(CollaborationRequest(req), or(answer, "(no answer)"))
    }
  }
}
