execute
meta {doc: """POST /webhooks/{webhook_id}/{webhook_token}"""}
fn (wait: Str, thread-id: Str, with-components: Str, request: ExecuteWebhookRequest): ExecuteWebhookResponse {
  response api-request("POST", `${::discord/BASE_URL}/webhooks/{webhook_id}/{webhook_token}?wait=${wait}&thread_id=${thread-id}&with_components=${with-components}`, {}, request)
  if(is-ok-response(response), ExecuteWebhookResponse(response.body), err(HttpError(response)))
}

