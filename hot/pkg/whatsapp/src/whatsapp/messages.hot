::whatsapp::messages ns

::api ::whatsapp::api

// ============================================================================
// Text Messages
// ============================================================================

SendTextRequest type {
  phone_number_id: Str,
  to: Str,
  text: Str,
  preview_url: Bool?
}

send-text
meta {
    doc: """
Send a text message. `to` is the recipient's phone number in international format (e.g. "15551234567").

**Example**

```hot
::messages ::whatsapp::messages

response ::messages/send-text(::messages/SendTextRequest({
  phone_number_id: "109876543210",
  to: "15551234567",
  text: "Hello from Hot!"
}))
response.messages[0].id  // => "wamid.HBg..."
```
"""
}
fn (request: SendTextRequest): Map {
  body {
    messaging_product: "whatsapp",
    recipient_type: "individual",
    to: request.to,
    type: "text",
    text: {
      preview_url: or(request.preview_url, false),
      body: request.text
    }
  }

  ::api/request("POST", ::api/url(`${request.phone_number_id}/messages`), {}, body)
}

// ============================================================================
// Media Messages
// ============================================================================

SendImageRequest type {
  phone_number_id: Str,
  to: Str,
  image_url: Str?,
  image_id: Str?,
  caption: Str?
}

send-image
meta {
    doc: """
Send an image. Provide either `image_url` (public HTTPS URL) or `image_id` (uploaded media ID). Supported: JPEG, PNG. Max 5 MB.

**Example**

```hot
::messages ::whatsapp::messages

response ::messages/send-image(::messages/SendImageRequest({
  phone_number_id: "109876543210",
  to: "15551234567",
  image_url: "https://example.com/photo.jpg",
  caption: "Check this out!"
}))
```
"""
}
fn (request: SendImageRequest): Map {
  image cond {
    is-some(request.image_id) => { {id: request.image_id} }
    is-some(request.image_url) => { {link: request.image_url} }
    => { fail("Provide either image_url or image_id") }
  }

  body {
    messaging_product: "whatsapp",
    recipient_type: "individual",
    to: request.to,
    type: "image",
    image: image |> assoc-some("caption", request.caption)
  }

  ::api/request("POST", ::api/url(`${request.phone_number_id}/messages`), {}, body)
}

SendDocumentRequest type {
  phone_number_id: Str,
  to: Str,
  document_url: Str?,
  document_id: Str?,
  caption: Str?,
  filename: Str?
}

send-document
meta {
    doc: """Send a document. Provide either `document_url` or `document_id`. Supports PDF, DOC, DOCX, PPT, XLS, etc. Max 100 MB."""
}
fn (request: SendDocumentRequest): Map {
  doc cond {
    is-some(request.document_id) => { {id: request.document_id} }
    is-some(request.document_url) => { {link: request.document_url} }
    => { fail("Provide either document_url or document_id") }
  }

  body {
    messaging_product: "whatsapp",
    recipient_type: "individual",
    to: request.to,
    type: "document",
    document: doc
      |> assoc-some("caption", request.caption)
      |> assoc-some("filename", request.filename)
  }

  ::api/request("POST", ::api/url(`${request.phone_number_id}/messages`), {}, body)
}

