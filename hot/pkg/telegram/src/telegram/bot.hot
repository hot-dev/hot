::telegram::bot ns

api-request ::telegram::api/request

// ============================================================================
// Bot Info
// ============================================================================

get-me
meta {
    doc: """
getMe - Get basic information about the bot. Returns the bot's id, username, first_name, and capabilities.

**Example**

```hot
::bot ::telegram::bot

response ::bot/get-me()
response.id          // => 123456789
response.username    // => "my_hot_bot"
response.first_name  // => "Hot Bot"
response.is_bot      // => true
```
"""
}
fn (): Map {
  api-request("getMe")
}

GetMyNameRequest type {
  language_code: Str?
}

get-my-name
meta {
    doc: """getMyName - Get the bot's name for the given language. Returns `{name: "Bot Name"}`."""
}
fn (request: GetMyNameRequest): Map {
  api-request("getMyName", untype(request))
}

SetMyNameRequest type {
  name: Str?,
  language_code: Str?
}

set-my-name
meta {
    doc: """setMyName - Change the bot's name. Max 64 characters."""
}
fn (request: SetMyNameRequest): Bool {
  api-request("setMyName", untype(request))
}

