::jwt::test ns
meta ["test"]

::jwt ::jwt
::hex ::hot::hex

// Independently generated with Python hmac/hashlib/base64:
//   header {"alg":"HS256","typ":"JWT"}, payload {"sub":"42","name":"Ada"},
//   secret "test-secret"
KNOWN_TOKEN "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI0MiIsIm5hbWUiOiJBZGEifQ.Uj1pcABU3gzYNe0xmmVPWwc63LvhuUzR3-Ryv_AADRM"
SECRET "test-secret"

