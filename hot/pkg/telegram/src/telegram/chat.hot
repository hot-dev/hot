// ============================================================================
// Member Management
// ============================================================================

BanChatMemberRequest type {
  chat_id: Any,
  user_id: Int,
  until_date: Int?,
  revoke_messages: Bool?
}

ban-chat-member
meta {
    doc: """banChatMember - Ban a user from a group or channel. `until_date` is a Unix timestamp for a temporary ban (30 seconds to 366 days in the future). Set `revoke_messages: true` to delete all messages from the user."""
}
fn (request: BanChatMemberRequest): Bool {
  api-request("banChatMember", untype(request))
}

UnbanChatMemberRequest type {
  chat_id: Any,
  user_id: Int,
  only_if_banned: Bool?
}

unban-chat-member
meta {
    doc: """unbanChatMember - Unban a previously banned user. Set `only_if_banned: true` to avoid accidentally unbanning an active member (which would remove them)."""
}
fn (request: UnbanChatMemberRequest): Bool {
  api-request("unbanChatMember", untype(request))
}

RestrictChatMemberRequest type {
  chat_id: Any,
  user_id: Int,
  permissions: Map,
  until_date: Int?,
  use_independent_chat_permissions: Bool?
}

restrict-chat-member
meta {
    doc: """restrictChatMember - Restrict a user in a supergroup. `permissions` is a ChatPermissions object controlling what the user can do (send messages, media, polls, etc.)."""
}
fn (request: RestrictChatMemberRequest): Bool {
  api-request("restrictChatMember", untype(request))
}

PromoteChatMemberRequest type {
  chat_id: Any,
  user_id: Int,
  is_anonymous: Bool?,
  can_manage_chat: Bool?,
  can_delete_messages: Bool?,
  can_manage_video_chats: Bool?,
  can_restrict_members: Bool?,
  can_promote_members: Bool?,
  can_change_info: Bool?,
  can_invite_users: Bool?,
  can_post_messages: Bool?,
  can_edit_messages: Bool?,
  can_pin_messages: Bool?,
  can_post_stories: Bool?,
  can_edit_stories: Bool?,
  can_delete_stories: Bool?,
  can_manage_topics: Bool?
}

promote-chat-member
meta {
    doc: """promoteChatMember - Promote or demote a user in a supergroup or channel. Pass the specific admin rights to grant. All rights default to false."""
}
fn (request: PromoteChatMemberRequest): Bool {
  api-request("promoteChatMember", untype(request))
}

