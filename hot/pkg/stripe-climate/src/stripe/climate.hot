cancel-order
meta {doc: """POST /v1/climate/orders/{order}/cancel - Cancel an order"""}
fn (order: Str, request: PostClimateOrdersOrderCancelRequest): PostClimateOrdersOrderCancelResponse {
  response api-request("POST", `${::stripe/BASE_URL}/v1/climate/orders/${order}/cancel`, {}, request)
  if(is-ok-response(response), PostClimateOrdersOrderCancelResponse(response.body), err(HttpError(response)))
}

GetClimateProductsRequest type {

}

GetClimateProductsResponse type {
    data: Vec<ClimateProduct>,
    has_more: Bool,
    object: "list",
    url: Str
}


list-products
meta {doc: """GET /v1/climate/products - List products"""}
fn (ending-before: Str, expand: Str, limit: Str, starting-after: Str, request: GetClimateProductsRequest): GetClimateProductsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/climate/products?ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetClimateProductsResponse(response.body), err(HttpError(response)))
}

GetClimateProductsProductRequest type {

}

GetClimateProductsProductResponse type {
    created: Int,
    current_prices_per_metric_ton: Map,
    delivery_year: Int?,
    id: Str,
    livemode: Bool,
    metric_tons_available: Str,
    name: Str,
    object: "climate.product",
    suppliers: Vec<ClimateSupplier>
}


retrieve-product
meta {doc: """GET /v1/climate/products/{product} - Retrieve a product"""}
fn (product: Str, expand: Str, request: GetClimateProductsProductRequest): GetClimateProductsProductResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/climate/products/${product}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetClimateProductsProductResponse(response.body), err(HttpError(response)))
}

