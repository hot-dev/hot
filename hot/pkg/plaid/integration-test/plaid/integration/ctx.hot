::plaid::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the plaid integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "plaid.client-id": ::env/get("PLAID_CLIENT_ID", ""),
    "plaid.secret": ::env/get("PLAID_SECRET", ""),
    "plaid.env": ::env/get("PLAID_ENV", ""),
})
