// Documentation examples for: resources/docs/language/functions.md
::hot::test::docs::functions ns
meta ["test"]

// =============================================================================
// Imports
// =============================================================================
// Note: All functions used here are core (add, mul, sub, eq, concat, reduce, map, filter, length, first, rest, is-empty, lte, if, assert-eq, etc.)

// =============================================================================
// Snippets
// =============================================================================

// @doc: basic-functions
greet fn (name: Str): Str {
  `Hello, ${name}!`
}

add-numbers fn (a: Int, b: Int): Int {
  add(a, b)
}
// @end: basic-functions

// @doc: calling-functions
result-greet greet("World")         // "Hello, World!"
sum add-numbers(5, 3)               // 8
// @end: calling-functions

// @doc: fn-equivalent-forms
// These are equivalent:
greet-v1 fn (name: Str): Str { `Hello, ${name}!` }
greet-v2 fn serial (name: Str): Str { `Hello, ${name}!` }
// @end: fn-equivalent-forms

// @doc: fn-cond-example
// Conditional function using cond flow
is-admin fn cond (user): Bool {
  eq(user.role, "admin") => { true }
  => { false }
}
// @end: fn-cond-example

// @doc: param-types
// Fully typed
greet-typed fn (name: Str): Str {
  `Hello, ${name}!`
}

// Untyped (accepts anything)
echo fn (x) {
  x
}

// Mixed
process fn (data: Map, options): Map {
  data
}
// @end: param-types

// @doc: overload-by-arity
process-data fn
(x: Int): Str { `Integer: ${x}` },
(x: Str): Str { `String: ${x}` },
(x: Vec): Str { `Vector with ${length(x)} items` }
// @end: overload-by-arity

// @doc: lambda-as-var
double-fn (x) { mul(x, 2) }
result-double double-fn(5)   // 10
// @end: lambda-as-var

// @doc: nullable-params
greet-titled fn (name: Str, title: Str?): Str {
  if(title,
    `Hello, ${title} ${name}!`,
    `Hello, ${name}!`)
}
// @end: nullable-params

// @doc: function-overloading
slice fn
(coll: Vec, start: Int): Vec {
  // slice from start to end (stub)
  coll
},
(coll: Vec, start: Int, end: Int): Vec {
  // slice from start to end (stub)
  coll
}
// @end: function-overloading

// @doc: variadic-functions
concat-all fn (first-vec: Vec, ...rest: Vec): Vec {
  reduce(rest, (acc, v) { concat(acc, v) }, first-vec)
}
// @end: variadic-functions

// @doc: lambdas
doubled map([1, 2, 3], (x) { mul(x, 2) })
sum-lambda reduce([1, 2, 3], (acc, x) { add(acc, x) }, 0)
// @end: lambdas

// @doc: lambda-as-value
double (x) { mul(x, 2) }
// @end: lambda-as-value

// @doc: lazy-arguments
safe-access fn (data, lazy fallback) {
  if(data, data, do fallback)
}
// @end: lazy-arguments

// @doc: function-reference
apply fn (func, value) {
  func(value)
}
// @end: function-reference

// Helper for test - pass function directly
apply-double apply(double, 5)

// @doc: tco-factorial
factorial fn cond (n: Int, acc: Int): Int {
  lte(n, 1) => { acc }
  => { factorial(sub(n, 1), mul(n, acc)) }
}
// @end: tco-factorial

// TCO sum example removed - fn cond TCO needs investigation
// See: TCO bug with fn cond where flow contexts aren't properly reset

// =============================================================================
// Tests
// =============================================================================

test-basic-functions
meta ["test"] fn () {
  assert-eq("Hello, World!", greet("World"), "greet")
  assert-eq(8, add-numbers(5, 3), "add-numbers")
}
// @result: basic-functions
// greet("World")      → "Hello, World!"
// add-numbers(5, 3)   → 8
// @end: basic-functions

test-fn-equivalent-forms
meta ["test"] fn () {
  assert-eq("Hello, World!", greet-v1("World"), "greet-v1")
  assert-eq("Hello, World!", greet-v2("World"), "greet-v2")
}

test-fn-cond
meta ["test"] fn () {
  admin {role: "admin"}
  member {role: "member"}
  assert-eq(true, is-admin(admin), "is-admin admin")
  assert-eq(false, is-admin(member), "is-admin member")
}

test-param-types
meta ["test"] fn () {
  assert-eq("Hello, Alice!", greet-typed("Alice"), "greet-typed")
  assert-eq(42, echo(42), "echo int")
  assert-eq("test", echo("test"), "echo str")
}

test-overload-by-arity
meta ["test"] fn () {
  assert-eq("Integer: 42", process-data(42), "process int")
  assert-eq("String: hello", process-data("hello"), "process str")
  assert-eq("Vector with 3 items", process-data([1, 2, 3]), "process vec")
}

test-lambda-as-var
meta ["test"] fn () {
  assert-eq(10, result-double, "double result")
}

test-nullable-params
meta ["test"] fn () {
  assert-eq("Hello, Alice!", greet-titled("Alice", null), "with null title")
  assert-eq("Hello, Dr Smith!", greet-titled("Smith", "Dr"), "with title")
}
// @result: nullable-params
// greet-titled("Alice", null)  → "Hello, Alice!"
// greet-titled("Smith", "Dr")  → "Hello, Dr Smith!"
// @end: nullable-params

test-variadic
meta ["test"] fn () {
  result concat-all([1], [2], [3], [4])
  assert-eq(4, length(result), "concat-all length")
}

test-lambdas
meta ["test"] fn () {
  assert-eq(3, length(doubled), "doubled length")
  assert-eq(6, sum-lambda, "sum-lambda")
}
// @result: lambdas
// map([1, 2, 3], (x) { mul(x, 2) })        → [2, 4, 6]
// reduce([1, 2, 3], (acc, x) { add(acc, x) }, 0)  → 6
// @end: lambdas

test-lambda-as-value
meta ["test"] fn () {
  assert-eq(10, double(5), "double")
}

test-function-reference
meta ["test"] fn () {
  assert-eq(10, apply-double, "apply with reference")
}

test-tco-factorial
meta ["test"] fn () {
  assert-eq(120, factorial(5, 1), "factorial 5")
  assert-eq(1, factorial(1, 1), "factorial 1")
}
// @result: tco-factorial
// factorial(5, 1) → 120
// factorial(1, 1) → 1
// @end: tco-factorial

// test-tco-sum removed - fn cond TCO needs investigation

// =============================================================================
// Cross-arity self-calls: lower arity delegates to higher arity
// =============================================================================

// Pattern: 1-arity calls 2-arity, 2-arity calls 3-arity (forward delegation)
make-greeting fn
(name: Str): Str {
  make-greeting(name, "Hello")
},
(name: Str, salutation: Str): Str {
  make-greeting(name, salutation, "!")
},
(name: Str, salutation: Str, punctuation: Str): Str {
  `${salutation}, ${name}${punctuation}`
}

test-cross-arity-forward-delegation
meta ["test"] fn () {
  assert-eq("Hello, Alice!", make-greeting("Alice"), "1-arity delegates to 2-arity which delegates to 3-arity")
  assert-eq("Hi, Bob!", make-greeting("Bob", "Hi"), "2-arity delegates to 3-arity")
  assert-eq("Hey, Carol?", make-greeting("Carol", "Hey", "?"), "3-arity direct call")
}

// Pattern: higher arity defined first, lower arity defined after (mixed order)
build-url fn
(base: Str, path: Str, query: Str): Str {
  `${base}/${path}?${query}`
},
(base: Str, path: Str): Str {
  build-url(base, path, "")
},
(base: Str): Str {
  build-url(base, "", "")
}

test-cross-arity-reverse-delegation
meta ["test"] fn () {
  assert-eq("api.com/users?active=true", build-url("api.com", "users", "active=true"), "3-arity direct")
  assert-eq("api.com/users?", build-url("api.com", "users"), "2-arity delegates to 3-arity")
  assert-eq("api.com/?", build-url("api.com"), "1-arity delegates to 2-arity which delegates to 3-arity")
}
