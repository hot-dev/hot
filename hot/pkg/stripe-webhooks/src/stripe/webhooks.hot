list-all-events
meta {doc: """GET /v1/events - List all events"""}
fn (created: Str, delivery-success: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, type-param: Str, types: Str, request: GetEventsRequest): GetEventsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/events?created=${created}&delivery_success=${delivery-success}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}&type=${type-param}&types=${types}`, {}, request)
  if(is-ok-response(response), GetEventsResponse(response.body), err(HttpError(response)))
}

