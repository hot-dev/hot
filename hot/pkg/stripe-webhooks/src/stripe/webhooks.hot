}


retrieve-event
meta {doc: """GET /v1/events/{id} - Retrieve an event"""}
fn (id: Str, expand: Str, request: GetEventsIdRequest): GetEventsIdResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/events/${id}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetEventsIdResponse(response.body), err(HttpError(response)))
}

