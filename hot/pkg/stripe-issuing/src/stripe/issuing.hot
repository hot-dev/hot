list-all-authorizations
meta {doc: """GET /v1/issuing/authorizations - List all authorizations"""}
fn (card: Str, cardholder: Str, created: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, status: Str, request: GetIssuingAuthorizationsRequest): GetIssuingAuthorizationsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/issuing/authorizations?card=${card}&cardholder=${cardholder}&created=${created}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}&status=${status}`, {}, request)
  if(is-ok-response(response), GetIssuingAuthorizationsResponse(response.body), err(HttpError(response)))
}

