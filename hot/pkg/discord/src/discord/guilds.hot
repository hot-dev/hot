CreateGuildRoleRequest type {
  guild_id: Str,
  name: Str?,
  permissions: Str?,
  color: Int?,
  hoist: Bool?,
  mentionable: Bool?
}

create-guild-role
meta {
    doc: """POST /guilds/{guild_id}/roles - Create a new role. Requires MANAGE_ROLES. `permissions` is a bitfield string. `color` is an integer RGB value. `hoist: true` displays the role separately in the member list."""
}
fn (request: CreateGuildRoleRequest): Map {
  body {
    name: request.name,
    permissions: request.permissions,
    color: request.color,
    hoist: request.hoist,
    mentionable: request.mentionable
  }

  response api-request("POST", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/roles`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

