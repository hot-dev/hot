hot.db.uri ::env/get("HOT_DB_URI", "sqlite:./.hot/db/hot.sqlite.db")
//hot.db.uri "postgres://postgres:password@localhost:5432/hot"
hot.db.schema "hot"

hot.file.mode ::env/get("HOT_FILE_MODE", "service")
hot.file.storage.type ::env/get("HOT_FILE_STORAGE_TYPE", "local")
hot.file.storage.path ::env/get("HOT_FILE_STORAGE_PATH", "./.hot/file")

hot.log.level "info"
hot.log.target "stdout"
hot.log.dir ".hot/log"
hot.log.rotation "daily"
hot.log.retention 7

hot.redis.uri ::env/get("HOT_REDIS_URI", "redis://localhost:6379")
hot.redis.cluster Bool(::env/get("HOT_REDIS_CLUSTER", "false"))

hot.api.host Str(::env/get("HOT_API_HOST", "localhost"))
hot.api.port Int(::env/get("HOT_API_PORT", "4681"))

hot.app.host Str(::env/get("HOT_APP_HOST", "localhost"))
hot.app.port Int(::env/get("HOT_APP_PORT", "4680"))
hot.app.session.timeout Int(::env/get("HOT_APP_SESSION_TIMEOUT", "24"))
hot.app.session.secret ::env/get("HOT_APP_SESSION_SECRET", "")

hot.product.experience ::env/get("HOT_PRODUCT_EXPERIENCE", "local-dev")
hot.product.web-url ::env/get("HOT_PRODUCT_WEB_URL", "https://hot.dev")
hot.product.pricing-url ::env/get("HOT_PRODUCT_PRICING_URL", "https://hot.dev/pricing")
hot.product.support-email ::env/get("HOT_PRODUCT_SUPPORT_EMAIL", "support@hot.dev")
hot.billing.enabled Bool(::env/get("HOT_BILLING_ENABLED", "false"))

hot.email.app-url ::env/get("HOT_APP_URL", "http://localhost:4680")
hot.email.web-url ::env/get("HOT_EMAIL_WEB_URL", ::env/get("HOT_PRODUCT_WEB_URL", "https://hot.dev"))
hot.email.docs-url ::env/get("HOT_EMAIL_DOCS_URL", "https://hot.dev/docs")
hot.email.logo-url ::env/get("HOT_EMAIL_LOGO_URL", "https://assets.hot.dev/email/hot_logo_email.png")
hot.email.from ::env/get("HOT_EMAIL_FROM", "hi@notifications.hot.dev")
hot.email.from-name ::env/get("HOT_EMAIL_FROM_NAME", "Hot Dev")
hot.email.alerts.from ::env/get("HOT_EMAIL_ALERTS_FROM", "alerts@notifications.hot.dev")
hot.email.alerts.from-name ::env/get("HOT_EMAIL_ALERTS_FROM_NAME", "Hot Alerts")

hot.build.aws.s3.bucket ::env/get("HOT_BUILD_AWS_S3_BUCKET", "")
hot.build.aws.s3.prefix ::env/get("HOT_BUILD_AWS_S3_PREFIX", "")
hot.build.aws.s3.region ::env/get("HOT_BUILD_AWS_S3_REGION", "")
hot.build.aws.access-key-id ::env/get("HOT_BUILD_AWS_ACCESS_KEY_ID", "")
hot.build.aws.secret-access-key ::env/get("HOT_BUILD_AWS_SECRET_ACCESS_KEY", "")

hot.file.mode ::env/get("HOT_FILE_MODE", "service")
hot.file.storage.type ::env/get("HOT_FILE_STORAGE_TYPE", "local")
hot.file.storage.path ::env/get("HOT_FILE_STORAGE_PATH", "./.hot/file")
hot.file.aws.s3.bucket ::env/get("HOT_FILE_AWS_S3_BUCKET", "")
hot.file.aws.s3.prefix ::env/get("HOT_FILE_AWS_S3_PREFIX", "files/")
hot.file.aws.s3.region ::env/get("HOT_FILE_AWS_S3_REGION", "")
hot.file.aws.access-key-id ::env/get("HOT_FILE_AWS_ACCESS_KEY_ID", "")
hot.file.aws.secret-access-key ::env/get("HOT_FILE_AWS_SECRET_ACCESS_KEY", "")

// Custom Domain Configuration
// Mode: "none" (disabled) or a deployment-provided domain provider.
hot.domain.mode ::env/get("HOT_DOMAIN_MODE", "none")

hot.cache.enabled false
hot.cache.format "zstdjson"

hot.check.format "pretty"
hot.check.raw false
hot.check.with-tests false
// Treat deprecation (and future) warnings as errors: when true, `hot check`
// exits non-zero if any warnings are emitted. Default false (warnings report
// but never fail the check).
hot.check.deny-warnings false

hot.emitter.type "db"

hot.engine.isolation Bool(::env/get("HOT_ENGINE_ISOLATION", "false"))
hot.engine.threads Int(::env/get("HOT_ENGINE_THREADS", "4"))

hot.queue.type "memory"
//hot.queue.type "redis"
hot.queue.event-orphan-idle-ms Int(::env/get("HOT_QUEUE_EVENT_ORPHAN_IDLE_MS", "60000"))
hot.queue.task-orphan-idle-ms Int(::env/get("HOT_QUEUE_TASK_ORPHAN_IDLE_MS", "120000"))
hot.queue.infra-retry-backoff-ms Int(::env/get("HOT_QUEUE_INFRA_RETRY_BACKOFF_MS", "1000"))
hot.queue.wait-target-p99-ms Int(::env/get("HOT_QUEUE_WAIT_TARGET_P99_MS", "1000"))
hot.queue.metrics-enabled Bool(::env/get("HOT_QUEUE_METRICS_ENABLED", "true"))

hot.scheduler.backfill Bool(::env/get("HOT_SCHEDULER_BACKFILL", "false"))
hot.scheduler.sync-interval-seconds Int(::env/get("HOT_SCHEDULER_SYNC_INTERVAL_SECONDS", "10"))
hot.scheduler.retry-interval-seconds Int(::env/get("HOT_SCHEDULER_RETRY_INTERVAL_SECONDS", "1"))
hot.scheduler.at-interval-seconds Int(::env/get("HOT_SCHEDULER_AT_INTERVAL_SECONDS", "1"))
hot.scheduler.singleton Bool(::env/get("HOT_SCHEDULER_SINGLETON", "true"))

hot.serialization.type "zstdjson"

hot.lsp.transport "stdio"

hot.watch.debounce 200
hot.watch.with-tests false

// Worker Configuration
hot.worker.run-timeout Int(::env/get("HOT_WORKER_RUN_TIMEOUT", "300"))
hot.worker.shutdown-timeout Int(::env/get("HOT_WORKER_SHUTDOWN_TIMEOUT", "1"))
hot.worker.threads Int(::env/get("HOT_WORKER_THREADS", "4"))
hot.worker.vm-concurrency ::env/get("HOT_WORKER_VM_CONCURRENCY", "auto")
hot.worker.vm-memory-mb Int(::env/get("HOT_WORKER_VM_MEMORY_MB", "256"))
hot.worker.reserved-memory-mb Int(::env/get("HOT_WORKER_RESERVED_MEMORY_MB", "512"))
hot.worker.db-reserved-connections Int(::env/get("HOT_WORKER_DB_RESERVED_CONNECTIONS", "4"))
hot.worker.db-max-connections ::env/get("HOT_WORKER_DB_MAX_CONNECTIONS", "auto")
hot.worker.cancel-on-timeout Bool(::env/get("HOT_WORKER_CANCEL_ON_TIMEOUT", "true"))
hot.worker.event-ordering ::env/get("HOT_WORKER_EVENT_ORDERING", "current")
hot.worker.handler-concurrency ::env/get("HOT_WORKER_HANDLER_CONCURRENCY", "serial")
hot.worker.shared-process Bool(::env/get("HOT_WORKER_SHARED_PROCESS", "true"))
hot.worker.local-write-concurrency Int(::env/get("HOT_WORKER_LOCAL_WRITE_CONCURRENCY", "1"))
hot.worker.read-batch-size Int(::env/get("HOT_WORKER_READ_BATCH_SIZE", "8"))

// =============================================================================
// Task Configuration (long-running tasks via ::hot::task/start)
// =============================================================================
hot.task.max-concurrent Int(::env/get("HOT_TASK_MAX_CONCURRENT", "4")) // Max concurrent tasks in the task worker
hot.task.code-max-concurrent Int(::env/get("HOT_TASK_CODE_MAX_CONCURRENT", "500"))
hot.task.code-vm-memory-mb Int(::env/get("HOT_TASK_CODE_VM_MEMORY_MB", "256"))
hot.task.code-memory-percent Int(::env/get("HOT_TASK_CODE_MEMORY_PERCENT", "50"))
hot.task.worker-memory-mb Int(::env/get("HOT_TASK_WORKER_MEMORY_MB", "8192"))
hot.task.worker-disk-mb Int(::env/get("HOT_TASK_WORKER_DISK_MB", "51200"))
hot.task.container-max-concurrent ::env/get("HOT_TASK_CONTAINER_MAX_CONCURRENT", "auto")
hot.task.container-reserved-memory-mb Int(::env/get("HOT_TASK_CONTAINER_RESERVED_MEMORY_MB", "512"))
hot.task.container-reserved-disk-mb Int(::env/get("HOT_TASK_CONTAINER_RESERVED_DISK_MB", "10240"))
hot.task.recovery-reserved-slots Int(::env/get("HOT_TASK_RECOVERY_RESERVED_SLOTS", "1"))
hot.task.capacity-fairness ::env/get("HOT_TASK_CAPACITY_FAIRNESS", "none")
hot.task.shutdown-drain-seconds Int(::env/get("HOT_TASK_SHUTDOWN_DRAIN_SECONDS", "5"))
hot.task.shutdown-container-timeout-seconds Int(::env/get("HOT_TASK_SHUTDOWN_CONTAINER_TIMEOUT_SECONDS", "30"))
hot.task.reconcile-queued-after-seconds Int(::env/get("HOT_TASK_RECONCILE_QUEUED_AFTER_SECONDS", "60"))
hot.task.reconcile-interval-seconds Int(::env/get("HOT_TASK_RECONCILE_INTERVAL_SECONDS", "30"))

// Box Configuration (container execution via ::hot::box/start)
// =============================================================================
// Box support is still evolving; keep the default backend explicit.
hot.box.enabled Bool(::env/get("HOT_BOX_ENABLED", "true"))
hot.box.backend ::env/get("HOT_BOX_BACKEND", "docker") // "docker" (default) or "firecracker"

hot.daemon false

hot.deploy.auto true

// =============================================================================
// Additional Test, Demo, and Integration Projects
// =============================================================================
// These project definitions are kept at the end so core runtime configuration
// remains easy to scan near the top of the file.

// =============================================================================
// Package Unit Test Projects
// =============================================================================

// hot-ai unit tests
hot.project.pkg-test-hot-ai.src.paths ["./hot/pkg/hot-ai/src"]
hot.project.pkg-test-hot-ai.test.paths ["./hot/pkg/hot-ai/test"]
hot.project.pkg-test-hot-ai.test.capture true
hot.project.pkg-test-hot-ai.deps {
    "hot.dev/hot-std": { "local": "./hot/pkg/hot-std" }
}

// hot-ai-agent unit tests
hot.project.pkg-test-hot-ai-agent.src.paths ["./hot/pkg/hot-ai-agent/src"]
hot.project.pkg-test-hot-ai-agent.test.paths ["./hot/pkg/hot-ai-agent/test"]
hot.project.pkg-test-hot-ai-agent.test.capture true
hot.project.pkg-test-hot-ai-agent.deps {
    "hot.dev/hot-ai": { "local": "./hot/pkg/hot-ai" }
}

// mcp unit tests (pure-Hot, no network required)
hot.project.pkg-test-mcp.src.paths ["./hot/pkg/mcp/src"]
hot.project.pkg-test-mcp.test.paths ["./hot/pkg/mcp/test"]
hot.project.pkg-test-mcp.test.capture true
hot.project.pkg-test-mcp.deps {
    "hot.dev/hot-ai":   { "local": "./hot/pkg/hot-ai" },
    "hot.dev/json-rpc": { "local": "./hot/pkg/json-rpc" }
}

// anthropic unit tests (hermetic; live smoke tests self-gate on HOT_LIVE_TESTS)
hot.project.pkg-test-anthropic.src.paths ["./hot/pkg/anthropic/src"]
hot.project.pkg-test-anthropic.test.paths ["./hot/pkg/anthropic/test"]
hot.project.pkg-test-anthropic.test.capture true
hot.project.pkg-test-anthropic.deps {
    "hot.dev/hot-ai": { "local": "./hot/pkg/hot-ai" }
}

// openai unit tests (hermetic; live smoke tests self-gate on HOT_LIVE_TESTS)
hot.project.pkg-test-openai.src.paths ["./hot/pkg/openai/src"]
hot.project.pkg-test-openai.test.paths ["./hot/pkg/openai/test"]
hot.project.pkg-test-openai.test.capture true
hot.project.pkg-test-openai.deps {
    "hot.dev/hot-ai": { "local": "./hot/pkg/hot-ai" }
}

// supabase unit tests (pure-Hot filter/query builders, no network required)
hot.project.pkg-test-supabase.src.paths ["./hot/pkg/supabase/src"]
hot.project.pkg-test-supabase.test.paths ["./hot/pkg/supabase/test"]
hot.project.pkg-test-supabase.test.capture true
hot.project.pkg-test-supabase.deps {}

// supabase-admin unit tests (pure-Hot path builders, no network required)
hot.project.pkg-test-supabase-admin.src.paths ["./hot/pkg/supabase-admin/src"]
hot.project.pkg-test-supabase-admin.test.paths ["./hot/pkg/supabase-admin/test"]
hot.project.pkg-test-supabase-admin.test.capture true
hot.project.pkg-test-supabase-admin.deps {}

// twilio unit tests (pure-Hot form/query encoders, no network required)
hot.project.pkg-test-twilio.src.paths ["./hot/pkg/twilio/src"]
hot.project.pkg-test-twilio.test.paths ["./hot/pkg/twilio/test"]
hot.project.pkg-test-twilio.test.capture true
hot.project.pkg-test-twilio.deps {}

// stripe unit tests (pure-Hot form encoder + webhook signature verification)
hot.project.pkg-test-stripe.src.paths ["./hot/pkg/stripe/src"]
hot.project.pkg-test-stripe.test.paths ["./hot/pkg/stripe/test"]
hot.project.pkg-test-stripe.test.capture true
hot.project.pkg-test-stripe.deps {}

// airtable unit tests (hermetic)
hot.project.pkg-test-airtable.src.paths ["./hot/pkg/airtable/src"]
hot.project.pkg-test-airtable.test.paths ["./hot/pkg/airtable/test"]
hot.project.pkg-test-airtable.test.capture true
