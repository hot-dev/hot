::hubspot::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the hubspot integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "hubspot.token": ::env/get("HUBSPOT_TOKEN", ""),
    "hubspot.client.secret": ::env/get("HUBSPOT_CLIENT_SECRET", ""),
})
