}


sort-by
meta {
    core: true,
    doc: """
    Sort `coll` by keys derived from `func(x)`.

    **Example**

    ```hot
    users [{name: "Bob", age: 30}, {name: "Alice", age: 25}]
    sort-by(users, %.age)
    // [{name: "Alice", age: 25}, {name: "Bob", age: 30}]
    ```
    """
}
fn (coll: Str | Vec | Map, func: Fn): Str | Vec | Map {
    call-lib(::hot::coll/sort-by, [coll, func])
}


shuffle
meta {
    core: true,
    doc: """
    Return a new collection with elements of `coll` in random order.

    **Example**

    ```hot
    shuffle([1, 2, 3, 4, 5])
    // [3, 1, 5, 2, 4] (random order)
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/shuffle, [coll])
}


interleave
meta {
    core: true,
    doc: """
    Alternate elements from `a` and `b`.

    **Example**

    ```hot
    interleave([1, 3, 5], [2, 4, 6])
    // [1, 2, 3, 4, 5, 6]
    ```
    """
}
fn (a: Str | Vec | Map, b: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/interleave, [a, b])
}


interpose
meta {
    core: true,
    doc: """
    Insert `separator` between elements of `coll`.

    **Example**

    ```hot
    interpose(["a", "b", "c"], ",")
    // ["a", ",", "b", ",", "c"]
    ```
    """
}
fn (coll: Str | Vec | Map, separator: Any): Str | Vec | Map {
    call-lib(::hot::coll/interpose, [coll, separator])
}


flatten
meta {
    core: true,
    doc: """
    Flatten nested collections by one level.

    **Example**

    ```hot
    flatten([[1, 2], [3, [4, 5]], 6])
    // [1, 2, 3, 4, 5, 6]
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/flatten, [coll])
}


zipmap
meta {
    core: true,
    doc: """
    Create a map from keys in `a` and values in `b`.

    **Example**

    ```hot
    zipmap(["a", "b", "c"], [1, 2, 3])
    // {a: 1, b: 2, c: 3}
    ```
    """
}
fn (a: Vec, b: Vec): Map {
    call-lib(::hot::coll/zipmap, [a, b])
}


index-by
meta {
    core: true,
    doc: """
    Index a collection by a key function, returning a map from key to element.
    If multiple elements produce the same key, the last one wins.

    **Example**

    ```hot
    users [
      {id: 1, name: "Alice"},
      {id: 2, name: "Bob"},
      {id: 3, name: "Carol"}
    ]

    index-by(users, %.id)
    // {1: {id: 1, name: "Alice"}, 2: {id: 2, name: "Bob"}, 3: {id: 3, name: "Carol"}}

    // Quick lookup after indexing
    by-id index-by(users, %.id)
    get(by-id, 2).name  // "Bob"

    // Index by a derived key
    index-by(["apple", "banana", "cherry"], first)
    // {a: "apple", b: "banana", c: "cherry"}
    ```
    """
}
fn (coll: Vec, func: Fn): Map {
    reduce(coll, (acc, x) { assoc(acc, func(x), x) }, {})
}


group-by
meta {
    core: true,
    doc: """
    Group elements of a collection by a key function.
    Returns a map from key to a vector of elements that produced that key.

    **Example**

    ```hot
    orders [
      {id: 1, status: "pending"},
      {id: 2, status: "shipped"},
      {id: 3, status: "pending"},
      {id: 4, status: "delivered"},
      {id: 5, status: "shipped"}
    ]

    group-by(orders, %.status)
    // {
    //   pending:   [{id: 1, ...}, {id: 3, ...}],
    //   shipped:   [{id: 2, ...}, {id: 5, ...}],
    //   delivered: [{id: 4, ...}]
    // }

    // Group numbers by even/odd
    group-by([1, 2, 3, 4, 5, 6], if(eq(mod(%, 2), 0), "even", "odd"))
    // {odd: [1, 3, 5], even: [2, 4, 6]}
    ```
    """
}
fn (coll: Vec, func: Fn): Map {
    reduce(coll, (acc, x) {
        k func(x)
        existing get(acc, k, [])
        assoc(acc, k, concat(existing, [x]))
    }, {})
}


frequencies
meta {
    core: true,
    doc: """
    Count the number of occurrences of each element in a collection.
    Returns a map from element to count.

    **Example**

    ```hot
    frequencies(["a", "b", "a", "c", "a", "b"])
    // {a: 3, b: 2, c: 1}

    frequencies([1, 2, 2, 3, 3, 3])
    // {1: 1, 2: 2, 3: 3}

    // Count word occurrences
    words split("the cat sat on the mat", " ")
    frequencies(words)
    // {the: 2, cat: 1, sat: 1, on: 1, mat: 1}
    ```
    """
}
fn (coll: Vec): Map {
    reduce(coll, (acc, x) {
        assoc(acc, x, add(get(acc, x, 0), 1))
    }, {})
}


some
meta {
    core: true,
    doc: """
    Return true if any element of `coll` satisfies `predicate`.

    **Example**

    ```hot
    some([1, 2, 3, 4], gt(%, 3))   // true
    some([1, 2, 3], gt(%, 5))      // false
    ```
    """
}
fn (coll: Str | Vec | Map, predicate: Fn): Bool {
    call-lib(::hot::coll/some, [coll, predicate])
}


all
meta {
    core: true,
    doc: """
    Return true if all elements of `coll` satisfy `predicate`.

    **Example**

    ```hot
    all([2, 4, 6], eq(mod(%, 2), 0))  // true (all even)
    all([1, 2, 3], gt(%, 0))          // true (all positive)
    all([1, 2, 3], gt(%, 2))          // false
    ```
    """
}
fn (coll: Str | Vec | Map, predicate: Fn): Bool {
    call-lib(::hot::coll/all, [coll, predicate])
}


find-first
meta {
    core: true,
    doc: """
    Return the first element of `coll` that satisfies `predicate`, or null if none match.
    Short-circuits: stops iterating as soon as a match is found.

    **Example**

    ```hot
    find-first([1, 2, 3, 4, 5], gt(%, 3))
    // 4

    find-first([1, 2, 3], gt(%, 10))
    // null

    // Find a user by email
    users [{name: "Alice", email: "a@b.com"}, {name: "Bob", email: "b@b.com"}]
    find-first(users, eq(%.email, "b@b.com"))
    // {name: "Bob", email: "b@b.com"}

    // With or for a default
    or(find-first(items, %.featured), first(items))
    ```
    """
}
fn (coll: Vec, predicate: Fn): Any {
    call-lib(::hot::coll/find_first, [coll, predicate])
}


Reduced
meta {
    core: true,
    doc: """
    Wrapper type that signals early termination from `reduce`.
    When a reducer function returns `Reduced`, `reduce` stops iterating
    and returns the unwrapped value. Use the `reduced` function to create.

    **Fields**
    - `value` - The final accumulator value to return
    """
}
type {
    value: Any
}


reduced
meta {
    core: true,
    doc: """
    Signal early termination from inside a `reduce`. When the reducer
    returns `reduced(x)`, `reduce` immediately stops and returns `x`.
    Similar to Clojure's `reduced`.

    **Example**

    ```hot
    // Find first negative number via reduce (stops at -3)
    reduce([1, 2, -3, 4, 5], (acc, x) {
        if(lt(x, 0), reduced(x), acc)
    }, null)
    // -3

    // Sum until total exceeds a threshold
    reduce([10, 20, 30, 40], (total, x) {
        new-total add(total, x)
        if(gt(new-total, 50), reduced(new-total), new-total)
    }, 0)
    // 60

    // Short-circuit search with accumulation
    reduce(orders, (acc, order) {
        if(eq(order.status, "urgent"), reduced(order), acc)
    }, null)
    ```
    """
}
fn (value: Any): Reduced {
    Reduced({value: value})
}


slice
meta {
    core: true,
    doc: """
    Return a subrange from `coll` from `start` (inclusive) to optional `end` (exclusive).

    **Example**

    ```hot
    slice([1, 2, 3, 4, 5], 2)      // [3, 4, 5]
    slice([1, 2, 3, 4, 5], 1, 4)   // [2, 3, 4]
    slice("hello world", 0, 5)    // "hello"
    slice(Bytes([1, 2, 3, 4, 5]), 1, 3)  // Bytes([2, 3])
    ```
    """
}
fn
(coll: Str | Vec | Map | Bytes, start: Int): Str | Vec | Map | Bytes {
    call-lib(::hot::coll/slice, [coll, start])
},
(coll: Str | Vec | Map | Bytes, start: Int, end: Int): Str | Vec | Map | Bytes {
    call-lib(::hot::coll/slice, [coll, start, end])
}


keys
meta {
    core: true,
    doc: """
    Return the keys of a map or indices of a vector/string.

    **Example**

    ```hot
    keys({a: 1, b: 2})   // ["a", "b"]
    keys([10, 20, 30])        // [0, 1, 2]
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/keys, [coll])
}


vals
meta {
    core: true,
    doc: """
    Return the values of a collection.

    **Example**

    ```hot
    vals({a: 1, b: 2})   // [1, 2]
    vals([10, 20, 30])        // [10, 20, 30]
    ```
    """
}
fn (coll: Str | Vec | Map): Str | Vec | Map {
    call-lib(::hot::coll/vals, [coll])
}


// Mapcat implementation - maps function over coll, then flattens results
mapcat
meta {
    core: true,
    doc: """
    Map `f` over `coll` and concatenate the results.

    **Example**

    ```hot
    mapcat([1, 2, 3], [%, mul(%, 10)])
    // [1, 10, 2, 20, 3, 30]
    ```
    """
}
fn
(coll: Str | Vec | Map, f: Fn): Str | Vec | Map {
    coll
    |> map(f)
    |> reduce((acc, x) { concat(acc, x) }, [])
},
(coll: Str | Vec | Map, f: Fn, on-err: OnErr): Str | Vec | Map {
    call-lib(::hot::coll/mapcat, [coll, f, on-err])
}


range
meta {
    core: true,
    doc: """
    Generate a sequence from 0 to `end` (exclusive), or from `start` to `end` with optional `step`.

    **Example**

    ```hot
    range(5)          // [0, 1, 2, 3, 4]
    range(2, 7)       // [2, 3, 4, 5, 6]
    range(0, 10, 2)   // [0, 2, 4, 6, 8]
    range(10, 5, -1)  // [10, 9, 8, 7, 6]
    ```
    """
}
fn
(end: Int | Dec): Vec<Int | Dec> {
    call-lib(::hot::coll/range, [end])
},
(start: Int | Dec, end: Int | Dec): Vec<Int | Dec> {
    call-lib(::hot::coll/range, [start, end])
},
(start: Int | Dec, end: Int | Dec, step: Int | Dec): Vec<Int | Dec> {
    call-lib(::hot::coll/range, [start, end, step])
}


walk
meta {
    core: true,
    doc: """
    Walk through a data structure applying inner function to children, then outer function to result.

    **Example**

    ```hot
    // Double all numbers in a nested structure
    walk(
        if(is-int(%), mul(%, 2), %),
        %,
        {a: [1, 2], b: 3}
    )
    // {a: [2, 4], b: 6}
    ```
    """
}
fn (inner: Fn, outer: Fn, form: Any): Any {
    call-lib(::hot::coll/walk, [inner, outer, form])
}


prewalk
meta {
    core: true,
    doc: """
    Pre-order walk: apply function to each node before walking children.

    **Example**

    ```hot
    prewalk(if(is-int(%), mul(%, 2), %), [1, [2, 3]])
    // [2, [4, 6]]
    ```
    """
}
fn (f: Fn, form: Any): Any {
    call-lib(::hot::coll/prewalk, [f, form])
}


postwalk
meta {
    core: true,
    doc: """
    Post-order walk: apply function to each node after walking children.

    **Example**

    ```hot
    postwalk(if(is-int(%), mul(%, 2), %), [1, [2, 3]])
    // [2, [4, 6]]
    ```
    """
}
fn (f: Fn, form: Any): Any {
    call-lib(::hot::coll/postwalk, [f, form])
}


postwalk-replace
meta {
    core: true,
    doc: """
    Replace values in a structure based on a replacement map using post-order walk.

    **Example**

    ```hot
    postwalk-replace({a: "x", b: "y"}, ["a", ["b", "c"]])
    // ["x", ["y", "c"]]
    ```
    """
}
fn (replacement-map: Map, form: Any): Any {
    call-lib(::hot::coll/postwalk-replace, [replacement-map, form])
}
