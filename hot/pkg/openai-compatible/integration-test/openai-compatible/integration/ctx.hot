::openai-compatible::integration::ctx ns
meta {
    doc: """Placeholder credential wiring for the openai-compatible integration suite: copies `OPENAI_COMPATIBLE_URL`, `OPENAI_COMPATIBLE_API_KEY` from the environment into context at load. Unset variables are skipped."""
}

set-ctx fn (key: Str, env-name: Str, secret: Bool): Null {
    value ::hot::env/get(env-name, "")
    cond {
        is-empty(value) => { null }
        secret => {
            ::hot::ctx/set-secret(key, value)
            null
        }
        => {
            ::hot::ctx/set(key, value)
            null
        }
    }
}

wired [
    set-ctx("openai-compatible.url", "OPENAI_COMPATIBLE_URL", false),
    set-ctx("openai-compatible.api.key", "OPENAI_COMPATIBLE_API_KEY", true)
]
