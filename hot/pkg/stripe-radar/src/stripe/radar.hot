list-all-open-reviews
meta {doc: """GET /v1/reviews - List all open reviews"""}
fn (created: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, request: GetReviewsRequest): GetReviewsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/reviews?created=${created}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetReviewsResponse(response.body), err(HttpError(response)))
}

