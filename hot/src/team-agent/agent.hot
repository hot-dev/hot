// ============================================================================
// MCP Tool: Let external AI agents search any registered session's brain
// ============================================================================

search-brain
meta {
    doc: "Search a registered session's history using semantic search. Pass session_id to target a specific chat; defaults to the first registered session.",
    agent: TeamAgent,
    mcp: {
        service: "team-agent",
        name: "search_team_agent",
        description: "Search a chat's message history by meaning. Returns relevant messages with sender and relevance score.",
    },
}
fn (params) {
  query or(params.query, "")
  limit or(params.limit, 10)

  // Pick the target session: explicit session_id wins; otherwise fall
  // back to the first registered session (most installs only have one).
  registered list-registered-sessions()
  session ::agent-mcp/select-session(params, registered)

  cond {
    is-empty(query)   => { err("query is required") }
    is-null(session)  => { err("no registered sessions; pass session_id explicitly or send a message to the bot first") }
    => {
      mem make-memory(session, system-identity)
      results ::mem/recall(mem, query, {limit: limit, min-score: 0.3})
      map(results, (r) {
        {
          user: or(r.value.sender-name, "unknown"),
          message: r.value.content,
          timestamp: r.value.timestamp,
          relevance: round(mul(r.score, 100)),
        }
      })
    }
  }
}

query-team-agent-graph
meta {
    doc: "Hybrid vector plus graph retrieval over a registered TeamAgent session.",
    agent: TeamAgent,
    mcp: {
        service: "team-agent",
        name: "query_team_agent_graph",
        description: "Query TeamAgent graph memory for decisions, blockers, launch readiness, incidents, or unresolved questions.",
    },
}
fn (params) {
  query or(params.query, "")
  registered list-registered-sessions()
  session ::agent-mcp/select-session(params, registered)
  cond {
    is-empty(query)  => { err("query is required") }
    is-null(session) => { err("no registered sessions; pass session_id explicitly or send a message to the bot first") }
    => {
      mem make-memory(session, system-identity)
      result ::mem/hybrid-recall(mem, query, {
        limit: or(params.limit, 10),
        seed-node-ids: or(params.seed_node_ids, []),
      })
      {
        citations: map(result.citations, (c) {
          {
            id: c.id,
            label: c.label,
            excerpt: c.excerpt,
            score: c.score,
          }
        }),
        graph_edges: map(result.graph.edges, (e) { e.value }),
      }
    }
  }
}
