retrieve-order
meta {doc: """GET /v1/climate/orders/{order} - Retrieve an order"""}
fn (order: Str, expand: Str, request: GetClimateOrdersOrderRequest): GetClimateOrdersOrderResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/climate/orders/${order}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetClimateOrdersOrderResponse(response.body), err(HttpError(response)))
}

