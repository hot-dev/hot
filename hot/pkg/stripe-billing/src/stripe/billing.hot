fn (collection-method: Str, created: Str, customer: Str, customer-account: Str, due-date: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, status: Str, subscription: Str, request: GetInvoicesRequest): GetInvoicesResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/invoices?collection_method=${collection-method}&created=${created}&customer=${customer}&customer_account=${customer-account}&due_date=${due-date}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}&status=${status}&subscription=${subscription}`, {}, request)
  if(is-ok-response(response), GetInvoicesResponse(response.body), err(HttpError(response)))
}

PostInvoicesRequest type {
    account_tax_ids: Any?,
    application_fee_amount: Int?,
    auto_advance: Bool?,
    automatic_tax: Map?,
    automatically_finalizes_at: Int?,
    collection_method: "charge_automatically" | "send_invoice"?,
    currency: Str?,
    custom_fields: Any?,
    customer: Str?,
    customer_account: Str?,
    days_until_due: Int?,
    default_payment_method: Str?,
    default_source: Str?,
    default_tax_rates: Vec<Str>?,
    description: Str?,
    discounts: Any?,
    due_date: Int?,
    effective_at: Int?,
    expand: Vec<Str>?,
    footer: Str?,
    from_invoice: Map?,
    issuer: Map?,
    metadata: Any?,
    number: Str?,
    on_behalf_of: Str?,
    payment_settings: Map?,
    pending_invoice_items_behavior: "exclude" | "include"?,
    rendering: Map?,
    shipping_cost: Map?,
    shipping_details: Map?,
    statement_descriptor: Str?,
    subscription: Str?,
    transfer_data: Map?
}

