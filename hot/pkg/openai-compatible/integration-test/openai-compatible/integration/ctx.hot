::openai-compatible::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the openai-compatible integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "openai-compatible.url": ::env/get("OPENAI_COMPATIBLE_URL", ""),
    "openai-compatible.api.key": ::env/get("OPENAI_COMPATIBLE_API_KEY", ""),
})
