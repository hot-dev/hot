::discord::guilds ns

api-request ::discord::api/request
HttpError ::discord::api/HttpError
is-ok-response ::hot::http/is-ok-response

// ============================================================================
// Guild Info
// ============================================================================

GetGuildRequest type {
  guild_id: Str,
  with_counts: Bool?
}

get-guild
meta {
    doc: """
GET /guilds/{guild_id} - Get a guild by ID. Set `with_counts: true` to include approximate member and presence counts.

**Example**

```hot
::guilds ::discord::guilds

response ::guilds/get-guild(::guilds/GetGuildRequest({
  guild_id: "123456789",
  with_counts: true
}))
response.name                      // => "My Server"
response.approximate_member_count  // => 150
```
"""
}
fn (request: GetGuildRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/guilds/${request.guild_id}?with_counts=${or(request.with_counts, "")}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

GetGuildPreviewRequest type {
  guild_id: Str
}

get-guild-preview
meta {
    doc: """GET /guilds/{guild_id}/preview - Get a guild preview. Available for discoverable guilds; returns name, icon, splash, emojis, features, and counts."""
}
fn (request: GetGuildPreviewRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/preview`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

ModifyGuildRequest type {
  guild_id: Str,
  name: Str?,
  verification_level: Int?,
  default_message_notifications: Int?,
  explicit_content_filter: Int?,
  afk_channel_id: Str?,
  afk_timeout: Int?,
  icon: Str?,
  owner_id: Str?,
  splash: Str?,
  system_channel_id: Str?,
  system_channel_flags: Int?,
  rules_channel_id: Str?,
  public_updates_channel_id: Str?,
  preferred_locale: Str?,
  description: Str?
}

modify-guild
meta {
    doc: """PATCH /guilds/{guild_id} - Modify guild settings. Requires MANAGE_GUILD. Only specified fields are updated."""
}
fn (request: ModifyGuildRequest): Map {
  body {
    name: request.name,
    verification_level: request.verification_level,
    default_message_notifications: request.default_message_notifications,
    explicit_content_filter: request.explicit_content_filter,
    afk_channel_id: request.afk_channel_id,
    afk_timeout: request.afk_timeout,
    icon: request.icon,
    owner_id: request.owner_id,
    splash: request.splash,
    system_channel_id: request.system_channel_id,
    system_channel_flags: request.system_channel_flags,
    rules_channel_id: request.rules_channel_id,
    public_updates_channel_id: request.public_updates_channel_id,
    preferred_locale: request.preferred_locale,
    description: request.description
  }

  response api-request("PATCH", `${::discord::core/BASE_URL}/guilds/${request.guild_id}`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

// ============================================================================
// Members
// ============================================================================

GetGuildMemberRequest type {
  guild_id: Str,
  user_id: Str
}

get-guild-member
meta {
    doc: """
GET /guilds/{guild_id}/members/{user_id} - Get a specific guild member. Returns the member object with roles, nickname, and join date.

**Example**

```hot
::guilds ::discord::guilds

response ::guilds/get-guild-member(::guilds/GetGuildMemberRequest({
  guild_id: "123456789",
  user_id: "987654321"
}))
response.user.username  // => "some-user"
response.nick           // => "Server Nickname"
response.roles          // => ["role-id-1", "role-id-2"]
```
"""
}
fn (request: GetGuildMemberRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/members/${request.user_id}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

ListGuildMembersRequest type {
  guild_id: Str,
  limit: Int?,
  after: Str?
}

list-guild-members
meta {
    doc: """GET /guilds/{guild_id}/members - List members of a guild. Returns up to 1000 members. Use `after` with a user ID for pagination."""
}
fn (request: ListGuildMembersRequest): Vec<Map> {
  response api-request("GET", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/members?limit=${or(request.limit, "")}&after=${or(request.after, "")}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

