}

create-guild-emoji
meta {
    doc: """POST /guilds/{guild_id}/emojis - Create a custom emoji. `image` is a base64-encoded data URI. Max 256 KB. `roles` restricts which roles can use it. Requires MANAGE_GUILD_EXPRESSIONS."""
}
fn (request: CreateGuildEmojiRequest): Map {
  body {
    name: request.name,
    image: request.image,
    roles: request.roles
