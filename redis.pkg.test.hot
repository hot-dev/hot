::hot::conf ns

::env ::hot::env

// Test configuration for the hot.dev/redis package.
//
// Runs against a local Redis/Valkey (the dev container exposes 6379).
// Override via env vars: REDISHOST, REDISPORT.
//
// Run:  cargo run -p hot_cli -- test -c redis.pkg.test.hot

hot.set.profile "redis-pkg"
hot.set.project "redis-pkg"

hot.profile.redis-pkg.user.email "redis-pkg-test@hot.dev"
hot.profile.redis-pkg.org.slug "redis-pkg"
hot.profile.redis-pkg.env.name "development"

hot.project.redis-pkg.src.paths ["./hot/pkg/redis/src"]
hot.project.redis-pkg.test.paths ["./hot/pkg/redis/test"]
hot.project.redis-pkg.test.capture true
hot.project.redis-pkg.skills.codegen.enabled false

hot.ctx.redis.host ::env/get("REDISHOST", "127.0.0.1")
hot.ctx.redis.port ::env/get("REDISPORT", "6379")

hot.log.level "info"
hot.log.target "stdout"
