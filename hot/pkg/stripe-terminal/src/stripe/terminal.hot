create-configuration
meta {doc: """POST /v1/terminal/configurations - Create a Configuration"""}
fn (request: PostTerminalConfigurationsRequest): PostTerminalConfigurationsResponse {
  response api-request("POST", `${::stripe/BASE_URL}/v1/terminal/configurations`, {}, request)
  if(is-ok-response(response), PostTerminalConfigurationsResponse(response.body), err(HttpError(response)))
}

