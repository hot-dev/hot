}

edit-message-text
meta {
    doc: """
editMessageText - Edit a text message. Provide either `chat_id` + `message_id` for regular messages, or `inline_message_id` for inline bot messages.

**Example**

```hot
::messages ::telegram::messages

::messages/edit-message-text(::messages/EditMessageTextRequest({
  chat_id: 123456789,
  message_id: 42,
  text: "Updated message text"
}))
```
"""
}
fn (request: EditMessageTextRequest): Any {
  api-request("editMessageText", untype(request))
}

