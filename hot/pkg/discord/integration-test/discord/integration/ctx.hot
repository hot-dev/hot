::discord::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the discord integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "discord.bot.token": ::env/get("DISCORD_BOT_TOKEN", ""),
    "discord.public.key": ::env/get("DISCORD_PUBLIC_KEY", ""),
})
