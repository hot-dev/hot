::sql::test::compile ns
meta ["test"]

::compile ::sql::compile

// ============================================================================
// Positional ? placeholders
// ============================================================================

test-dollar-positional
meta ["test"] fn () {
    out ::compile/compile("SELECT * FROM users WHERE id = ? AND active = ?", "dollar")
    assert-eq("SELECT * FROM users WHERE id = $1 AND active = $2", out.sql)
    assert-eq(2, out.count)
    assert-eq([null, null], out.names)
}

test-question-positional-passthrough
meta ["test"] fn () {
    out ::compile/compile("SELECT * FROM t WHERE a = ? AND b = ?", "question")
    assert-eq("SELECT * FROM t WHERE a = ? AND b = ?", out.sql)
    assert-eq(2, out.count)
}

test-no-placeholders
meta ["test"] fn () {
    out ::compile/compile("SELECT 1", "dollar")
    assert-eq("SELECT 1", out.sql)
    assert-eq(0, out.count)
}

// ============================================================================
// Named :name placeholders
// ============================================================================

test-dollar-named
meta ["test"] fn () {
    out ::compile/compile("UPDATE users SET name = :name WHERE id = :id", "dollar")
    assert-eq("UPDATE users SET name = $1 WHERE id = $2", out.sql)
    assert-eq(["name", "id"], out.names)
}

test-dollar-named-dedupes-repeats
meta ["test"] fn () {
    out ::compile/compile("SELECT * FROM t WHERE a = :x OR b = :x OR c = :y", "dollar")
    assert-eq("SELECT * FROM t WHERE a = $1 OR b = $1 OR c = $2", out.sql)
    assert-eq(["x", "y"], out.names)
    assert-eq(2, out.count)
}

test-question-named-repeats-per-occurrence
meta ["test"] fn () {
    out ::compile/compile("SELECT * FROM t WHERE a = :x OR b = :x", "question")
    assert-eq("SELECT * FROM t WHERE a = ? OR b = ?", out.sql)
    assert-eq(["x", "x"], out.names)
}

test-mixed-placeholders-error
meta ["test"] fn () {
    out ::compile/compile("SELECT * FROM t WHERE a = ? AND b = :b", "dollar")
    assert(is-err(out), "mixing ? and :name should error")
}

// ============================================================================
// Skipped regions
// ============================================================================

test-question-in-string-literal-ignored
meta ["test"] fn () {
    out ::compile/compile("SELECT 'a?b' FROM t WHERE id = ?", "dollar")
    assert-eq("SELECT 'a?b' FROM t WHERE id = $1", out.sql)
    assert-eq(1, out.count)
}

test-escaped-quote-in-string
meta ["test"] fn () {
    out ::compile/compile("SELECT 'it''s a ?' WHERE id = ?", "dollar")
    assert-eq("SELECT 'it''s a ?' WHERE id = $1", out.sql)
}

test-quoted-identifier-ignored
meta ["test"] fn () {
    out ::compile/compile("SELECT \"weird?col\" FROM t WHERE id = ?", "dollar")
    assert-eq("SELECT \"weird?col\" FROM t WHERE id = $1", out.sql)
}

test-line-comment-ignored
meta ["test"] fn () {
    out ::compile/compile("SELECT 1 -- what? :nope\n WHERE id = ?", "dollar")
    assert-eq("SELECT 1 -- what? :nope\n WHERE id = $1", out.sql)
    assert-eq(1, out.count)
}

test-block-comment-ignored
meta ["test"] fn () {
    out ::compile/compile("SELECT /* ? :x /* nested ? */ still */ ?", "dollar")
    assert-eq("SELECT /* ? :x /* nested ? */ still */ $1", out.sql)
    assert-eq(1, out.count)
}

test-postgres-cast-not-a-named-param
meta ["test"] fn () {
    out ::compile/compile("SELECT id::text FROM t WHERE id = :id", "dollar")
    assert-eq("SELECT id::text FROM t WHERE id = $1", out.sql)
    assert-eq(["id"], out.names)
}

// ============================================================================
// ?? escape (PostgreSQL JSONB operators)
// ============================================================================

test-double-question-escapes-literal
meta ["test"] fn () {
    out ::compile/compile("SELECT * FROM t WHERE data ?? 'key' AND id = ?", "dollar")
    assert-eq("SELECT * FROM t WHERE data ? 'key' AND id = $1", out.sql)
    assert-eq(1, out.count)
}

test-double-question-operator-variants
meta ["test"] fn () {
    out ::compile/compile("SELECT data ??| array['a'] , data ??& array['b'] FROM t", "dollar")
    assert-eq("SELECT data ?| array['a'] , data ?& array['b'] FROM t", out.sql)
    assert-eq(0, out.count)
}

// ============================================================================
// Array slices are not named placeholders
// ============================================================================

test-array-slice-not-a-named-param
meta ["test"] fn () {
    out ::compile/compile("SELECT arr[1:3] FROM t WHERE id = ?", "dollar")
    assert-eq("SELECT arr[1:3] FROM t WHERE id = $1", out.sql)
    assert-eq([null], out.names)
}

// ============================================================================
// Dollar-quoted strings (dollar style)
// ============================================================================

test-dollar-quoted-string-ignored
meta ["test"] fn () {
    out ::compile/compile("SELECT $$literal ? :x$$ , ?", "dollar")
    assert-eq("SELECT $$literal ? :x$$ , $1", out.sql)
    assert-eq(1, out.count)
}

test-tagged-dollar-quote-ignored
meta ["test"] fn () {
    out ::compile/compile("CREATE FUNCTION f() AS $fn$ SELECT ?; $$ still inside $fn$ WHERE id = ?", "dollar")
    assert-eq("CREATE FUNCTION f() AS $fn$ SELECT ?; $$ still inside $fn$ WHERE id = $1", out.sql)
    assert-eq(1, out.count)
}

test-bare-dollar-passes-through
meta ["test"] fn () {
    // "$1" is not a dollar-quote opener (tags are identifier-shaped).
    out ::compile/compile("SELECT '$'::text , ? , 5 $ 3", "dollar")
    assert-eq("SELECT '$'::text , $1 , 5 $ 3", out.sql)
}

// ============================================================================
// MySQL dialect lexing
// ============================================================================

test-mysql-backslash-escaped-quote
meta ["test"] fn () {
    // With MySQL's default sql_mode, \' stays inside the string; without
    // backslash handling the string would end early and swallow the ?.
    out ::compile/compile("SELECT 'it\\'s a ?' FROM t WHERE id = ?", "question", "mysql")
    assert-eq("SELECT 'it\\'s a ?' FROM t WHERE id = ?", out.sql)
    assert-eq(1, out.count)
}

test-mysql-hash-comment
meta ["test"] fn () {
    out ::compile/compile("SELECT 1 # what? :nope\nFROM t WHERE id = ?", "question", "mysql")
    assert-eq("SELECT 1 # what? :nope\nFROM t WHERE id = ?", out.sql)
    assert-eq(1, out.count)
}

test-backtick-identifier-ignored
meta ["test"] fn () {
    out ::compile/compile("SELECT `weird ? col` FROM t WHERE id = :id", "question", "mysql")
    assert-eq("SELECT `weird ? col` FROM t WHERE id = ?", out.sql)
    assert-eq(["id"], out.names)
}

test-pg-string-backslash-is-literal
meta ["test"] fn () {
    // PostgreSQL standard strings treat backslash literally: '\' is a
    // complete string and the following ? is a real placeholder.
    out ::compile/compile("SELECT '\\' , ?", "dollar", "pg")
    assert-eq("SELECT '\\' , $1", out.sql)
    assert-eq(1, out.count)
}
