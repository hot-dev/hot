ListThreadMembersRequest type {
  channel_id: Str,
  with_member: Bool?,
  after: Str?,
  limit: Int?
}

list-thread-members
meta {
    doc: """GET /channels/{channel_id}/thread-members - List members of a thread. Returns thread member objects."""
}
fn (request: ListThreadMembersRequest): Vec<Map> {
  response api-request("GET", `${::discord::core/BASE_URL}/channels/${request.channel_id}/thread-members?with_member=${or(request.with_member, "")}&after=${or(request.after, "")}&limit=${or(request.limit, "")}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

