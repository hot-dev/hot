::hot::test::result-boundary ns
meta ["test"]

// The strict-argument law at hotlib call boundaries: a Result.Err passed
// in any strict argument position halts ("Result error: ..."), Result.Ok
// auto-unwraps, lazy arguments and the Result-aware inspection natives
// (is-err, if-err, ok-value, err-value, ...) are exempt, and OnErr
// annotations govern callback results only — never the collection
// argument.

::exec ::hot::internal::exec

make-err fn (): Any {
    err("boundary-payload")
}

// ----------------------------------------------------------------------------
// Err in the collection position halts — every HOF, both map arities
// ----------------------------------------------------------------------------

test-map-over-err-halts
meta ["test"] fn () {
    out ::exec/contain(() {
        r make-err()
        map(r, (e) { e })
    })
    assert(is-err(out), "map over an Err must halt, not iterate its internals")
    assert(contains(err-message(out), "boundary-payload"), "halt carries the payload")
}

test-map-preserve-arity-over-err-still-halts
meta ["test"] fn () {
    // OnErr.Preserve governs per-element callback results; a collection-level
    // Err has no slots to preserve and must still halt.
    out ::exec/contain(() {
        r make-err()
        map(r, (e) { e }, OnErr.Preserve)
    })
    assert(is-err(out), "OnErr.Preserve does not exempt the collection argument")
}

test-filter-over-err-halts
meta ["test"] fn () {
    out ::exec/contain(() {
        r make-err()
        filter(r, (e) { true })
    })
    assert(is-err(out), "filter over an Err must halt")
}

test-reduce-over-err-halts
meta ["test"] fn () {
    out ::exec/contain(() {
        r make-err()
        reduce(r, (acc, e) { acc }, [])
    })
    assert(is-err(out), "reduce over an Err must halt")
}

// ----------------------------------------------------------------------------
// Err in other strict positions halts too
// ----------------------------------------------------------------------------

test-err-in-second-strict-position-halts
meta ["test"] fn () {
    out ::exec/contain(() {
        r make-err()
        join(["a", "b"], r)
    })
    assert(is-err(out), "join separator must not accept an Err")
}

test-err-interpolation-halts
meta ["test"] fn () {
    out ::exec/contain(() {
        r make-err()
        concat("prefix: ", r)
    })
    assert(is-err(out), "concat must not stringify an Err")
}

// ----------------------------------------------------------------------------
// Ok auto-unwraps at the boundary
// ----------------------------------------------------------------------------

test-ok-collection-auto-unwraps
meta ["test"] fn () {
    wrapped ok([1, 2, 3])
    assert-eq([2, 3, 4], map(wrapped, add(%, 1)), "Ok-wrapped collection unwraps at the boundary")
}

// ----------------------------------------------------------------------------
// The sanctioned inspection points stay exempt
// ----------------------------------------------------------------------------

test-result-aware-natives-receive-errs
meta ["test"] fn () {
    r make-err()
    assert(is-err(r), "is-err receives the Err")
    assert(not(is-ok(r)), "is-ok receives the Err")
    assert-eq("boundary-payload", if-err(r, (e) { e }), "if-err handler sees the payload")
    assert-eq("boundary-payload", err-value(r), "err-value extracts the payload")
    assert-eq("boundary-payload", err-message(r), "err-message reads the payload")
}

test-onerr-preserve-callback-errs-survive
meta ["test"] fn () {
    // The complementary contract: with a REAL collection, per-element
    // callback Errs stay in their slots under OnErr.Preserve — including
    // when handed to the Result-aware natives by filter.
    load fn cond (n: Int): Any {
        eq(n, 0) => { err("missing") }
        => { mul(n, 10) }
    }

    scores map([1, 0, 3], (n) { load(n) }, OnErr.Preserve)
    assert-eq(3, length(scores), "every slot kept")
    assert(is-err(scores[1]), "the failing slot stays an Err value")
    assert-eq(1, length(filter(scores, is-err)), "filter + is-err over Err slots works")
}

// ----------------------------------------------------------------------------
// JIT parity: the law must hold identically once the function compiles
// ----------------------------------------------------------------------------

test-jit-warm-map-over-err-halts
meta ["test"] fn () {
    // Warm the mapping fn well past the JIT threshold with valid input,
    // then hit it with an Err collection: the compiled path must halt
    // exactly like the interpreter did on call one.
    double-all fn (coll: Any): Any {
        map(coll, mul(%, 2))
    }

    warmed reduce(range(0, 200), (acc, i) {
        add(acc, first(double-all([i])))
    }, 0)
    assert(gt(warmed, 0), "warm loop ran")

    out ::exec/contain(() {
        r make-err()
        double-all(r)
    })
    assert(is-err(out), "JIT-compiled map over an Err must halt like the interpreter")
    assert(contains(err-message(out), "boundary-payload"), "halt carries the payload through the JIT boundary")
}
