::hubspot::integration::ctx ns
meta {
    doc: """Placeholder credential wiring for the hubspot integration suite: copies `HUBSPOT_TOKEN`, `HUBSPOT_CLIENT_SECRET` from the environment into context at load. Unset variables are skipped."""
}

set-ctx fn (key: Str, env-name: Str, secret: Bool): Null {
    value ::hot::env/get(env-name, "")
    cond {
        is-empty(value) => { null }
        secret => {
            ::hot::ctx/set-secret(key, value)
            null
        }
        => {
            ::hot::ctx/set(key, value)
            null
        }
    }
}

wired [
    set-ctx("hubspot.token", "HUBSPOT_TOKEN", true),
    set-ctx("hubspot.client.secret", "HUBSPOT_CLIENT_SECRET", true)
]
