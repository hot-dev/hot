test-video-creation
meta ["test"]
fn () {
    file-meta mock-file-meta("videos/clip.mp4", 1234567)

    video-data Video({
        file: file-meta,
        prompt: "A timelapse of clouds",
        revised_prompt: "A stunning timelapse of cumulus clouds moving across a blue sky",
        model: "sora",
        provider: "openai",
        duration_seconds: 15.0,
        width: 1920,
        height: 1080,
        format: "mp4",
        fps: 30
    })

    media Media.Video(video-data)

    assert(not(::hot::media/is-image(media)), "Should not be identified as image")
    assert(not(::hot::media/is-audio(media)), "Should not be identified as audio")
    assert(::hot::media/is-video(media), "Should be identified as video")
    assert(::hot::media/has-duration(media), "Video should have duration")
}

test-video-field-access
