}

start-thread-from-message
meta {
    doc: """POST /channels/{channel_id}/messages/{message_id}/threads - Create a new thread from an existing message. `auto_archive_duration` can be 60, 1440, 4320, or 10080 minutes."""
}
fn (request: StartThreadFromMessageRequest): Map {
  body {
    name: request.name,
    auto_archive_duration: request.auto_archive_duration,
    rate_limit_per_user: request.rate_limit_per_user
  }

  response api-request("POST", `${::discord::core/BASE_URL}/channels/${request.channel_id}/messages/${request.message_id}/threads`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

