list-all-file-links
meta {doc: """GET /v1/file_links - List all file links"""}
fn (created: Str, ending-before: Str, expand: Str, expired: Str, file: Str, limit: Str, starting-after: Str, request: GetFileLinksRequest): GetFileLinksResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/file_links?created=${created}&ending_before=${ending-before}&expand=${expand}&expired=${expired}&file=${file}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetFileLinksResponse(response.body), err(HttpError(response)))
}

