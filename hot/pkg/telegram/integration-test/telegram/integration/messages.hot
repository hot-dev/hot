test-send-location
meta ["test"]
fn () {
  assert(TELEGRAM_TEST_CHAT_ID, "Set TELEGRAM_TEST_CHAT_ID in .env for Telegram integration tests")

  chat-id Int(TELEGRAM_TEST_CHAT_ID)

  response ::telegram::messages/send-location(::telegram::messages/SendLocationRequest({
    chat_id: chat-id,
    latitude: 37.7749,
    longitude: -122.4194
  }))

  assert(response.message_id, "sendLocation should return message_id")
  assert(response.location, "sendLocation should return location")

  ::telegram::messages/delete-message(::telegram::messages/DeleteMessageRequest({
    chat_id: chat-id,
    message_id: response.message_id
  }))
}

test-send-dice
meta ["test"]
fn () {
  assert(TELEGRAM_TEST_CHAT_ID, "Set TELEGRAM_TEST_CHAT_ID in .env for Telegram integration tests")

  chat-id Int(TELEGRAM_TEST_CHAT_ID)

  response ::telegram::messages/send-dice(::telegram::messages/SendDiceRequest({
    chat_id: chat-id
  }))

  assert(response.message_id, "sendDice should return message_id")
  assert(response.dice, "sendDice should return dice")
  assert(between(response.dice.value, 1, 6), "dice value should be 1-6")

  ::telegram::messages/delete-message(::telegram::messages/DeleteMessageRequest({
    chat_id: chat-id,
    message_id: response.message_id
  }))
}

test-forward-message
meta ["test"]
fn () {
  assert(TELEGRAM_TEST_CHAT_ID, "Set TELEGRAM_TEST_CHAT_ID in .env for Telegram integration tests")

  chat-id Int(TELEGRAM_TEST_CHAT_ID)

  original ::telegram::messages/send-message(::telegram::messages/SendMessageRequest({
    chat_id: chat-id,
    text: "Hot integration test — forward source"
  }))

  forwarded ::telegram::messages/forward-message(::telegram::messages/ForwardMessageRequest({
    chat_id: chat-id,
    from_chat_id: chat-id,
    message_id: original.message_id
  }))

  assert(forwarded.message_id, "forwardMessage should return message_id")
  assert(ne(forwarded.message_id, original.message_id), "forwarded message should have a new id")

  ::telegram::messages/delete-messages(::telegram::messages/DeleteMessagesRequest({
    chat_id: chat-id,
    message_ids: [original.message_id, forwarded.message_id]
  }))
}

test-copy-message
meta ["test"]
fn () {
  assert(TELEGRAM_TEST_CHAT_ID, "Set TELEGRAM_TEST_CHAT_ID in .env for Telegram integration tests")

  chat-id Int(TELEGRAM_TEST_CHAT_ID)

  original ::telegram::messages/send-message(::telegram::messages/SendMessageRequest({
    chat_id: chat-id,
    text: "Hot integration test — copy source"
  }))

  copied ::telegram::messages/copy-message(::telegram::messages/CopyMessageRequest({
    chat_id: chat-id,
    from_chat_id: chat-id,
    message_id: original.message_id
  }))

  assert(copied.message_id, "copyMessage should return message_id")

  ::telegram::messages/delete-messages(::telegram::messages/DeleteMessagesRequest({
    chat_id: chat-id,
    message_ids: [original.message_id, copied.message_id]
  }))
}
