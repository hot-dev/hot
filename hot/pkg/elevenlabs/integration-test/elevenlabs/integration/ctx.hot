::elevenlabs::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the elevenlabs integration suite. Unset
// environment variables are skipped entirely, so absent credentials
// behave exactly as if never configured.
::hot::ctx/set(filter-vals({
    "elevenlabs.api.key": ::env/get("ELEVENLABS_API_KEY", ""),
}, (v) { not(is-empty(v)) }))
