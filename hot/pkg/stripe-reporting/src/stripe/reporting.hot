retrieve-balance-transaction
meta {doc: """GET /v1/balance_transactions/{id} - Retrieve a balance transaction"""}
fn (id: Str, expand: Str, request: GetBalanceTransactionsIdRequest): GetBalanceTransactionsIdResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/balance_transactions/${id}?expand=${expand}`, {}, request)
  if(is-ok-response(response), GetBalanceTransactionsIdResponse(response.body), err(HttpError(response)))
}

