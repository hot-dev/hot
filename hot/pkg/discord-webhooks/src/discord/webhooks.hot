create
meta {doc: """POST /channels/{channel_id}/webhooks"""}
fn (request: CreateWebhookRequest): CreateWebhookResponse {
  response api-request("POST", `${::discord/BASE_URL}/channels/{channel_id}/webhooks`, {}, request)
  if(is-ok-response(response), CreateWebhookResponse(response.body), err(HttpError(response)))
}

