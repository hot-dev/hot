TEST_RSA_MODULUS_HEX ""

// ============================================================================
// HS256
// ============================================================================

test-sign-matches-independent-vector
meta ["test"] fn () {
    token ::jwt/sign({sub: "42", name: "Ada"}, SECRET)
    assert-eq(KNOWN_TOKEN, token)
}

test-verify-accepts-known-token
meta ["test"] fn () {
    claims ::jwt/verify(KNOWN_TOKEN, SECRET)
    assert-eq("42", claims.sub)
    assert-eq("Ada", claims.name)
}

test-verify-rejects-wrong-secret
meta ["test"] fn () {
    out ::jwt/verify(KNOWN_TOKEN, "other-secret")
    assert(is-err(out), "wrong secret should fail")
}

test-verify-rejects-tampered-payload
meta ["test"] fn () {
    parts split(KNOWN_TOKEN, ".")
    forged-payload ::hot::base64/encode-url(to-json({sub: "1", name: "Eve"}))
    forged `${parts[0]}.${forged-payload}.${parts[2]}`
    assert(is-err(::jwt/verify(forged, SECRET)), "tampered payload should fail")
}

test-verify-rejects-malformed-token
meta ["test"] fn () {
    assert(is-err(::jwt/verify("not-a-jwt", SECRET)))
    assert(is-err(::jwt/verify("a.b", SECRET)))
}

// ============================================================================
// Claims validation
// ============================================================================

test-verify-rejects-expired
meta ["test"] fn () {
    token ::jwt/sign({sub: "42", exp: 1000}, SECRET)
    out ::jwt/verify(token, SECRET, {now: 2000})
    assert(is-err(out), "expired token should fail")
}

test-verify-accepts-within-leeway
meta ["test"] fn () {
    token ::jwt/sign({sub: "42", exp: 1000}, SECRET)
    claims ::jwt/verify(token, SECRET, {now: 1030})
    assert-eq("42", claims.sub, "30s past exp is inside the default 60s leeway")
}

test-verify-rejects-nbf-in-future
meta ["test"] fn () {
    token ::jwt/sign({sub: "42", nbf: 5000}, SECRET)
    assert(is-err(::jwt/verify(token, SECRET, {now: 1000})), "nbf in future should fail")
}

test-verify-checks-issuer-and-audience
meta ["test"] fn () {
    token ::jwt/sign({sub: "42", iss: "me", aud: "you"}, SECRET)
    ok ::jwt/verify(token, SECRET, {issuer: "me", audience: "you", now: 1})
    assert-eq("42", ok.sub)
    assert(is-err(::jwt/verify(token, SECRET, {issuer: "them"})), "wrong issuer fails")
    assert(is-err(::jwt/verify(token, SECRET, {audience: "nobody"})), "wrong audience fails")
}

// ============================================================================
// decode (unverified inspection)
// ============================================================================

test-decode-exposes-header-and-payload
meta ["test"] fn () {
    decoded ::jwt/decode(KNOWN_TOKEN)
    assert-eq("HS256", decoded.header.alg)
    assert-eq("42", decoded.payload.sub)
}

// ============================================================================
// RS256
// ============================================================================

rsa-n fn (): Bytes { ::hex/decode(TEST_RSA_MODULUS_HEX) }
rsa-e fn (): Bytes { ::hex/decode("010001") }

test-rs256-sign-verify-roundtrip
meta ["test"] fn () {
    token ::jwt/sign({iss: "svc@example.iam", scope: "email"}, TEST_RSA_PEM, "RS256")
    claims ::jwt/verify-rs256(token, rsa-n(), rsa-e())
    assert-eq("svc@example.iam", claims.iss)
}

test-rs256-rejects-tampered-token
meta ["test"] fn () {
    token ::jwt/sign({iss: "svc"}, TEST_RSA_PEM, "RS256")
    parts split(token, ".")
    forged-payload ::hot::base64/encode-url(to-json({iss: "attacker"}))
    forged `${parts[0]}.${forged-payload}.${parts[2]}`
    assert(is-err(::jwt/verify-rs256(forged, rsa-n(), rsa-e())), "tampered RS256 should fail")
}

test-rs256-rejects-hs256-token
meta ["test"] fn () {
    // Algorithm-confusion guard: an HS256 token must not pass verify-rs256
    assert(is-err(::jwt/verify-rs256(KNOWN_TOKEN, rsa-n(), rsa-e())))
}

test-sign-rejects-unknown-algorithm
meta ["test"] fn () {
    assert(is-err(::jwt/sign({a: 1}, "k", "none")), "alg none must not be signable")
}

