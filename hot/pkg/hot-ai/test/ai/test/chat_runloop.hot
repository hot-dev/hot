::skill ::ai::skill

tone-skill
meta {
    skill: {
        name: "customer-tone",
        description: "Apply our customer voice rules.",
        when: ["reply", "marketing"],
        body: "Use a warm, plain-language tone."
    }
}
fn () { {} }

escalation-skill
meta {
    skill: {
        name: "escalation",
        description: "Decide when to hand off to a human.",
        when: ["refund"]
    }
}
fn () { {} }

mock-chat-records-system
meta {
    doc: """
    Mock chat-fn that echoes the system prompt it received as text and
    ends immediately. Lets us assert that the resolver index was
    injected into `system`.
    """
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    ::chat/ChatReply({
        text: or(system, ""),
        tool-calls: null,
        stop-reason: "end_turn",
        usage: null,
        raw: null
    })
}

mock-chat-records-tools
meta {
    doc: """
    Mock chat-fn that returns the joined names of every tool it received.
    """
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    names map(or(tools, []), %.name)
    ::chat/ChatReply({
        text: join(names, ","),
        tool-calls: null,
        stop-reason: "end_turn",
        usage: null,
        raw: null
    })
}

mock-chat-reads-skill
meta {
    doc: """
    Mock chat-fn that calls `read_skill("customer-tone")` on its first
    turn, then echoes the returned body once the tool result arrives.
    """
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::tool/Tool>?): ::chat/ChatReply {
    tool-msg find-first(messages, eq(%.role, "tool"))
    cond {
        is-some(tool-msg) => {
            ::chat/ChatReply({
                text: tool-msg.content,
                tool-calls: null,
                stop-reason: "end_turn",
                usage: null,
                raw: null
            })
        }
        => {
            ::chat/ChatReply({
                text: null,
                tool-calls: [::tool/ToolCall({
                    id: "rs-1",
                    name: "read_skill",
                    input: {name: "customer-tone"}
                })],
                stop-reason: "tool_use",
                usage: null,
                raw: null
            })
        }
    }
}

test-run-loop-skills-inject-resolver-index
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-records-system,
        model: "mock-model",
        skills: [tone-skill, escalation-skill]
    })
    result ::chat/run-loop(opts, "hi")
    assert(contains(result, "Available skills"), "system prompt should include resolver header")
    assert(contains(result, "customer-tone"), "system prompt should list customer-tone")
    assert(contains(result, "escalation"), "system prompt should list escalation")
}

test-run-loop-skills-merge-system-prompt
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-records-system,
        model: "mock-model",
        system: "You are a careful agent.",
        skills: [tone-skill]
    })
    result ::chat/run-loop(opts, "hi")
    assert(contains(result, "You are a careful agent."), "user system prompt should be preserved")
    assert(contains(result, "customer-tone"), "resolver index should be appended")
}

test-run-loop-skills-no-skills-leaves-system-untouched
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-records-system,
        model: "mock-model",
        system: "Plain system."
    })
    result ::chat/run-loop(opts, "hi")
    assert-eq("Plain system.", result)
}

test-run-loop-skills-add-builtin-tools
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-records-tools,
        model: "mock-model",
        tools: [::tool/from-fn(add-fn)],
        skills: [tone-skill]
    })
    result ::chat/run-loop(opts, "hi")
    assert(contains(result, "list_skills"), "list_skills builtin should be present")
    assert(contains(result, "read_skill"),  "read_skill builtin should be present")
    assert(contains(result, "apply_skill"), "apply_skill builtin should be present")
    assert(contains(result, "::ai::test::chat_runloop/add-fn"), "user-supplied tool should remain")
}

test-run-loop-skills-empty-skipped
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-records-tools,
        model: "mock-model",
        tools: [::tool/from-fn(add-fn)],
        skills: []
    })
    result ::chat/run-loop(opts, "hi")
    assert-eq("::ai::test::chat_runloop/add-fn", result)
}

test-run-loop-read-skill-roundtrip
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-reads-skill,
        model: "mock-model",
        skills: [tone-skill]
