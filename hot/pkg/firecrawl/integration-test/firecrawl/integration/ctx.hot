::firecrawl::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the firecrawl integration suite. Unset
// environment variables are skipped entirely, so absent credentials
// behave exactly as if never configured.
::hot::ctx/set(filter-vals({
    "firecrawl.api.key": ::env/get("FIRECRAWL_API_KEY", ""),
}, (v) { not(is-empty(v)) }))
