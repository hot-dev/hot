list-all-features-attached-product
meta {
    doc: """GET /v1/products/{product}/features - List all features attached to a product"""
}
fn (product: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, request: GetProductsProductFeaturesRequest): GetProductsProductFeaturesResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/products/${product}/features?ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}`, {}, request)
