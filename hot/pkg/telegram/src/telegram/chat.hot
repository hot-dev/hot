  chat_id: Any,
  invite_link: Str
}

revoke-chat-invite-link
meta {
    doc: """revokeChatInviteLink - Revoke an invite link created by the bot. The link will no longer work."""
}
fn (request: RevokeChatInviteLinkRequest): Map {
  api-request("revokeChatInviteLink", untype(request))
}

ExportChatInviteLinkRequest type {
  chat_id: Any
}

export-chat-invite-link
meta {
    doc: """exportChatInviteLink - Generate a new primary invite link. Any previously generated primary link is revoked."""
}
fn (request: ExportChatInviteLinkRequest): Str {
  api-request("exportChatInviteLink", untype(request))
}

