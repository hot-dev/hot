// =============================================================================
// TeamAgent Agent Demo
// =============================================================================
// Narrow project for deploying or testing only the Team Agent agent.
// Local development uses the default hot-dev project.
// Run with: hot dev
// Deploy:   hot deploy --project demo-team-agent
//
// TeamAgent is a multi-transport agent — Telegram and Slack adapters
// share the same agent core, transport abstraction, and skill resolver.
//
// Source layout:
//   hot/src/team-agent/        — agent.hot, transport.hot,
//                                    telegram_adapter.hot, slack_adapter.hot,
//                                    skills.hot, researcher.hot, seed.hot
//   hot/src/team-agent/resources/ — *.skill.md sources
//   hot/src/_skills/team-agent/   — codegen output (mirror of resources)
//
// We compile both the hand-authored sources and the codegen output, but
// not the rest of `hot/src/` (frontpage-demos, so-fire, etc.) so the
// demo stays self-contained.
hot.project.demo-team-agent.src.paths [
    "./hot/src/team-agent",
    "./hot/src/_skills/team-agent",
]
hot.project.demo-team-agent.test.paths ["./hot/src/team-agent/test"]
hot.project.demo-team-agent.test.capture true
hot.project.demo-team-agent.resources.paths [
    "./hot/src/team-agent/resources",
]
// Codegen owns hot/src/_skills/team-agent/ — re-runs of `hot dev`
// regenerate the stubs from `*.skill.md` sources whenever the source
// changes, and prune stubs whose source disappeared.
hot.project.demo-team-agent.skills.codegen.enabled true
hot.project.demo-team-agent.deps {
    "hot.dev/hot-ai":    { "local": "./hot/pkg/hot-ai" },
    "hot.dev/hot-ai-agent": { "local": "./hot/pkg/hot-ai-agent" },
    "hot.dev/telegram":  { "local": "./hot/pkg/telegram" },
    "hot.dev/slack":     { "local": "./hot/pkg/slack" },
    "hot.dev/anthropic": { "local": "./hot/pkg/anthropic" },
    "hot.dev/openai":    { "local": "./hot/pkg/openai" },
    "hot.dev/whisper":   { "local": "./hot/pkg/whisper" },
}

// =============================================================================
// PersonalAgent Demo
// =============================================================================
hot.project.demo-personal-agent.src.paths [
    "./hot/src/personal-agent",
    "./hot/src/_skills/personal-agent",
]
hot.project.demo-personal-agent.test.paths ["./hot/src/personal-agent/test"]
hot.project.demo-personal-agent.test.capture true
hot.project.demo-personal-agent.resources.paths [
    "./hot/src/personal-agent/resources",
]
hot.project.demo-personal-agent.skills.codegen.enabled true
hot.project.demo-personal-agent.deps {
    "hot.dev/hot-ai":       { "local": "./hot/pkg/hot-ai" },
    "hot.dev/hot-ai-agent": { "local": "./hot/pkg/hot-ai-agent" },
}

