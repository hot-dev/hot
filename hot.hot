::hot::conf ns

// Namespace alias for env module
::env ::hot::env

hot.set.profile "local-dev"
hot.set.project "hot-dev"
hot.set.remote "hot-dev"

hot.profile.local-dev.user.email "local@hot.dev"
hot.profile.local-dev.org.slug "local"
hot.profile.local-dev.env.name "development"

hot.remote.hot-dev.url ::env/get("HOT_API_URL", "https://api.hot.dev")
hot.remote.hot-dev.key ::env/get("HOT_API_KEY", "")

hot.project.hot-dev.src.paths ["./hot/src"]
//hot.project.hot-dev.test.paths ["./hot/test", "./hot/pkg/hot-std/test", "./hot/pkg/aws-eventstream/test"]
hot.project.hot-dev.test.paths ["./hot/test", "./hot/pkg/hot-std/test", "./hot/src/telegram-agent/test"]
hot.project.hot-dev.test.capture true
hot.project.hot-dev.resources.paths [
    "./hot/src/telegram-agent/resources",
    "./hot/pkg/hot-std/test/fixtures/resources",
]
// The default hot-dev project compiles the Team Brain agent, so it owns
// the agent's Markdown-authored skills too. Keep codegen scoped to the
// agent resources so test-only resource fixtures remain data fixtures.
hot.project.hot-dev.skills.codegen.enabled true
hot.project.hot-dev.skills.codegen.paths ["./hot/src/telegram-agent/resources"]
hot.project.hot-dev.deps {
    // AI types package
    "hot.dev/hot-ai": { "local": "./hot/pkg/hot-ai" },

    // AI packages — enabled because hot/src/telegram-agent/agent.hot
    // depends on ::anthropic::messages and ::openai::chat for live LLM
    // dispatch. Keep these enabled (not commented) so hot-dev compiles
    // the demo agent.
    "hot.dev/anthropic": { "local": "./hot/pkg/anthropic" },
    "hot.dev/openai":    { "local": "./hot/pkg/openai" },
