}

create-channel-invite
meta {
    doc: """POST /channels/{channel_id}/invites - Create a new invite for a channel. `max_age` in seconds (0 = never expires). `max_uses` (0 = unlimited). Requires CREATE_INSTANT_INVITE."""
}
fn (request: CreateChannelInviteRequest): Map {
  body merge({}, {
    max_age: request.max_age,
    max_uses: request.max_uses,
    temporary: request.temporary,
    unique: request.unique,
    target_type: request.target_type,
    target_user_id: request.target_user_id,
    target_application_id: request.target_application_id
  })
  response api-request("POST", `${::discord::core/BASE_URL}/channels/${request.channel_id}/invites`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

