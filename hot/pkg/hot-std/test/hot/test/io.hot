::hot::test::io ns
meta ["test"]

// Note: print and println are core, so no aliasing needed. assert-eq is now core too.

test-print
meta ["test"] fn () {

    // Test basic println functionality
    hello "hello"
    print_result println(hello)
    assert-eq("hello\n", print_result, "println(hello) returns string with newline")
    // Test template string printing
    template_result println(`${hello}`)
    assert-eq("hello\n", template_result, "println template string returns string with newline")
    // Test various data types (should return string representations with newlines)
    string_input "hello\n"
    string_result println(string_input)
    assert-eq("hello\n\n", string_result, "println(string) returns string with added newline")
    number_input 123
    number_result println(number_input)
    assert-eq("123\n", number_result, "println(number) returns number string with newline")
    decimal_input 1.23
    decimal_result println(decimal_input)
    assert-eq("1.23\n", decimal_result, "println(decimal) returns decimal string with newline")
    bool_true_input true
    bool_true_result println(bool_true_input)
    assert-eq("true\n", bool_true_result, "println(true) returns true string with newline")
    // Test complex types (should return string representations with newlines)
    bool_false_result println(false)
    assert-eq("false\n", bool_false_result, "println(false) returns false string with newline")
    array_result println([1, 2, 3])
    assert-eq("[1, 2, 3]\n", array_result, "println(array) returns array string with newline")
    map_result println({a: 1, b: 2, c: 3})
    assert-eq(`{a: 1, b: 2, c: 3}\n`, map_result, "println(map) returns map string with newline")
    null_result println(null)
    assert-eq("\n", null_result, "println(null) returns empty string with newline")
}

