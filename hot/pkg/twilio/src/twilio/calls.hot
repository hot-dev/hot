  sid: Str,
  Url: Str?,
  Method: Str?,
  Status: Str?,
  FallbackUrl: Str?,
  FallbackMethod: Str?,
  StatusCallback: Str?,
  StatusCallbackMethod: Str?,
  Twiml: Str?
}

UpdateCallResponse type {
  sid: Str?,
  account_sid: Str?,
  to: Str?,
  from: Str?,
  status: Str?,
  date_updated: Str?
}

update-call
meta {
    ctx: {"twilio.account.sid": {required: true}},
    doc: """POST /Accounts/{AccountSid}/Calls/{Sid}.json - Update a live call. Set `Status: "completed"` to hang up, or provide a new `Url`/`Twiml` to redirect the call."""
}
fn (request: UpdateCallRequest): UpdateCallResponse {
  body {
    Url: request.Url,
    Method: request.Method,
    Status: request.Status,
    FallbackUrl: request.FallbackUrl,
    FallbackMethod: request.FallbackMethod,
    StatusCallback: request.StatusCallback,
    StatusCallbackMethod: request.StatusCallbackMethod,
    Twiml: request.Twiml
  }

  response api-request("POST", `${account-url()}/Calls/${request.sid}.json`, {}, body)
  if(is-ok-response(response), UpdateCallResponse(response.body), err(HttpError(response)))
}

DeleteCallRequest type {
  sid: Str
}

delete-call
meta {
    ctx: {"twilio.account.sid": {required: true}},
    doc: """DELETE /Accounts/{AccountSid}/Calls/{Sid}.json - Delete a call record. The call log is permanently removed."""
}
fn (request: DeleteCallRequest): Bool {
  response api-request("DELETE", `${account-url()}/Calls/${request.sid}.json`)
  if(is-ok-response(response), true, err(HttpError(response)))
}
