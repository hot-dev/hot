::web-search::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the web-search integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "tavily.api.key": ::env/get("TAVILY_API_KEY", ""),
    "brave.api.key": ::env/get("BRAVE_API_KEY", ""),
    "exa.api.key": ::env/get("EXA_API_KEY", ""),
})
