::ai::agent::ctx ns
meta {
    doc: """
    Per-request context bindings for agent runs.

    Concrete agents typically expose LLM tools as top-level functions in
    their namespace (e.g. `record-task-completion`, `forget-source`,
    `record-decision`). Those tools must know **whose** session and
    identity to write against, but they're registered once at the top of
    the file — they don't take session/identity as parameters, because
    that would let the model spoof them.

    The pattern is:

    1. The event handler calls `bind-request(session, sender)` immediately
       after resolving session/identity from the incoming event.
    2. The tool body calls `current-session()` / `current-sender()` to
       recover them inside the per-run context.

    Hot's `::hot::ctx` is request-scoped (each agent run gets its own ctx
    inheritance), so the bindings are isolated to one event and cannot
    leak between concurrent requests.

    Tools that recover session/identity this way are tamper-resistant:
    the model can send any tool arguments it likes, but it cannot rewrite
    the per-run context. Callers can still pass extra typed fields via
    `extras` (e.g. transport name, channel id) without polluting the
    fixed keys.
    """
}

::ctx     ::hot::ctx
::session ::ai::session

Session  ::session/Session
Identity ::session/Identity

CTX_SESSION_ID "ai.agent.session-id"
CTX_USER_ID    "ai.agent.user-id"
CTX_USER_NAME  "ai.agent.user-name"
CTX_EXTRAS     "ai.agent.extras"

bind-request
meta {
    doc: """
    Bind the active session/identity into the per-run context so tool
    functions (registered statically at namespace top-level) can recover
    them. Returns `null`; the binding lives for the rest of the current
    `::hot::ctx` scope.

    `extras` (optional) is stored under the `ai.agent.extras` key and is
    intended for transport- or agent-specific fields (e.g. channel id,
    transport name, locale). Keep it small — anything routinely consumed
    by tools deserves its own typed ctx key.
    """
}
fn (session: Session, sender: Identity, extras: Map?): Null {
    // Use the 2-arg `set(key, value)` form: Hot map literals treat bare
    // identifiers in key position as punning labels, not as expressions
    // that get evaluated against the constants above.
    ::ctx/set(CTX_SESSION_ID, session.id)
    ::ctx/set(CTX_USER_ID,    sender.id)
    ::ctx/set(CTX_USER_NAME,  or(sender.name, sender.id))
    ::ctx/set(CTX_EXTRAS,     or(extras, {}))
    null
}

current-session-id
meta {
    doc: "Return the session id bound by `bind-request`, or `null` if unbound."
}
fn (): Str? {
    raw ::ctx/get(CTX_SESSION_ID, null)
    cond {
        is-null(raw) => { null }
        => { Str(raw) }
    }
}

current-user-id
meta {
    doc: "Return the user id bound by `bind-request`, or `null` if unbound."
}
fn (): Str? {
    raw ::ctx/get(CTX_USER_ID, null)
    cond {
        is-null(raw) => { null }
        => { Str(raw) }
    }
}

current-user-name
meta {
    doc: "Return the user name bound by `bind-request`, or `null` if unbound."
}
fn (): Str? {
    raw ::ctx/get(CTX_USER_NAME, null)
    cond {
        is-null(raw) => { null }
        => { Str(raw) }
    }
}

current-session
meta {
    doc: """
    Recover the bound session as a `Session` value. Returns `null` if
    `bind-request` has not been called in this request scope.

    Callers that need transport-decorated sessions should wrap the
    returned value with `::ai::agent::transport/session-with-transport`.
    """
}
fn (): Session? {
    sid current-session-id()
    cond {
        is-null(sid) => { null }
        => { Session({id: sid}) }
    }
}

current-sender
meta {
    doc: """
    Recover the bound identity as an `Identity` value. Returns `null` if
    `bind-request` has not been called in this request scope. The
    returned identity has `meta = {}`; if your tools need richer
    identity metadata, pass it through `extras` and recover it with
    `current-extras`.
    """
}
fn (): Identity? {
    uid current-user-id()
    cond {
        is-null(uid) => { null }
        => {
            name or(current-user-name(), uid)
            Identity({id: uid, name: name, meta: {}})
        }
    }
}

current-extras
meta {
    doc: "Return the extras map bound by `bind-request`, or `{}` if none."
}
fn (): Map {
    or(::ctx/get(CTX_EXTRAS, {}), {})
}

clear-request
meta {
    doc: """
    Clear the per-request bindings. Rarely needed — `::hot::ctx` is
    request-scoped — but handy in long-running test loops that reuse a
    single ctx and want to reset between iterations.
    """
}
fn (): Null {
    ::ctx/set(CTX_SESSION_ID, null)
    ::ctx/set(CTX_USER_ID,    null)
    ::ctx/set(CTX_USER_NAME,  null)
    ::ctx/set(CTX_EXTRAS,     {})
    null
}
