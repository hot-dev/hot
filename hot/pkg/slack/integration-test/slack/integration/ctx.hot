::slack::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the slack integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "slack.api.key": ::env/get("SLACK_API_KEY", ""),
    "slack.signing.secret": ::env/get("SLACK_SIGNING_SECRET", ""),
})
