list-all-webhook-endpoints
meta {doc: """GET /v1/webhook_endpoints - List all webhook endpoints"""}
fn (ending-before: Str, expand: Str, limit: Str, starting-after: Str, request: GetWebhookEndpointsRequest): GetWebhookEndpointsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/webhook_endpoints?ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}`, {}, request)
  if(is-ok-response(response), GetWebhookEndpointsResponse(response.body), err(HttpError(response)))
}

