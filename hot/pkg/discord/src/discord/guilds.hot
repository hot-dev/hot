GetGuildAuditLogRequest type {
  guild_id: Str,
  user_id: Str?,
  action_type: Int?,
  before: Str?,
  after: Str?,
  limit: Int?
}

get-guild-audit-log
meta {
    doc: """GET /guilds/{guild_id}/audit-logs - Get the guild audit log. Filter by `user_id` and `action_type`. Requires VIEW_AUDIT_LOG. Returns up to 100 entries."""
}
fn (request: GetGuildAuditLogRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/audit-logs?user_id=${or(request.user_id, "")}&action_type=${or(request.action_type, "")}&before=${or(request.before, "")}&after=${or(request.after, "")}&limit=${or(request.limit, "")}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

