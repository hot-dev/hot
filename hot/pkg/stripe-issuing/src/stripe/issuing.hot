update-transaction
meta {doc: """POST /v1/issuing/transactions/{transaction} - Update a transaction"""}
fn (transaction: Str, request: PostIssuingTransactionsTransactionRequest): PostIssuingTransactionsTransactionResponse {
  response api-request("POST", `${::stripe/BASE_URL}/v1/issuing/transactions/${transaction}`, {}, request)
  if(is-ok-response(response), PostIssuingTransactionsTransactionResponse(response.body), err(HttpError(response)))
