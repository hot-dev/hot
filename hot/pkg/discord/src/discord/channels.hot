::discord::channels ns

api-request ::discord::api/request
HttpError ::discord::api/HttpError
is-ok-response ::hot::http/is-ok-response

// ============================================================================
// Channels
// ============================================================================

GetChannelRequest type {
  channel_id: Str
}

get-channel
meta {
    doc: """
GET /channels/{channel_id} - Get a channel by ID. Returns the full channel object including name, type, topic, and permission overwrites.

**Example**

```hot
::channels ::discord::channels

response ::channels/get-channel(::channels/GetChannelRequest({
  channel_id: "123456789"
}))
response.name  // => "general"
response.type  // => 0 (guild text channel)
```
"""
}
fn (request: GetChannelRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/channels/${request.channel_id}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

ModifyChannelRequest type {
  channel_id: Str,
  name: Str?,
  type: Int?,
  position: Int?,
  topic: Str?,
  nsfw: Bool?,
  rate_limit_per_user: Int?,
  bitrate: Int?,
  user_limit: Int?,
  permission_overwrites: Vec<Map>?,
  parent_id: Str?,
  default_auto_archive_duration: Int?
}

modify-channel
meta {
    doc: """PATCH /channels/{channel_id} - Update a channel's settings. Requires MANAGE_CHANNELS permission. Only specified fields are updated."""
}
fn (request: ModifyChannelRequest): Map {
  body merge({}, {
    name: request.name,
    type: request.type,
    position: request.position,
    topic: request.topic,
    nsfw: request.nsfw,
    rate_limit_per_user: request.rate_limit_per_user,
    bitrate: request.bitrate,
    user_limit: request.user_limit,
    permission_overwrites: request.permission_overwrites,
    parent_id: request.parent_id,
    default_auto_archive_duration: request.default_auto_archive_duration
  })
  response api-request("PATCH", `${::discord::core/BASE_URL}/channels/${request.channel_id}`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

DeleteChannelRequest type {
  channel_id: Str
}

delete-channel
meta {
    doc: """DELETE /channels/{channel_id} - Delete a channel or close a DM. Requires MANAGE_CHANNELS for guild channels. Deleting a category does not delete its child channels."""
}
fn (request: DeleteChannelRequest): Map {
  response api-request("DELETE", `${::discord::core/BASE_URL}/channels/${request.channel_id}`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

EditChannelPermissionsRequest type {
  channel_id: Str,
  overwrite_id: Str,
  allow: Str?,
  deny: Str?,
  type: Int
}

edit-channel-permissions
meta {
    doc: """PUT /channels/{channel_id}/permissions/{overwrite_id} - Edit channel permission overwrites for a user or role. `type` 0 = role, 1 = member. `allow` and `deny` are permission bit strings."""
}
fn (request: EditChannelPermissionsRequest): Bool {
  body {
    allow: request.allow,
    deny: request.deny,
    type: request.type
  }

  response api-request("PUT", `${::discord::core/BASE_URL}/channels/${request.channel_id}/permissions/${request.overwrite_id}`, {}, body)
  if(is-ok-response(response), true, err(HttpError(response)))
}

DeleteChannelPermissionRequest type {
  channel_id: Str,
  overwrite_id: Str
}

delete-channel-permission
meta {
    doc: """DELETE /channels/{channel_id}/permissions/{overwrite_id} - Delete a channel permission overwrite for a user or role. Requires MANAGE_ROLES."""
}
fn (request: DeleteChannelPermissionRequest): Bool {
  response api-request("DELETE", `${::discord::core/BASE_URL}/channels/${request.channel_id}/permissions/${request.overwrite_id}`)
