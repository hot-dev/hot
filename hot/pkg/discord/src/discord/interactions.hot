::discord::interactions ns

api-request ::discord::api/request
HttpError ::discord::api/HttpError
is-ok-response ::hot::http/is-ok-response

// ============================================================================
// Interaction Responses
// ============================================================================
// When Discord sends an interaction (slash command, button, etc.), your
// endpoint must respond within 3 seconds. These functions send that response.
//
// Response types:
//   1 = PONG (for ping)
//   4 = CHANNEL_MESSAGE_WITH_SOURCE (send a message)
//   5 = DEFERRED_CHANNEL_MESSAGE_WITH_SOURCE (ack, edit later)
//   6 = DEFERRED_UPDATE_MESSAGE (for components, ack, edit later)
//   7 = UPDATE_MESSAGE (for components, edit the original)
//   8 = APPLICATION_COMMAND_AUTOCOMPLETE_RESULT
//   9 = MODAL

CreateInteractionResponseRequest type {
  interaction_id: Str,
  interaction_token: Str,
  type: Int,
  data: Map?
}

create-interaction-response
meta {
    doc: """
POST /interactions/{interaction_id}/{interaction_token}/callback - Respond to an interaction. Must be called within 3 seconds. `type` determines the response behavior (4=message, 5=deferred, 7=update).

**Example**

```hot
::interactions ::discord::interactions

// Reply to a slash command
::interactions/create-interaction-response(::interactions/CreateInteractionResponseRequest({
  interaction_id: event.id,
  interaction_token: event.token,
  type: 4,
  data: {content: "Hello from Hot!"}
}))

// Defer a response (show "thinking..." indicator, edit later)
::interactions/create-interaction-response(::interactions/CreateInteractionResponseRequest({
  interaction_id: event.id,
  interaction_token: event.token,
  type: 5
}))
```
"""
}
fn (request: CreateInteractionResponseRequest): Bool {
  body {
    type: request.type,
    data: request.data
  }

  response ::hot::http/request(::hot::http/HttpRequest({
    method: "POST",
    url: `${::discord::core/BASE_URL}/interactions/${request.interaction_id}/${request.interaction_token}/callback`,
    headers: {Content-Type: "application/json"},
    body: to-json(untype(body))
  }))
  if(is-ok-response(response), true, err(HttpError(response)))
}

// ============================================================================
// Followup Messages (via webhook-style endpoints with application_id)
// ============================================================================

GetOriginalInteractionResponseRequest type {
  application_id: Str,
  interaction_token: Str
}

get-original-interaction-response
meta {
    doc: """GET /webhooks/{application_id}/{interaction_token}/messages/@original - Get the original interaction response message."""
}
fn (request: GetOriginalInteractionResponseRequest): Map {
  response api-request("GET", `${::discord::core/BASE_URL}/webhooks/${request.application_id}/${request.interaction_token}/messages/@original`)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

EditOriginalInteractionResponseRequest type {
  application_id: Str,
  interaction_token: Str,
  content: Str?,
  embeds: Vec<Map>?,
  allowed_mentions: Map?,
  components: Vec<Map>?
}

edit-original-interaction-response
meta {
    doc: """
PATCH /webhooks/{application_id}/{interaction_token}/messages/@original - Edit the original interaction response. Use this after sending a deferred response (type 5) to provide the actual content.

**Example**

```hot
::interactions ::discord::interactions

// After deferring, edit with the actual response
::interactions/edit-original-interaction-response(::interactions/EditOriginalInteractionResponseRequest({
  application_id: "123456789",
  interaction_token: event.token,
  content: "Here's your result after processing!"
}))
```
"""
}
fn (request: EditOriginalInteractionResponseRequest): Map {
  body merge({}, {
    content: request.content,
    embeds: request.embeds,
    allowed_mentions: request.allowed_mentions,
    components: request.components
  })
  response api-request("PATCH", `${::discord::core/BASE_URL}/webhooks/${request.application_id}/${request.interaction_token}/messages/@original`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

