::telegram::integration::messages ns
meta ["test"]

TELEGRAM_TEST_CHAT_ID ::hot::env/get("TELEGRAM_TEST_CHAT_ID", "")

test-send-edit-delete-message
meta ["test"]
fn () {
  assert(TELEGRAM_TEST_CHAT_ID, "Set TELEGRAM_TEST_CHAT_ID in .env for Telegram integration tests")

  chat-id Int(TELEGRAM_TEST_CHAT_ID)

  send-response ::telegram::messages/send-message(::telegram::messages/SendMessageRequest({
    chat_id: chat-id,
    text: "Hot integration test message"
  }))

  assert(send-response.message_id, `sendMessage should return message_id. response=${to-json(send-response)}`)
  assert-eq("Hot integration test message", send-response.text, "text should match")

  edit-response ::telegram::messages/edit-message-text(::telegram::messages/EditMessageTextRequest({
    chat_id: chat-id,
    message_id: send-response.message_id,
    text: "Hot integration test message (updated)"
  }))

  assert-eq(send-response.message_id, edit-response.message_id, "message_id should match")

  deleted ::telegram::messages/delete-message(::telegram::messages/DeleteMessageRequest({
    chat_id: chat-id,
    message_id: send-response.message_id
  }))

  assert(deleted, "deleteMessage should return true")
}

test-send-message-with-parse-mode
meta ["test"]
fn () {
  assert(TELEGRAM_TEST_CHAT_ID, "Set TELEGRAM_TEST_CHAT_ID in .env for Telegram integration tests")

  chat-id Int(TELEGRAM_TEST_CHAT_ID)

  response ::telegram::messages/send-message(::telegram::messages/SendMessageRequest({
    chat_id: chat-id,
    text: "*bold* _italic_ `code`",
    parse_mode: "Markdown"
  }))

  assert(response.message_id, "sendMessage with Markdown should return message_id")

  ::telegram::messages/delete-message(::telegram::messages/DeleteMessageRequest({
    chat_id: chat-id,
    message_id: response.message_id
  }))
}

