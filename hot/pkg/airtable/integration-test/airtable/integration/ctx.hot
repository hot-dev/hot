::airtable::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the airtable integration suite. Unset
// environment variables are skipped entirely, so absent credentials
// behave exactly as if never configured.
::hot::ctx/set(filter-vals({
    "airtable.token": ::env/get("AIRTABLE_TOKEN", ""),
}, (v) { not(is-empty(v)) }))
