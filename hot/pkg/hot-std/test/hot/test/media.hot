// ============================================================================
// MediaBatch Tests
// ============================================================================

test-media-batch-success
meta ["test"]
fn () {
    file1 mock-file-meta("batch/image-0.png", 1000)
    file2 mock-file-meta("batch/image-1.png", 2000)
    file3 mock-file-meta("batch/image-2.png", 3000)

    items [
        Media.Image({file: file1, prompt: "Test 1", revised_prompt: null, model: "aurora", provider: "xai", width: 512, height: 512, format: "png", style: null, quality: null}),
        Media.Image({file: file2, prompt: "Test 2", revised_prompt: null, model: "aurora", provider: "xai", width: 512, height: 512, format: "png", style: null, quality: null}),
        Media.Image({file: file3, prompt: "Test 3", revised_prompt: null, model: "aurora", provider: "xai", width: 512, height: 512, format: "png", style: null, quality: null})
    ]

    batch MediaBatch({
        items: items,
        succeeded: 3,
        failed: 0,
        errors: null
    })

    assert-eq(3, batch.succeeded, "Should have 3 successes")
    assert-eq(0, batch.failed, "Should have 0 failures")
    assert-eq(3, length(batch.items), "Should have 3 items")
    assert(is-null(batch.errors), "Should have no errors")
}

test-media-batch-partial-failure
meta ["test"]
fn () {
    file1 mock-file-meta("batch/image-0.png", 1000)

    items [
        Media.Image({file: file1, prompt: "Test 1", revised_prompt: null, model: "aurora", provider: "xai", width: 512, height: 512, format: "png", style: null, quality: null})
    ]

    errors [
        MediaError({index: 1, message: "Rate limit exceeded"}),
        MediaError({index: 2, message: "Content policy violation"})
    ]

    batch MediaBatch({
        items: items,
        succeeded: 1,
        failed: 2,
        errors: errors
    })

    assert-eq(1, batch.succeeded, "Should have 1 success")
    assert-eq(2, batch.failed, "Should have 2 failures")
    assert-eq(1, length(batch.items), "Should have 1 item")
    assert-eq(2, length(batch.errors), "Should have 2 errors")
    assert-eq(1, batch.errors[0].index, "First error should be at index 1")
    assert-eq("Rate limit exceeded", batch.errors[0].message, "First error message should match")
}

// ============================================================================
// Variant Constructor Tests (the `image`/`audio`/`video` helper
// functions were removed in favor of using the synthesized variant
// constructors directly — `Media.Image(data)` etc.)
// ============================================================================

test-image-variant-constructor
meta ["test"]
fn () {
    file-meta mock-file-meta("test.png", 100)
    data Image({file: file-meta, prompt: "Test", revised_prompt: null, model: "test", provider: "test", width: 100, height: 100, format: "png", style: null, quality: null})

    media Media.Image(data)

    assert(::hot::media/is-image(media), "Media.Image(data) should construct an Image variant")
}

test-audio-variant-constructor
meta ["test"]
fn () {
    file-meta mock-file-meta("test.mp3", 100)
    data Audio({file: file-meta, prompt: "Test", transcript: null, model: "test", provider: "test", duration_seconds: 1.0, format: "mp3", voice: null, language: null})

    media Media.Audio(data)

    assert(::hot::media/is-audio(media), "Media.Audio(data) should construct an Audio variant")
}

test-video-variant-constructor
meta ["test"]
fn () {
    file-meta mock-file-meta("test.mp4", 100)
    data Video({file: file-meta, prompt: "Test", revised_prompt: null, model: "test", provider: "test", duration_seconds: 1.0, width: 100, height: 100, format: "mp4", fps: 30})

    media Media.Video(data)

    assert(::hot::media/is-video(media), "Media.Video(data) should construct a Video variant")
}

// ============================================================================
// Pattern Matching Tests
// ============================================================================

test-match-on-media-variants
meta ["test"]
fn () {
    file-meta mock-file-meta("test.png", 100)

    // Test with pre-typed data (wrapping in Image type first)
    // The variant constructor should extract the inner $val automatically
    image-media-typed Media.Image(Image({file: file-meta, prompt: "Typed", revised_prompt: null, model: "m", provider: "p", width: 100, height: 100, format: "png", style: null, quality: null}))

    // Test with struct literal directly (the simpler/preferred form)
    image-media-literal Media.Image({file: file-meta, prompt: "Literal", revised_prompt: null, model: "m", provider: "p", width: 100, height: 100, format: "png", style: null, quality: null})

    // Both forms should have the same $type
    assert-eq(image-media-typed.$type, "::hot::media/Media.Image", "Typed form should have correct $type")
    assert-eq(image-media-literal.$type, "::hot::media/Media.Image", "Literal form should have correct $type")

    // Both should match correctly
    result-typed match image-media-typed {
        Media.Image => { "image" }
        Media.Audio => { "audio" }
        Media.Video => { "video" }
    }

    result-literal match image-media-literal {
        Media.Image => { "image" }
        Media.Audio => { "audio" }
        Media.Video => { "video" }
    }

    assert-eq("image", result-typed, "Match should work with typed construction")
    assert-eq("image", result-literal, "Match should work with literal construction")

    // Both forms should have equivalent field access
    assert-eq("Typed", image-media-typed.$val.prompt, "Typed form field access should work")
    assert-eq("Literal", image-media-literal.$val.prompt, "Literal form field access should work")

    // Test default branch in match
    audio-media Media.Audio({file: file-meta, prompt: "Audio", revised_prompt: null, model: "m", provider: "p", duration_seconds: 60, sample_rate: 44100, channels: 2, format: "mp3", voice: null, speed: null})

    result-with-default match audio-media {
        Media.Image => { "image" }
        => { "default" }
    }

    assert-eq("default", result-with-default, "Match default branch should work when no variant matches")
}
