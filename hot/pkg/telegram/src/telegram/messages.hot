SendPhotoRequest type {
  chat_id: Any,
  photo: Str,
  caption: Str?,
  parse_mode: Str?,
  has_spoiler: Bool?,
  disable_notification: Bool?,
  protect_content: Bool?,
  reply_parameters: Map?,
  reply_markup: Map?,
  message_thread_id: Int?
}

send-photo
meta {
    doc: """
sendPhoto - Send a photo. `photo` can be a file_id (to resend), an HTTP URL, or a file path for upload.

**Example**

```hot
::messages ::telegram::messages

response ::messages/send-photo(::messages/SendPhotoRequest({
  chat_id: 123456789,
  photo: "https://example.com/image.jpg",
  caption: "Check out this image!"
}))
```
"""
}
fn (request: SendPhotoRequest): Map {
  api-request("sendPhoto", untype(request))
}

