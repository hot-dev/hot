// ============================================================================
// Interaction Webhook Signature Verification (Ed25519)
// ============================================================================
// Discord signs interaction callbacks with Ed25519. The public key is provided
// in your application settings. The signature is in the X-Signature-Ed25519
// header and the timestamp in X-Signature-Timestamp.
//
// See: https://discord.com/developers/docs/interactions/receiving-and-responding#security-and-authorization

verify-request
meta {
    ctx: {"discord.public.key": {required: false}},
    doc: """
  Verify a Discord interaction webhook using Ed25519 signature. Returns true if the request is authentic. Uses the `discord.public.key` context variable by default, or accepts an explicit public key as a second argument.

  Discord requires interaction endpoints to verify every request. Failing verification should return a 401 response.

  **Example**

  ```hot
  // Using context variable (1-arity, most common)
  is-valid ::discord::webhooks/verify-request(request)

  // With explicit public key (2-arity)
  is-valid ::discord::webhooks/verify-request(request, "your-ed25519-public-key")
  ```
  """
}
fn
(request: Map): Bool {
  public-key or(::hot::ctx/get("discord.public.key"), "")
  if(is-empty(public-key),
    fail("discord.public.key is not set. Add it in Context Variables to verify interaction requests.")
  )
  verify-request(request, public-key)
},
(request: Map, public-key: Str): Bool {
  signature get(request.headers, "x-signature-ed25519", "")
  timestamp get(request.headers, "x-signature-timestamp", "")

  cond {
    is-empty(public-key) => { false }
    is-empty(signature) => { false }
    is-empty(timestamp) => { false }
    => {
      message `${timestamp}${request.body-raw}`
      ::hot::hash/ed25519-verify(public-key, message, signature)
    }
  }
}
