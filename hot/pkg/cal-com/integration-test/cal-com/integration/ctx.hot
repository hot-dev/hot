::cal-com::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the cal-com integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "cal-com.api.key": ::env/get("CAL_COM_API_KEY", ""),
    "cal-com.url": ::env/get("CAL_COM_URL", ""),
})
