    content: request.content,
    tts: request.tts,
    embeds: request.embeds,
    allowed_mentions: request.allowed_mentions,
    components: request.components,
    flags: request.flags
  })
  response api-request("POST", `${::discord::core/BASE_URL}/webhooks/${request.application_id}/${request.interaction_token}`, {}, body)
  if(is-ok-response(response), response.body, err(HttpError(response)))
}

