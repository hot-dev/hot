GetClimateSuppliersSupplierRequest type {

}

GetClimateSuppliersSupplierResponse type {
    id: Str,
    info_url: Str,
    livemode: Bool,
    locations: Vec<ClimateRemovalsLocation>,
    name: Str,
    object: "climate.supplier",
    removal_pathway: "biomass_carbon_removal_and_storage" | "direct_air_capture" | "enhanced_weathering"
}


retrieve-supplier
meta {doc: """GET /v1/climate/suppliers/{supplier} - Retrieve a supplier"""}
fn (supplier: Str, expand: Str, request: GetClimateSuppliersSupplierRequest): GetClimateSuppliersSupplierResponse {
