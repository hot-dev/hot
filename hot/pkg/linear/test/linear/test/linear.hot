::linear::test ns
meta ["test"]

::api ::linear::api
::issues ::linear::issues

// ============================================================================
// Auth header forms
// ============================================================================

test-auth-header-personal-key-is-raw
meta ["test"] fn () {
    assert-eq("lin_api_abc123", ::api/auth-header("lin_api_abc123"))
}

test-auth-header-oauth-gets-bearer
meta ["test"] fn () {
    assert-eq("Bearer lin_oauth_xyz", ::api/auth-header("lin_oauth_xyz"))
}

// ============================================================================
// GraphQL response unwrapping
// ============================================================================

test-parse-response-returns-data
meta ["test"] fn () {
    out ::api/parse-graphql-response({data: {viewer: {name: "Ada"}}})
    assert-eq("Ada", out.viewer.name)
}

test-parse-response-errors-become-err
meta ["test"] fn () {
    out ::api/parse-graphql-response({errors: [{message: "Field 'nope' not found"}], data: null})
    assert(is-err(out), "GraphQL errors should be an Err")
    payload if-err(out, (e) { e })
    assert(contains(first(payload.errors).message, "not found"))
}

test-parse-response-partial-data-with-errors-is-err
meta ["test"] fn () {
    out ::api/parse-graphql-response({errors: [{message: "partial"}], data: {issues: []}})
    assert(is-err(out), "partial data with errors still errs (data preserved in payload)")
}

// ============================================================================
// Webhook verification (vectors generated independently with Python)
// ============================================================================

test-webhook-verify-accepts-vector
meta ["test"] fn () {
    request {
        headers: {linear-signature: "f94173456225cddb0497ce1f384bd4b3498257e64ab2c50019730e6b7c678325"},
        body-raw: """{"action":"create","type":"Issue"}"""
    }

    assert(::linear::webhooks/verify-request(request, "lin_wh_test_secret"))
}

test-webhook-verify-rejects
meta ["test"] fn () {
    // Signature for a Comment payload must not verify an Issue payload.
    tampered {
        headers: {linear-signature: "244a4f05be84071b099c284b3cfcb08eb0f9e947cf763f52fb2bca0818f0c402"},
        body-raw: """{"action":"create","type":"Issue"}"""
    }

    assert(not(::linear::webhooks/verify-request(tampered, "lin_wh_test_secret")), "wrong-body signature fails")
    assert(not(::linear::webhooks/verify-request({headers: {}, body-raw: "{}"}, "lin_wh_test_secret")), "missing header fails")
}

test-webhook-empty-secret-fails-closed
meta ["test"] fn () {
    body """{"action":"create"}"""
    sig ::hot::hmac/hmac-sha256("", body)
    request {headers: {linear-signature: sig}, body-raw: body}
    assert(not(::linear::webhooks/verify-request(request, "")), "empty secret fails closed")
}

// ============================================================================
// Issue create input
// ============================================================================

test-build-create-input
meta ["test"] fn () {
    input ::issues/build-create-input("team-1", "Fix it", {priority: 2, labelIds: ["l1"]})
    assert-eq("team-1", input.teamId)
    assert-eq("Fix it", input.title)
    assert-eq(2, input.priority)
    assert-eq(["l1"], input.labelIds)
    assert(not(in("description", keys(input))), "unset options are omitted, not null")
}
