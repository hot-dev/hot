list-verificationsessions
meta {doc: """GET /v1/identity/verification_sessions - List VerificationSessions"""}
fn (client-reference-id: Str, created: Str, ending-before: Str, expand: Str, limit: Str, related-customer: Str, related-customer-account: Str, starting-after: Str, status: Str, request: GetIdentityVerificationSessionsRequest): GetIdentityVerificationSessionsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/identity/verification_sessions?client_reference_id=${client-reference-id}&created=${created}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&related_customer=${related-customer}&related_customer_account=${related-customer-account}&starting_after=${starting-after}&status=${status}`, {}, request)
  if(is-ok-response(response), GetIdentityVerificationSessionsResponse(response.body), err(HttpError(response)))
}

