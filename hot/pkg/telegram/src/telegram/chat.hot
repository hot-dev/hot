CreateChatInviteLinkRequest type {
  chat_id: Any,
  name: Str?,
  expire_date: Int?,
  member_limit: Int?,
  creates_join_request: Bool?
}

create-chat-invite-link
meta {
    doc: """createChatInviteLink - Create an additional invite link. `member_limit` (1-99999) limits joins. `expire_date` is a Unix timestamp. Set `creates_join_request: true` to require admin approval."""
}
fn (request: CreateChatInviteLinkRequest): Map {
  api-request("createChatInviteLink", untype(request))
}

