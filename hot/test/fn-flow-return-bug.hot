::test::fn-flow-return-bug ns

// Test for fn cond/parallel/match return value bug
// The bug: when a fn cond branch calls a function that returns a complex value,
// that value can incorrectly become the fn cond's return value instead of the
// actual branch result.

// ============================================================================
// LARGE DATA TEST - Simulating base64 encoded image data
// A real PNG image is typically 10KB-1MB when base64 encoded
// ============================================================================

// Generate a large base64-like string (simulating ~50KB of image data)
// This is a valid base64 data URL prefix followed by repeated data
LARGE_BASE64_DATA "data:image/png;base64,"

// Helper that returns a complex value (array)
build-complex-value fn (input: Str): Vec {
    // This returns an array - similar to build-anthropic-content
    [{"type": "text", "value": input}, {"type": "extra", "data": 123}]
}

// Helper that returns a complex value with LARGE data (like base64 image)
build-large-complex-value fn (input: Str): Vec {
    // This returns an array with large base64 data - exactly like build-anthropic-content with images
    text-block {"type": "text", "text": input}
    image-block {
        "type": "image",
        "source": {
            "type": "base64",
            "media_type": "image/png",
            "data": LARGE_BASE64_DATA
        }
    }
    [text-block, image-block]
}

// Helper that uses the complex value internally but returns something else
// This matches the pattern in call-anthropic which has an internal cond
process-with-complex fn (input: Str): Str {
    // Call function that returns complex value (stored in local var)
    complex-data build-complex-value(input)

    // Simulate API call returning a status
    status 200

    // Internal cond (like call-anthropic's error handling cond)
    cond {
        gte(status, 400) => { err("error") }
        => {
            // Do some processing and return a simple string
            result `processed: ${input}`
            if(gt(length(result), 0), result, "fallback")
        }
    }
}

// ============================================================================
// fn cond tests
// ============================================================================

// fn cond that calls a function which internally uses complex values
route-cond fn cond (choice: Str, input: Str): Str {
    eq(choice, "a") => { process-with-complex(input) }
    eq(choice, "b") => { "choice-b" }
    => { "default" }
}

test-fn-cond-returns-correct-value
meta ["test"]
fn () {
    result route-cond("a", "hello")
    expected "processed: hello"

    assert(eq(result, expected), `fn cond should return '${expected}' but got '${result}'`)
}

test-fn-cond-other-branches
meta ["test"]
fn () {
    result-b route-cond("b", "hello")
    assert(eq(result-b, "choice-b"), `fn cond branch b should return 'choice-b' but got '${result-b}'`)

    result-default route-cond("x", "hello")
    assert(eq(result-default, "default"), `fn cond default should return 'default' but got '${result-default}'`)
}

// ============================================================================
// fn match tests
// ============================================================================

ChoiceEnum enum { A, B, Other }

route-match fn match (choice: ChoiceEnum, input: Str): Str {
    ChoiceEnum.A => { process-with-complex(input) }
    ChoiceEnum.B => { "choice-b" }
    ChoiceEnum.Other => { "other" }
}

test-fn-match-returns-correct-value
meta ["test"]
fn () {
    result route-match(ChoiceEnum.A, "world")
    expected "processed: world"

    assert(eq(result, expected), `fn match should return '${expected}' but got '${result}'`)
}

// ============================================================================
// fn parallel tests
// ============================================================================

// fn parallel that includes a call to function with complex return
compute-parallel fn parallel (input: Str) {
    processed process-with-complex(input)
    doubled `${input}${input}`
}

test-fn-parallel-returns-correct-value
meta ["test"]
fn () {
    result compute-parallel("test")

    // Parallel returns a map with named results
    assert(eq(result.processed, "processed: test"), `fn parallel 'processed' should be 'processed: test' but got '${result.processed}'`)
    assert(eq(result.doubled, "testtest"), `fn parallel 'doubled' should be 'testtest' but got '${result.doubled}'`)
}

// ============================================================================
// fn cond-all tests
// ============================================================================

compute-cond-all fn cond-all (flags: Map) {
    flags.a => a { process-with-complex("a-branch") }
    flags.b => b { "b-result" }
    flags.c => c { "c-result" }
}

test-fn-cond-all-returns-correct-value
meta ["test"]
fn () {
    result compute-cond-all({"a": true, "b": true, "c": false})

    // cond-all returns a map with all matching branch results
    assert(eq(result.a, "processed: a-branch"), `fn cond-all 'a' should be 'processed: a-branch' but got '${result.a}'`)
    assert(eq(result.b, "b-result"), `fn cond-all 'b' should be 'b-result' but got '${result.b}'`)
}

// ============================================================================
// Nested fn cond calling fn cond (deeper nesting)
// ============================================================================

inner-cond fn cond (x: Int): Str {
    gt(x, 10) => {
        data build-complex-value("inner")
        "greater"
    }
    => { "not-greater" }
}

outer-cond fn cond (choice: Str, x: Int): Str {
    eq(choice, "nested") => { inner-cond(x) }
    => { "other" }
}

test-nested-fn-cond
meta ["test"]
fn () {
    result outer-cond("nested", 20)
    assert(eq(result, "greater"), `nested fn cond should return 'greater' but got '${result}'`)
}

// ============================================================================
// More complex case: multiple nested calls with complex values
// Mimics the exact pattern from call-anthropic/build-anthropic-messages
// ============================================================================

// Mimics build-anthropic-content - returns array when files present
build-content fn (text: Str, has-files: Bool): Any {
    cond {
        not(has-files) => { text }
        => {
            text-block {"type": "text", "text": text}
            image-block {"type": "image", "data": "base64data"}
            concat([text-block], [image-block])
        }
    }
}

// Mimics build-anthropic-content with LARGE base64 data
build-large-content fn (text: Str, has-files: Bool): Any {
    cond {
        not(has-files) => { text }
        => {
            text-block {"type": "text", "text": text}
            image-block {
                "type": "image",
                "source": {
                    "type": "base64",
                    "media_type": "image/png",
                    "data": LARGE_BASE64_DATA
                }
            }

            concat([text-block], [image-block])
        }
    }
}

// Mimics build-anthropic-messages - uses build-content result
build-messages fn (history: Vec, text: Str, has-files: Bool): Vec {
    user-content build-content(text, has-files)
    history
        |> concat([{"role": "user", "content": user-content}])
}

// Mimics call-anthropic - calls build-messages first, then has internal cond
process-api fn (history: Vec, text: Str, has-files: Bool): Str {
    // First: call function that internally returns complex value
    messages build-messages(history, text, has-files)

    // Second: simulate API response
    status 200

    // Third: cond for error handling (like call-anthropic)
    cond {
        gte(status, 400) => { err("API error") }
        => {
            response "API response text"
            if(gt(length(response), 0), response, "fallback")
        }
    }
}

// Mimics call-ai-service - fn cond that routes to process-api
route-api fn cond (service: Str, history: Vec, text: Str, has-files: Bool): Str {
    eq(service, "api") => { process-api(history, text, has-files) }
    => { "unknown service" }
}

test-complex-nesting
meta ["test"]
fn () {
    // Test WITHOUT files (like first message "hello")
    result-no-files route-api("api", [], "hello", false)
    assert(eq(result-no-files, "API response text"), `without files should return 'API response text' but got '${result-no-files}'`)

    // Test WITH files (like second message with image)
    result-with-files route-api("api", [{"role": "user", "content": "hello"}], "what do you think", true)
    assert(eq(result-with-files, "API response text"), `with files should return 'API response text' but got '${result-with-files}'`)
}

// Even more specific test: call the exact chain
test-exact-api-pattern
meta ["test"]
fn () {
    history [{"role": "user", "content": "hello"}, {"role": "assistant", "content": "Hi!"}]
    result route-api("api", history, "what do you think of this?", true)

    assert(eq(result, "API response text"), `exact pattern should return 'API response text' but got '${result}'`)
}

// ============================================================================
// LARGE DATA TESTS - Using actual large base64 data like real images
// ============================================================================

// Type constructor like InputMessage in the chatbot
Message type {
    role: Str,
    content: Any
}

// Mimics build-anthropic-messages with LARGE data AND type constructor
build-large-messages fn (history: Vec, text: Str, has-files: Bool): Vec<Message> {
    user-content build-large-content(text, has-files)
    // This exactly mimics: history |> map(InputMessage) |> concat([InputMessage({...})])
    history
        |> map(Message)
        |> concat([Message({"role": "user", "content": user-content})])
}

// Simulates process-anthropic-stream - RECURSIVE with nested conds
process-stream fn (items: Vec, accumulated: Str, idx: Int): Str {
    cond {
        gte(idx, length(items)) => { accumulated }
        => {
            value get(items, idx)
            cond {
                is-null(value) => { process-stream(items, accumulated, add(idx, 1)) }
                is-vec(value) => {
                    batch-text reduce(value, (acc, item) { concat(acc, item) }, "")
                    process-stream(items, concat(accumulated, batch-text), add(idx, 1))
                }
                => {
                    process-stream(items, concat(accumulated, value), add(idx, 1))
                }
            }
        }
    }
}

// Mimics call-anthropic with LARGE data - calls build-messages first, then has internal cond with recursion
process-large-api fn (history: Vec, text: Str, has-files: Bool): Str {
    // First: call function that internally returns LARGE complex value
    messages build-large-messages(history, text, has-files)

    // Second: simulate API response with streaming data
    stream-items ["Hello", " world", "!", " How", " are", " you", "?"]
    status 200

    // Third: cond for error handling (like call-anthropic) with recursive stream processing
    cond {
        gte(status, 400) => { err("API error") }
        => {
            full-text process-stream(stream-items, "", 0)
            if(gt(length(full-text), 0), full-text, "fallback")
        }
    }
}

// Mimics call-ai-service with LARGE data - fn cond that routes to process-api
route-large-api fn cond (service: Str, history: Vec, text: Str, has-files: Bool): Str {
    eq(service, "api") => { process-large-api(history, text, has-files) }
    => { "unknown service" }
}

test-large-data-without-files
meta ["test"]
fn () {
    result route-large-api("api", [], "hello", false)
    expected "Hello world! How are you?"
    assert(eq(result, expected), `large data without files should return '${expected}' but got '${result}'`)
}

test-large-data-with-files
meta ["test"]
fn () {
    // This is the exact scenario that triggers the bug in the chatbot
    history [{"role": "user", "content": "hello"}, {"role": "assistant", "content": "Hi!"}]
    result route-large-api("api", history, "what do you think of this?", true)

    expected "Hello world! How are you?"
    assert(eq(result, expected), `large data WITH files should return '${expected}' but got '${result}'`)
}

// Test with multiple history entries (like real chat)
test-large-data-longer-history
meta ["test"]
fn () {
    history [
        {"role": "user", "content": "hello"},
        {"role": "assistant", "content": "Hi there!"},
        {"role": "user", "content": "How are you?"},
        {"role": "assistant", "content": "I'm doing well, thanks!"}
    ]
    result route-large-api("api", history, "check out this image", true)

    expected "Hello world! How are you?"
    assert(eq(result, expected), `large data with longer history should return '${expected}' but got '${result}'`)
}
