::hot::test::result ns
meta ["test"]

is-ok ::hot::type/is-ok
is-err ::hot::type/is-err
ok ::hot::type/ok
err ::hot::type/err
assert-eq ::hot::test/assert-eq
assert ::hot::test/assert
not ::hot::bool/not
eq ::hot::cmp/eq
div ::hot::math/div
if ::hot::bool/if
contains ::hot::str/contains

// Helper function that can legitimately return either success or error
safe-divide fn (a, b) {
    if(eq(b, 0), err("Division by zero"), ok(div(a, b)))
}

// Helper function that always succeeds
always-succeeds fn (x) {
    ok(x)
}

// Helper function that always fails
always-fails fn (x) {
    err(`Failed with: ${x}`)
}

test-result
meta ["test"] fn () {
    // Test with functions that can legitimately return success or error
    assert(is-ok(safe-divide(10, 2)), "is-ok should return true for successful division")
    assert(is-err(safe-divide(10, 0)), "is-err should return true for division by zero")

    // Test with functions that always succeed or fail
    assert(is-ok(always-succeeds(42)), "is-ok should return true for always-succeeds")
    assert(is-err(always-fails("test")), "is-err should return true for always-fails")

    // Test with direct ok/err constructors
    assert(is-ok(ok(1)), "is-ok should return true for ok")
    assert(is-err(err(1)), "is-err should return true for err")

    // Test negations
    assert(not(is-ok(err(1))), "is-ok should return false for err")
    assert(not(is-err(ok(1))), "is-err should return false for ok")
    assert(not(is-ok(always-fails("test"))), "is-ok should return false for always-fails")
    assert(not(is-err(always-succeeds(42))), "is-err should return false for always-succeeds")
}


test-if-ok
meta ["test"] fn () {
    // if-ok with function: transforms Ok value
    result if-ok(ok(1), (n) { add(n, 10) })
    assert(is-ok(result), "if-ok with fn produces Ok")

    // if-ok with Err: passes through unchanged
    err-result if-ok(err("bad"), (n) { add(n, 10) })
    assert(is-err(err-result), "if-ok on Err passes through")

    // if-ok with value: replaces Ok value
    replaced if-ok(ok(1), "replaced")
    assert(is-ok(replaced), "if-ok with value produces Ok")

    // if-ok on plain (non-Result) value
    plain if-ok(42, (n) { add(n, 1) })
    assert(is-ok(plain), "if-ok on plain value treats as Ok")

    // Chain: ok value through pipeline
    chained ok(5)
        |> if-ok((n) { mul(n, 2) })
        |> if-ok((n) { add(n, 1) })
    assert(is-ok(chained), "chained if-ok stays Ok")

    // Chain: err passes through all if-ok
    err-chain err("fail")
        |> if-ok((n) { mul(n, 2) })
        |> if-ok((n) { add(n, 1) })
    assert(is-err(err-chain), "err passes through chained if-ok")
}


test-if-err
meta ["test"] fn () {
    // if-err with value: recovers from error with default
    recovered if-err(err("bad"), "default")
    assert(is-ok(recovered), "if-err with value recovers to Ok")

    // if-err with Ok: passes through unchanged
    ok-through if-err(ok(42), "default")
    assert(is-ok(ok-through), "if-err on Ok passes through")

    // if-err with function: transforms error
    transformed if-err(err("bad"), (e) { err(`wrapped: ${e}`) })
    assert(is-err(transformed), "if-err fn can produce new Err")

    // Chain: recover from error
    pipeline err("fail")
        |> if-err("recovered")
    assert(is-ok(pipeline), "if-err recovers from error in pipeline")

    // Combine if-ok and if-err
    combo ok(10)
        |> if-ok((n) { mul(n, 2) })
        |> if-err("fallback")
    assert(is-ok(combo), "combo if-ok then if-err on Ok")
}


// is-result recognizes Result values without unwrapping them
test-is-result
meta ["test"] fn () {
    assert(is-result(ok(42)), "ok value is a Result")
    assert(is-result(err("fail")), "err value is a Result")
    assert(not(is-result(42)), "plain Int is not a Result")
    assert(not(is-result("ok")), "plain Str is not a Result")
}

// ok-value extracts Ok payloads; plain values pass through
test-ok-value
meta ["test"] fn () {
    assert-eq(42, ok-value(ok(42)), "Ok payload extracted")
    assert-eq(42, ok-value(42), "plain value passes through")
    assert(is-null(ok-value(err("fail"))), "Err yields null")
}

// err-value extracts Err payloads without re-triggering the error
test-err-value
meta ["test"] fn () {
    assert-eq("boom", err-value(err("boom")), "Err payload extracted")
    assert(is-null(err-value(ok(42))), "Ok yields null")
    assert(is-null(err-value(42)), "plain value yields null")
}

// Regression: the contain boundary is idempotent on Results — a callee that
// returns an Err value comes back as that same single Err (not
// Ok(Err), which is-err could not see; not Err(Err), which err-value
// could not unwrap). The escalation-message half of this bug is pinned
// in Rust (vm.rs test_result_err_message_extraction).
test-try-is-idempotent-on-results
meta ["test"] fn () {
    caught ::hot::internal::exec/contain(() { err("the real reason") })
    assert(is-err(caught), "returned Err stays an Err through the boundary")
    assert-eq("the real reason", err-value(caught), "payload is not re-wrapped")

    passed ::hot::internal::exec/contain(() { ok(7) })
    assert(is-ok(passed), "returned Ok stays Ok")
    assert-eq(7, ok-value(passed), "Ok payload intact")
}

// Regression: an Err used inside a lambda body escalates with the
// payload's actual message in every execution context — the lambda
// executor's Call handler prepares arguments exactly like the main
// interpreter loop (this used to produce "add requires numbers"
// under the test runner while eval escalated correctly).
test-err-escalation-carries-message
meta ["test"] fn () {
    use-it fn (): Any {
        e err("the real reason")
        add(e, 1)
    }
    caught ::hot::internal::exec/contain(use-it)
    assert(is-err(caught), "escalation caught at the boundary")
    assert(contains(Str(err-value(caught)), "the real reason"), "halt carries the payload message")
}

// err-message extracts human-readable text from every payload shape
// in the convention: plain Str, {message}, halt Failure ({msg} under a
// typed wrapper), and bare payloads.
test-err-message
meta ["test"] fn () {
    assert-eq("connection refused", err-message(err("connection refused")), "Str payload")
    assert-eq("pg: bad", err-message(err({message: "pg: bad", code: "42P01"})), "message field")
    caught ::hot::internal::exec/contain(() { fail("boom", {why: "test"}) })
    assert-eq("boom", err-message(caught), "halt Failure msg")
    assert-eq("bare", err-message("bare"), "bare payload passes through")
}

// Fan-out isolation without a halt boundary: OnErr.Preserve keeps a
// per-item Err in its slot so one bad item never kills the loop.
test-map-onerr-preserve-fan-out
meta ["test"] fn () {
    step fn (x: Int): Any { if(eq(x, 2), err("bad item"), x) }
    results map([1, 2, 3], step, OnErr.Preserve)
    assert-eq(3, length(results), "every slot survives")
    assert(not(is-err(results[0])), "good slot is plain")
    assert(is-err(results[1]), "bad slot is an Err")
    assert-eq("bad item", err-value(results[1]), "Err payload intact")
    assert-eq(3, results[2], "later slots still ran")
}
