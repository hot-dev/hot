::whatsapp::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the whatsapp integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "whatsapp.access.token": ::env/get("WHATSAPP_ACCESS_TOKEN", ""),
    "whatsapp.app.secret": ::env/get("WHATSAPP_APP_SECRET", ""),
    "whatsapp.verify.token": ::env/get("WHATSAPP_VERIFY_TOKEN", ""),
})
