delete-message
meta {
    doc: """deleteMessage - Delete a message. Bots can delete messages they sent, messages in private chats, and messages in groups/channels where they have delete permissions."""
}
fn (request: DeleteMessageRequest): Bool {
  api-request("deleteMessage", untype(request))
}

DeleteMessagesRequest type {
  chat_id: Any,
  message_ids: Vec<Int>
}

delete-messages
meta {
    doc: """deleteMessages - Delete multiple messages at once (up to 100). Messages must be from the same chat and no older than 48 hours."""
}
