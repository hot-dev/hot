::hot::conf ns

hot.set.profile "local-dev"
hot.set.project "mcp-tests"

hot.profile.local-dev.user.email "local@hot.dev"
hot.profile.local-dev.org.slug "local"
hot.profile.local-dev.env.name "development"

hot.project.mcp-tests.src.paths ["./src", "../hot-ai/src", "../json-rpc/src"]
hot.project.mcp-tests.test.paths ["./test"]
hot.project.mcp-tests.test.capture true

hot.db.uri "sqlite::memory:"
hot.db.schema "hot"
hot.log.level "warn"
hot.log.target "stdout"
