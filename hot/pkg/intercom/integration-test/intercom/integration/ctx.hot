::intercom::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the intercom integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "intercom.token": ::env/get("INTERCOM_TOKEN", ""),
    "intercom.admin.id": ::env/get("INTERCOM_ADMIN_ID", ""),
})
