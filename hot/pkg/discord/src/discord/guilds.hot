CreateGuildBanRequest type {
  guild_id: Str,
  user_id: Str,
  delete_message_seconds: Int?
}

create-guild-ban
meta {
    doc: """PUT /guilds/{guild_id}/bans/{user_id} - Ban a user from the guild. `delete_message_seconds` (0-604800) controls how many seconds of messages to delete. Requires BAN_MEMBERS."""
}
fn (request: CreateGuildBanRequest): Bool {
  body {
    delete_message_seconds: request.delete_message_seconds
  }

  response api-request("PUT", `${::discord::core/BASE_URL}/guilds/${request.guild_id}/bans/${request.user_id}`, {}, body)
  if(is-ok-response(response), true, err(HttpError(response)))
}

