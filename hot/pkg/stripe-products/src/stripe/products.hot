list-all-products
meta {doc: """GET /v1/products - List all products"""}
fn (active: Str, created: Str, ending-before: Str, expand: Str, ids: Str, limit: Str, shippable: Str, starting-after: Str, url: Str, request: GetProductsRequest): GetProductsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/products?active=${active}&created=${created}&ending_before=${ending-before}&expand=${expand}&ids=${ids}&limit=${limit}&shippable=${shippable}&starting_after=${starting-after}&url=${url}`, {}, request)
  if(is-ok-response(response), GetProductsResponse(response.body), err(HttpError(response)))
}

