list-all-balance-transactions
meta {doc: """GET /v1/balance_transactions - List all balance transactions"""}
fn (created: Str, currency: Str, ending-before: Str, expand: Str, limit: Str, payout: Str, source: Str, starting-after: Str, type-param: Str, request: GetBalanceTransactionsRequest): GetBalanceTransactionsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/balance_transactions?created=${created}&currency=${currency}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&payout=${payout}&source=${source}&starting_after=${starting-after}&type=${type-param}`, {}, request)
  if(is-ok-response(response), GetBalanceTransactionsResponse(response.body), err(HttpError(response)))
}

