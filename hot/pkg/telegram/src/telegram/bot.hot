// ============================================================================
// Commands
// ============================================================================

GetMyCommandsRequest type {
  scope: Map?,
  language_code: Str?
}

get-my-commands
meta {
    doc: """
getMyCommands - Get the bot's command list. `scope` filters by context (e.g. `{type: "all_private_chats"}` or `{type: "chat", chat_id: 123}`).

**Example**

```hot
::bot ::telegram::bot

commands ::bot/get-my-commands(::bot/GetMyCommandsRequest({}))
// => [{command: "start", description: "Start the bot"}, {command: "help", description: "Show help"}]
```
"""
}
fn (request: GetMyCommandsRequest): Vec<Map> {
  api-request("getMyCommands", untype(request))
}

SetMyCommandsRequest type {
  commands: Vec<Map>,
  scope: Map?,
  language_code: Str?
}

set-my-commands
meta {
    doc: """
setMyCommands - Set the bot's command list. Each command is `{command: "name", description: "What it does"}`. Max 100 commands.

**Example**

```hot
::bot ::telegram::bot

::bot/set-my-commands(::bot/SetMyCommandsRequest({
  commands: [
    {command: "start", description: "Start the bot"},
    {command: "help", description: "Show help"},
    {command: "status", description: "Check system status"}
  ]
}))
```
"""
}
fn (request: SetMyCommandsRequest): Bool {
  api-request("setMyCommands", untype(request))
}

DeleteMyCommandsRequest type {
  scope: Map?,
  language_code: Str?
}

delete-my-commands
meta {
    doc: """deleteMyCommands - Delete the bot's command list for the given scope and language."""
}
fn (request: DeleteMyCommandsRequest): Bool {
  api-request("deleteMyCommands", untype(request))
}
