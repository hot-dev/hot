::plaid::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the plaid integration suite. Unset
// environment variables are skipped entirely, so absent credentials
// behave exactly as if never configured.
::hot::ctx/set(filter-vals({
    "plaid.client-id": ::env/get("PLAID_CLIENT_ID", ""),
    "plaid.secret": ::env/get("PLAID_SECRET", ""),
    "plaid.env": ::env/get("PLAID_ENV", ""),
}, (v) { not(is-empty(v)) }))
