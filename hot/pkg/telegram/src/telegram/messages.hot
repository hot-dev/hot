// ============================================================================
// Callback Queries
// ============================================================================

AnswerCallbackQueryRequest type {
  callback_query_id: Str,
  text: Str?,
  show_alert: Bool?,
  url: Str?,
  cache_time: Int?
}

answer-callback-query
meta {
    doc: """
answerCallbackQuery - Respond to a callback query from an inline keyboard button. Must be called even if no notification is needed. Set `show_alert: true` for a popup instead of a toast.

**Example**

```hot
::messages ::telegram::messages

::messages/answer-callback-query(::messages/AnswerCallbackQueryRequest({
  callback_query_id: event.callback_query.id,
  text: "Button pressed!"
}))
```
"""
}
fn (request: AnswerCallbackQueryRequest): Bool {
  api-request("answerCallbackQuery", untype(request))
}
