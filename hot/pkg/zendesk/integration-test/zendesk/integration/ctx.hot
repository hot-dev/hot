::zendesk::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the zendesk integration suite. Empty strings
// are falsy, so unset variables behave exactly like absent context.
::hot::ctx/set({
    "zendesk.subdomain": ::env/get("ZENDESK_SUBDOMAIN", ""),
    "zendesk.email": ::env/get("ZENDESK_EMAIL", ""),
    "zendesk.api.token": ::env/get("ZENDESK_API_TOKEN", ""),
})
