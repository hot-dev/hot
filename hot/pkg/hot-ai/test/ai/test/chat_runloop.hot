// ============================================================================
// emit-steps observability hook
// ============================================================================

test-run-loop-emit-steps-default-off
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-end-immediately,
        model: "mock-model"
    })
    result ::chat/run-loop(opts, "hi")
    assert-eq("Hello from mock!", result)
}

test-run-loop-emit-steps-on-no-stream-context
meta {
    doc: """
    With `emit-steps: true`, every turn calls `::hot::stream/data`.
    There is no stream context in unit tests, so the call returns an
    Err, but the helper swallows it via `if-err` and the loop must
    still terminate normally.
    """
}

meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-fn: mock-chat-one-tool-then-end,
        model: "mock-model",
        tools: [::tool/from-fn(add-fn)],
        emit-steps: true
    })
    result ::chat/run-loop(opts, "what is 2 + 3?")
    assert-eq("The answer is 5.", result)
}

// ============================================================================
// Streaming run-loop
// ============================================================================

mock-stream-end-immediately
meta {
    doc: """Streaming mock: emits two text deltas + Stop, no tool calls."""
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::chat/Message>?, on-delta: Fn): ::chat/ChatReply {
    on-delta(ReplyDelta.TextDelta(TextDelta({text: "Hello "})))
    on-delta(ReplyDelta.TextDelta(TextDelta({text: "world!"})))
    reply ::chat/ChatReply({
        text: "Hello world!",
        tool-calls: null,
        stop-reason: "end_turn",
        usage: {input-tokens: 5, output-tokens: 3},
        raw: null
    })
    on-delta(ReplyDelta.Stop(StreamStop({reason: reply.stop-reason, usage: reply.usage})))
    reply
}

mock-stream-one-tool-then-end
meta {
    doc: """Streaming mock: requests `add-fn(2,3)` first; returns final answer once it sees the tool result."""
}
fn (model: Str, messages: Vec<::chat/Message>, system: Str?, tools: Vec<::chat/Message>?, on-delta: Fn): ::chat/ChatReply {
    has-tool-result some(messages, eq(%.role, "tool"))
    cond {
        has-tool-result => {
            on-delta(ReplyDelta.TextDelta(TextDelta({text: "The answer is "})))
            tool-msg find-first(messages, eq(%.role, "tool"))
            on-delta(ReplyDelta.TextDelta(TextDelta({text: `${tool-msg.content}.`})))
            reply ::chat/ChatReply({
                text: `The answer is ${tool-msg.content}.`,
                tool-calls: null,
                stop-reason: "end_turn",
                usage: null,
                raw: null
            })
            on-delta(ReplyDelta.Stop(StreamStop({reason: reply.stop-reason, usage: reply.usage})))
            reply
        }
        => {
            call ::tool/ToolCall({
                id: "call-1",
                name: "::ai::test::chat_runloop/add-fn",
                input: {x: 2, y: 3}
            })
            on-delta(ReplyDelta.ToolUseStart(ToolUseStart({id: "call-1", name: "::ai::test::chat_runloop/add-fn"})))
            on-delta(ReplyDelta.ToolUseInputDelta(ToolUseInputDelta({id: "call-1", partial-input-json: "{\"x\":2,\"y\":3}"})))
            on-delta(ReplyDelta.ToolUseEnd(ToolUseEnd({id: "call-1"})))
            reply ::chat/ChatReply({
                text: null,
                tool-calls: [call],
                stop-reason: "tool_use",
                usage: null,
                raw: null
            })
            on-delta(ReplyDelta.Stop(StreamStop({reason: reply.stop-reason, usage: reply.usage})))
            reply
        }
    }
}

test-run-loop-stream-immediate-end
meta ["test"]
fn () {
    opts ::chat/ChatOptions({
        chat-stream-fn: mock-stream-end-immediately,
        model: "mock-model"
