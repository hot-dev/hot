::ai::rag ns
meta {
    doc: "Retrieve-Augment-Generate: compose memory search with AI generation. Accepts chat-fn parameter for provider-free AI calls."
}

ChatOptions ::ai::chat/ChatOptions
AgentMemory ::ai::memory/AgentMemory
Thread      ::ai::memory/Thread
MemoryCapsule ::ai::memory/MemoryCapsule
Role        ::ai::message/Role

// ============================================================================
// Pure helpers (testable without stores)
// ============================================================================

format-session-results
meta {
    doc: "Format a Vec of store search results (with v.sender-name, v.content) as `[name]: content` lines."
}
fn (results: Vec): Vec {
    map(results, (r) {
        `[${or(r.value.sender-name, "unknown")}]: ${r.value.content}`
    })
}

format-kb-results
meta { doc: "Format a Vec of KB search results as `[KB] content` lines." }
fn (results: Vec): Vec {
    map(results, (r) {
        content get(r.value, "content", to-json(r.value))
        `[KB] ${content}`
    })
}

format-thread-lines
meta { doc: "Format a Vec of ChatMessages as `role: content` lines." }
fn (history: Vec): Str {
    cond {
        is-empty(history) => { "" }
        => {
            lines map(history, (m) {
                role-str match m.role {
                    Role.User      => { "user" }
                    Role.Assistant => { "assistant" }
                    Role.System    => { "system" }
                }
                `${role-str}: ${m.content}`
            })
            concat("Previous conversation:\n", join(lines, "\n"), "\n---\n")
        }
    }
}

build-rag-prompt
meta {
    doc: "Compose a RAG prompt from optional history, optional context, and a question."
}
fn (history-text: Str, context: Str, question: Str): Str {
    cond {
        and(is-empty(context), is-empty(history-text)) => { question }
        is-empty(history-text) => {
            ```
            Context from memory:
            ${context}

            ---
            Question: ${question}
            ```
        }

        is-empty(context) => {
            ```
            ${history-text}Question: ${question}
            ```
        }
        => {
            ```
            ${history-text}Context from memory:
            ${context}

            ---
            Question: ${question}
            ```
        }
    }
}

DEFAULT_SYSTEM "You are a helpful AI assistant. Answer based on the provided context. Cite sources when possible."
DEFAULT_SYSTEM_THREAD "You are a helpful AI assistant. Answer based on the provided context and conversation history."
DEFAULT_SUMMARY_SYSTEM "You are a helpful assistant that summarizes conversations concisely."
DEFAULT_SUMMARY_INSTRUCTION "Summarize the key topics, decisions, and action items from this conversation."

DEFAULT_MEMORY_HEADING "## Memory"

with-memory-block
meta {
    doc: """
    Compose a system prompt by appending a memory-context section to `base`.

    Returns `base` unchanged when `context` is empty (or whitespace only), so
    callers can pass the result of `build-context` / `build-context-safe`
    directly without branching. When `context` is non-empty, the result is
    `${base}\n\n${heading}\n${context}`. `heading` defaults to `## Memory`.
    """
}
fn (base: Str, context: Str, heading: Str?): Str {
    h or(heading, DEFAULT_MEMORY_HEADING)
    cond {
        is-empty(trim(or(context, ""))) => { base }
        => { concat(base, "\n\n", h, "\n", context) }
    }
}

role-of
meta {
    doc: """
    Read the `role` tag from a `::ai::memory/recent` entry's metadata.
    Returns `""` when unset so role filters never accidentally drop
    untagged records (callers asking to exclude `assistant` shouldn't
    also exclude legacy un-roled writes).
    """
}
fn (entry: Map): Str {
    meta or(get-in(entry, ["value", "metadata"]), {})
    Str(or(get(meta, "role"), ""))
}

role-in
meta { doc: "True when `role` equals any element of `roles`." }
fn (roles: Vec, role: Str): Bool {
    some(roles, (r) { eq(r, role) })
}

passes-role-filter
meta {
    doc: """
    Apply `include-roles` / `exclude-roles` semantics:

    - When `include-roles` is non-empty, the entry must have a role in
      that list. Untagged entries are dropped.
    - `exclude-roles` is a blacklist applied next. Tagged matches are
      dropped; untagged entries pass.
    - With neither set, every entry passes.
    """
}
fn (entry: Map, include-roles: Vec?, exclude-roles: Vec?): Bool {
    role role-of(entry)
    inc or(include-roles, [])
    exc or(exclude-roles, [])
    include-pass cond {
        is-empty(inc) => { true }
        => { role-in(inc, role) }
    }

    exclude-pass cond {
        is-empty(exc) => { true }
        => { not(role-in(exc, role)) }
    }

    and(include-pass, exclude-pass)
}

recent-text
meta {
    doc: """
    Format recent session memory as bulleted `- <content>` lines, oldest
    first.

    Convenience over `::ai::memory/recent` for synthesis prompts that want
    the raw window as text rather than a finished summary. Errors degrade
    to `""` so missing stores / providers don't crash callers.

    Options:
    - `limit` — number of records to include (default 100, matches
      `::ai::memory/recent`).
    - `hours` — recency window in hours (default 24).
    - `include-roles` — `Vec<Str>?`. When set, only records whose
      `metadata.role` is in this list are kept. Untagged records are
      dropped.
    - `exclude-roles` — `Vec<Str>?`. When set, records whose
      `metadata.role` is in this list are dropped. Untagged records
      pass.

    The role filters compose with `limit`: filtering happens after
    `recent`, so `limit` bounds the window, not the post-filter count.
    For synthesis prompts that want only user turns + task records,
    pass `exclude-roles: ["assistant"]`.
    """
}
fn (mem: AgentMemory, opts: Map?): Str {
    o or(opts, {})
    records if-err(::ai::memory/recent(mem, o), [])
    include-roles get(o, "include-roles", null)
    exclude-roles get(o, "exclude-roles", null)
    kept cond {
        and(is-null(include-roles), is-null(exclude-roles)) => { records }
        => {
            filter(records, (entry) {
                passes-role-filter(entry, include-roles, exclude-roles)
            })
        }
    }

    cond {
        is-empty(kept) => { "" }
        => {
            lines map(kept, (entry) {
                content or(entry.value.content, "")
                `- ${content}`
            })
            join(lines, "\n")
        }
    }
}

// ============================================================================
// Core RAG (impure — uses AgentMemory)
// ============================================================================

build-context
meta {
    doc: "Search session memory and KB, format as a context string for AI prompts. Options: limit (default 10), min-score (default 0.5)."
}
fn (mem: AgentMemory, query: Str, opts: Map?): Str {
    limit get(or(opts, {}), "limit", 10)
    min-score get(or(opts, {}), "min-score", 0.5)
    search-opts {limit: limit, min-score: min-score}

    // Guard both searches: an unconfigured embedding provider (or store)
    // errs here, and that Err must propagate as a value — handing it to
    // the format fns would iterate the Err's internals instead.
    session-results ::ai::memory/recall(mem, query, search-opts)
    match session-results {
        Result.Err => { err(session-results) }

        _ => {
            kb-results ::ai::memory/search-kb(mem, query, {limit: limit})
            match kb-results {
                Result.Err => { err(kb-results) }

                _ => {
                    all-lines concat(format-session-results(session-results), format-kb-results(kb-results))
                    if(is-empty(all-lines), "", join(all-lines, "\n"))
                }
            }
        }
    }
}

build-context-safe
meta {
    doc: """
    Best-effort `build-context`. Any failure (no embedding provider
    configured, transient store error, etc.) degrades to `""` so callers
    can still answer ungrounded rather than aborting the whole reply.

    Use this in interactive request paths and demos / CI / offline
    tutorials where an embedding backend may not be wired. Prefer
    `build-context` directly in code paths that should propagate errors.
    """
}
fn (mem: AgentMemory, query: Str, opts: Map?): Str {
    if-err(build-context(mem, query, opts), "")
}

ask
meta {
    doc: "Search memory for relevant context, then generate an AI answer. Returns {answer, sources}."
}
fn (mem: AgentMemory, question: Str, chat-opts: ChatOptions, opts: Map?): Map {
    context build-context(mem, question, opts)
    match context {
        Result.Err => { err(context) }

        _ => { ask-with-context(mem, question, chat-opts, opts, context) }
    }
}

ask-with-context fn (mem: AgentMemory, question: Str, chat-opts: ChatOptions, opts: Map?, context: Str): Map {
    prompt build-rag-prompt("", context, question)
    system or(chat-opts.system, DEFAULT_SYSTEM)
    answer chat-opts.chat-fn(chat-opts.model, prompt, system)
    sources ::ai::memory/recall(mem, question, opts)
    {answer: answer, sources: sources}
}

ask-with-thread
meta {
    doc: "Like ask, but includes thread history for multi-turn context. Appends question and answer to the thread automatically."
}
fn (mem: AgentMemory, t: Thread, question: Str, chat-opts: ChatOptions, opts: Map?): Map {
    context build-context(mem, question, opts)
    history ::ai::memory/thread-history(t, null)
    history-text format-thread-lines(history)
    prompt build-rag-prompt(history-text, context, question)
    system or(chat-opts.system, DEFAULT_SYSTEM_THREAD)
    answer chat-opts.chat-fn(chat-opts.model, prompt, system)

    ::ai::memory/thread-add(t, Role.User, question)
    ::ai::memory/thread-add(t, Role.Assistant, answer)

    sources ::ai::memory/recall(mem, question, opts)
    {answer: answer, sources: sources}
}

summarize
meta {
    doc: "Summarize recent messages from session memory using AI. Options: hours, limit, instruction."
}
fn (mem: AgentMemory, chat-opts: ChatOptions, opts: Map?): Str {
    messages ::ai::memory/recent(mem, opts)

    cond {
        is-empty(messages) => { "No messages found in the time window." }
        => {
            lines map(messages, (entry) {
                `[${or(entry.value.sender-name, "unknown")}]: ${entry.value.content}`
            })
            instruction get(or(opts, {}), "instruction", DEFAULT_SUMMARY_INSTRUCTION)
            prompt ```
            Here are ${length(messages)} recent messages:

            ${join(lines, "\n")}

            ---
            ${instruction}
            ```
            system or(chat-opts.system, DEFAULT_SUMMARY_SYSTEM)
            chat-opts.chat-fn(chat-opts.model, prompt, system)
        }
    }
}

compact-window
meta {
    doc: "Summarize a recent memory window into a durable MemoryCapsule and store it in the KB. Options: hours, limit, id, instruction, metadata, emit-stream."
}
fn (mem: AgentMemory, chat-opts: ChatOptions, opts: Map?): MemoryCapsule {
    o or(opts, {})
    capsule-id get(o, "id", `capsule:${Uuid()}`)
    emit-stream-on get(o, "emit-stream", false)

    cond {
        emit-stream-on => {
        if-err(::hot::stream/data(::ai::stream-labels/RAG_COMPACTION_START, {
            agent-name: mem.agent-name,
            capsule-id: capsule-id,
            opts: o,
        }), null)
    }
    }

    messages ::ai::memory/recent(mem, o)
    summary summarize(mem, chat-opts, o)
    capsule ::ai::memory/capsule-from-window(capsule-id, summary, messages, o)
    ::ai::memory/store-capsule(mem, capsule)

    cond {
        emit-stream-on => {
        if-err(::hot::stream/data(::ai::stream-labels/RAG_COMPACTION_END, {
            agent-name: mem.agent-name,
            capsule-id: capsule-id,
            source-count: length(messages),
        }), null)
    }
    }

    capsule
}

compact-window-safe
meta {
    doc: "Like `compact-window`, returning `{ok, capsule, error}` and emitting compaction errors when requested."
}
fn (mem: AgentMemory, chat-opts: ChatOptions, opts: Map?): Map {
    res if-err(compact-window(mem, chat-opts, opts), (err) {
        o or(opts, {})
        cond {
            get(o, "emit-stream", false) => {
            if-err(::hot::stream/data(::ai::stream-labels/RAG_COMPACTION_ERROR, {
                agent-name: mem.agent-name,
                error: Str(err),
            }), null)
        }
        }
        {
            ok: false,
            capsule: null,
            error: Str(err),
        }
    })
    cond {
        and(is-map(res), contains(keys(res), "ok")) => { res }
        => {
            {
                ok: true,
                capsule: res,
                error: null,
            }
        }
    }
}

build-hybrid-context
meta {
    doc: "Build a citation-preserving context string from hybrid vector + graph retrieval."
}
fn (mem: AgentMemory, query: Str, opts: Map?): Str {
    result ::ai::memory/hybrid-recall(mem, query, opts)
    lines map(result.citations, (c) {
        label or(c.label, c.id)
        excerpt or(c.excerpt, "")
        `[${label}] ${excerpt}`
    })
    join(lines, "\n")
}
