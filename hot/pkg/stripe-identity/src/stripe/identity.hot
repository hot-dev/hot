list-verificationreports
meta {doc: """GET /v1/identity/verification_reports - List VerificationReports"""}
fn (client-reference-id: Str, created: Str, ending-before: Str, expand: Str, limit: Str, starting-after: Str, type-param: Str, verification-session: Str, request: GetIdentityVerificationReportsRequest): GetIdentityVerificationReportsResponse {
  response api-request("GET", `${::stripe/BASE_URL}/v1/identity/verification_reports?client_reference_id=${client-reference-id}&created=${created}&ending_before=${ending-before}&expand=${expand}&limit=${limit}&starting_after=${starting-after}&type=${type-param}&verification_session=${verification-session}`, {}, request)
  if(is-ok-response(response), GetIdentityVerificationReportsResponse(response.body), err(HttpError(response)))
}

