::zendesk::integration::ctx ns

::env ::hot::env

// Placeholder credentials for the zendesk integration suite. Unset
// environment variables are skipped entirely, so absent credentials
// behave exactly as if never configured.
::hot::ctx/set(filter-vals({
    "zendesk.subdomain": ::env/get("ZENDESK_SUBDOMAIN", ""),
    "zendesk.email": ::env/get("ZENDESK_EMAIL", ""),
    "zendesk.api.token": ::env/get("ZENDESK_API_TOKEN", ""),
}, (v) { not(is-empty(v)) }))
